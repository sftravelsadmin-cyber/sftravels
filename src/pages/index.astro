<style>
  /* ==================== HERO & BOOKING STYLES ==================== */
  .hero-section {
    min-height: 100vh;
    position: relative;
    padding-top: 130px;
    padding-bottom: 80px;
    display: flex;
    align-items: center;
    background-image: url('https://images.unsplash.com/photo-1549399542-7e3f8b79c341?q=80&w=1600&auto=format&fit=crop');
    background-size: cover;
    background-position: center center;
    overflow: hidden;
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(5, 13, 26, 0.9) 0%, rgba(5, 13, 26, 0.75) 100%);
    z-index: 1;
  }
  
  .hero-container {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    width: 100%;
  }
  
  .hero-text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .hero-title {
    font-size: 3.8rem;
    line-height: 1.15;
    font-weight: 800;
    text-shadow: 0 4px 12px rgba(5, 13, 26, 0.5);
  }
  
  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-light);
    max-width: 650px;
    line-height: 1.7;
    opacity: 0.95;
    text-shadow: 0 2px 8px rgba(5, 13, 26, 0.5);
  }
  
  /* Enquiry Form Booking Card - Premium Horizontal Dashboard Layout */
  .booking-card {
    background: #ffffff !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border: 1px solid rgba(0, 0, 0, 0.08) !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25) !important;
    display: flex;
    flex-direction: row;
    padding: 0 !important; /* Let children touch edge for side-bar framing */
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: var(--transition-smooth);
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
  }
  
  .booking-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3) !important;
    border-color: rgba(16, 185, 129, 0.3) !important;
  }

  .booking-sidebar {
    width: 250px;
    background: #f9fafb;
    padding: 30px 24px;
    border-right: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .booking-sidebar-title {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: #9ca3af;
    margin-bottom: 20px;
  }

  .booking-body {
    flex: 1;
    padding: 30px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .service-tabs {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }
  
  .tab-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 16px 20px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: #4b5563;
    cursor: pointer;
    transition: var(--transition-smooth);
    text-align: left;
  }
  
  .tab-btn:hover {
    background: #f9fafb;
    color: var(--brand-gold);
    border-color: rgba(16, 185, 129, 0.2);
  }
  
  .tab-btn.active {
    background: var(--brand-gold) !important;
    color: var(--text-white) !important;
    border-color: var(--brand-gold) !important;
    box-shadow: 0 6px 15px rgba(16, 185, 129, 0.22);
    transform: translateX(6px) scale(1.02);
  }

  .tab-icon {
    width: 20px;
    height: 20px;
    stroke-width: 2.2;
    flex-shrink: 0;
    color: var(--brand-gold);
    transition: var(--transition-smooth);
  }

  .tab-btn.active .tab-icon {
    color: #ffffff !important;
  }
  
  .booking-form {
    display: flex;
    flex-direction: column;
  }
  
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
