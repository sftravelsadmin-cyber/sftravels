  { id: "tempo-traveller-12", name: "Tempo Traveller 12", seats: "12", luggage: "8 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-12-1770871044575-9.png" },
  { id: "tempo-traveller-13", name: "Tempo Traveller 13", seats: "13", luggage: "9 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-13-1770871064897-30.png" },
