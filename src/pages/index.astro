  /* Premium Map Modal Styling */
  .map-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 13, 26, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
