  { id: "bus-33", name: "Bus 33", seats: "33", luggage: "30 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-33-1770871212474-45.png" },
