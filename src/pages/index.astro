---
import Layout from '../layouts/Layout.astro';
import { blogPosts } from '../data/blog.js';

const featuredBlogPosts = blogPosts.slice(0, 3);
const carsFleet = [
  { id: "hatchback", name: "Hatchback", desc: "Compact & economical, ideal for quick city trips and solo travellers.", seats: "4", luggage: "1-2 Bags", category: "car", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/hatchback-1770872540052-15.png" },
  { id: "sedan", name: "Sedan", desc: "Sleek and comfortable, perfect for business rides or airport transfers.", seats: "4", luggage: "2 Bags", category: "car", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/sedan-1770872682504-18.png" },
  { id: "ertiga", name: "Ertiga", desc: "Affordable 6-seater MPV, perfect for family travel on a budget.", seats: "6", luggage: "3 Bags", category: "mpv", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/ertiga-1770870707273-12.png" },
  { id: "innova", name: "Innova", desc: "The industry standard for comfortable, reliable long-distance travel.", seats: "7", luggage: "4 Bags", category: "mpv", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-1770870734987-27.png" },
  { id: "innova-crysta", name: "Innova Crysta", desc: "Premium executive MPV with captain seats and high luxury cabin space.", seats: "7", luggage: "4 Bags", category: "mpv", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-crysta-1770870762832-21.png" },
  { id: "innova-hycross", name: "Innova Hycross", desc: "Eco-friendly premium hybrid MPV with state-of-the-art features.", seats: "7", luggage: "4 Bags", category: "mpv", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-hycross-1770870785541-24.png" }
];

const urbaniaFleet = [
  { id: "force-urbania-deluxe", name: "Force Urbania Deluxe", desc: "Luxury 9-seater van with spacious stand-up cabin and individual AC.", seats: "9", luggage: "6-8 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-deluxe-1770870970157-1.png" },
  { id: "force-urbania-luxury", name: "Force Urbania Luxury", desc: "Premium 12-seater executive tourer for corporate group transport.", seats: "12", luggage: "8-10 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-luxury-1770870993546-3.png" },
  { id: "force-urbania-maharaj", name: "Force Urbania Maharaj", desc: "Super luxury 14-seater Maharaj coach with luxury recliner seating.", seats: "14", luggage: "10-12 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-maharaj-1770871014554-6.png" }
];

const tempoFleet = [
  { id: "tempo-traveller-12", name: "Tempo Traveller 12", desc: "Comfortable 12-seater touring coach, ideal for family picnics.", seats: "12", luggage: "8 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-12-1770871044575-9.png" },
  { id: "tempo-traveller-13", name: "Tempo Traveller 13", desc: "Spacious 13-seater passenger van for weddings and long tours.", seats: "13", luggage: "9 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-13-1770871064897-30.png" },
  { id: "tempo-traveller-14", name: "Tempo Traveller 14", desc: "Reliable 14-seater multi-utility touring van for outstation group trips.", seats: "14", luggage: "10 Bags", category: "van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-14-1770871083292-33.png" }
];

const busFleet = [
  { id: "mini-bus-21", name: "Mini Bus 21", desc: "21-seater compact coach, perfect for corporate events transit.", seats: "21", luggage: "15-20 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-21-1770871153503-36.png" },
  { id: "mini-bus-25", name: "Mini Bus 25", desc: "25-seater coach with rich audio-visual options and dual AC.", seats: "25", luggage: "20-25 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-25-1770871172403-39.png" },
  { id: "mini-bus-30", name: "Mini Bus 30", desc: "30-seater spacious coach for medium tours and long highway rides.", seats: "30", luggage: "25-30 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-30-1770871190798-42.png" },
  { id: "bus-33", name: "Bus 33", desc: "33-seater spacious bus, great for wedding guests and heavy groups.", seats: "33", luggage: "30 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-33-1770871212474-45.png" },
  { id: "bus-40", name: "Bus 40", desc: "40-seater luxury heavy coach with standard pushback seating.", seats: "40", luggage: "35-40 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-40-1770871824256-47.png" },
  { id: "volvo-bus-45", name: "Volvo Bus 45", desc: "45-seater multi-axle luxury coach with state-of-the-art air suspension.", seats: "45", luggage: "40-45 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/volvo-bus-45-1770872238415-49.png" },
  { id: "bus-50-seater", name: "Bus 50 Seater", desc: "50-seater heavy duty tourist coach for large excursions.", seats: "50", luggage: "45-50 Bags", category: "bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-50-1770872267131-52.png" }
];

const allFleet = [
  { label: "Cars", id: "tab-cars", fleet: carsFleet, category: "Cars Fleet" },
  { label: "Urbania Vans", id: "tab-urbania", fleet: urbaniaFleet, category: "Force Urbania Fleet" },
  { label: "Tempo Traveller", id: "tab-tempo", fleet: tempoFleet, category: "Tempo Traveller Fleet" },
  { label: "Buses", id: "tab-bus", fleet: busFleet, category: "Bus Fleet" }
];
---

<Layout
  title="SF Travels | Smooth Ride On Time - Corporate & Luxury Cabs Bangalore"
  description="Experience executive corporate mobility, professional airport transfers, and outstation trips with SF Travels in Bangalore. Transparent slab rate billing and verified chauffeurs."
>
  <!-- Flatpickr for Date Inputs -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr" is:inline></script>

  <div class="font-sans bg-white text-slate-800">

    <!-- ═══════════════════════════════════════════════════════════════
         HERO SECTION — Split Layout: Left copy + Right form
    ═══════════════════════════════════════════════════════════════ -->
    <section class="relative min-h-[85vh] lg:min-h-[90vh] flex items-center overflow-hidden pt-24 pb-12 bg-[#0d1629]">
      <!-- Full-bleed background with dark overlay -->
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://images.unsplash.com/photo-1608340173813-afedec884f1f?w=1920&q=80'); background-size: cover; background-position: center;">
      </div>
      <div class="absolute inset-0 bg-black/60 z-10"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
        <div class="max-w-4xl mx-auto text-center text-white mb-8">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-2 tracking-tight">
            <span class="text-white">Premium Rides,</span> <span class="text-[#D97706]">On Your Schedule</span>
          </h1>
        </div>

        <div class="max-w-6xl mx-auto">
          <!-- ── Booking Form Card ── -->
          <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-100">
            <!-- Tab bar -->
            <div class="bg-slate-50 px-5 py-4 border-b border-slate-200 flex flex-wrap gap-2 justify-center" id="serviceTabs">
              <button type="button" class="tab-btn flex items-center gap-2 px-6 py-3 rounded-xl text-base font-bold transition-all active-tab shadow" data-service="Outstation">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                Outstation
              </button>
              <button type="button" class="tab-btn flex items-center gap-2 px-6 py-3 rounded-xl text-base font-bold transition-all inactive-tab" data-service="Airport">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path></svg>
                Airport
              </button>
              <button type="button" class="tab-btn flex items-center gap-2 px-6 py-3 rounded-xl text-base font-bold transition-all inactive-tab" data-service="OneWay">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path></svg>
                One Way
              </button>
              <button type="button" class="tab-btn flex items-center gap-2 px-6 py-3 rounded-xl text-base font-bold transition-all inactive-tab" data-service="Local">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Local
              </button>
            </div>

            <!-- Form body -->
            <div class="p-6 sm:p-8">
              <form id="homepageBookingForm" class="flex flex-col gap-6">
                <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || "e2691c76-e159-4d9e-803f-cdf2fa4bebbe"} />
                <input type="hidden" name="subject" value="New Website Booking - {{fullName}} - SF Travels" />
                <input type="hidden" name="from_name" value="SF Travels Website" />
                <input type="hidden" name="service-type" id="serviceTypeInput" value="Outstation" />
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

                <!-- Row 1: Contact Info & Vehicle Type -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                  <!-- Full Name -->
                  <div>
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-wider mb-2">Full Name <span class="text-red-400">*</span></label>
                    <div class="relative">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                      <input type="text" name="fullName" placeholder="Your name" required class="w-full h-14 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-base sm:text-lg text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium">
                    </div>
                  </div>

                  <!-- Phone -->
                  <div>
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-wider mb-2">Phone <span class="text-red-400">*</span></label>
                    <div class="relative">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                      <input type="tel" name="phoneNumber" placeholder="10-digit number" maxlength="20" inputmode="numeric" required class="w-full h-14 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-base sm:text-lg text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium">
                    </div>
                  </div>

                  <!-- Select Vehicle -->
                  <div>
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-wider mb-2">Select Vehicle <span class="text-red-400">*</span></label>
                    <div class="relative">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 002 12v4c0 .6.4 1 1 1h2m2 0h6m2 0a2 2 0 114 0 2 2 0 01-4 0zM5 17a2 2 0 114 0 2 2 0 01-4 0z"></path></svg>
                      <select name="vehicleType" required class="w-full h-14 pl-12 pr-10 bg-slate-50 border border-slate-200 rounded-xl text-base sm:text-lg text-slate-800 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium appearance-none">
                        <option value="" disabled selected class="text-slate-400">Choose vehicle</option>
                        <optgroup label="Cars"><option value="Hatchback">Hatchback</option><option value="Sedan">Sedan</option></optgroup>
                        <optgroup label="SUVs & MPVs"><option value="Ertiga">Ertiga</option><option value="Innova">Innova</option><option value="Innova Crysta">Innova Crysta</option><option value="Innova Hycross">Innova Hycross</option></optgroup>
                        <optgroup label="Vans"><option value="Tempo Traveller 12">Tempo Traveller 12</option><option value="Tempo Traveller 13">Tempo Traveller 13</option><option value="Tempo Traveller 14">Tempo Traveller 14</option><option value="Force Urbania Deluxe">Force Urbania Deluxe</option><option value="Force Urbania Luxury">Force Urbania Luxury</option><option value="Force Urbania Maharaj">Force Urbania Maharaj</option></optgroup>
                        <optgroup label="Buses"><option value="Mini Bus 21">Mini Bus 21</option><option value="Mini Bus 25">Mini Bus 25</option><option value="Mini Bus 30">Mini Bus 30</option><option value="Bus 33">Bus 33</option><option value="Bus 40">Bus 40</option><option value="Volvo Bus 45">Volvo Bus 45</option><option value="Bus 50 Seater">Bus 50 Seater</option></optgroup>
                      </select>
                      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Row 2: Locations (2 cols for extra space) -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                  <!-- Pick Up Location -->
                  <div id="pickupLocationGroup" class="transition-all duration-300">
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-wider mb-2">Pick Up Location <span class="text-red-400">*</span></label>
                    <div class="relative flex gap-2 items-center">
                      <div class="relative flex-grow min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none z-10"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="pickupLocation" id="pickupLocationInput" placeholder="Enter pickup location" required class="w-full h-14 pl-12 pr-11 bg-slate-50 border border-slate-200 rounded-xl text-base sm:text-lg text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium truncate">
                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 p-1.5 hover:bg-slate-100 rounded-lg text-[#D97706] transition-colors z-20" id="pickupCurrentLocBtn" title="Use current location">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253"></path></svg>
                        </button>
                      </div>
                      <button type="button" class="flex-shrink-0 h-14 w-14 flex items-center justify-center bg-slate-50 border border-slate-200 rounded-xl hover:bg-[#1E2D5A] hover:text-white hover:border-[#1E2D5A] transition-all text-slate-500" id="pickupMapBtn" title="Pick on Map">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-6 h-6"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
                      </button>
                    </div>
                  </div>

                  <!-- Drop Off Location -->
                  <div id="dropoffGroup" class="transition-all duration-300">
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-wider mb-2">Drop Off Location <span class="text-red-400">*</span></label>
                    <div class="relative flex gap-2 items-center">
                      <div class="relative flex-grow min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none z-10"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="dropoffLocation" id="dropoffLocationInput" placeholder="Enter dropoff location" required class="w-full h-14 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium truncate">
                      </div>
                      <button type="button" class="flex-shrink-0 h-14 w-14 flex items-center justify-center bg-slate-50 border border-slate-200 rounded-xl hover:bg-[#1E2D5A] hover:text-white hover:border-[#1E2D5A] transition-all text-slate-500" id="dropoffMapBtn" title="Pick on Map">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-6 h-6"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" x2="9" y1="3" x2="9" y2="18"></line><line x1="15" x2="15" y1="6" x2="15" y2="21"></line></svg>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Row 3: Schedule & CTA -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                  <!-- Pick Up Date & Time -->
                  <div id="pickupDateGroup" class="transition-all duration-300">
                    <label class="block text-sm font-bold text-slate-600 uppercase tracking-wider mb-2">Pick Up Date & Time <span class="text-red-400">*</span></label>
                    <div class="grid grid-cols-2 gap-2">
                      <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <input type="text" name="pickupDate" id="pickupDatePicker" placeholder="Select date" required class="w-full h-14 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium">
                      </div>
                      <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
