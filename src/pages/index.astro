  }
  
  .input-wrapper input, .input-wrapper select {
    width: 100%;
    height: 46px;
    background: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding-left: 40px;
    padding-right: 16px;
    color: #050d1a;
    font-size: 0.88rem;
    transition: var(--transition-smooth);
