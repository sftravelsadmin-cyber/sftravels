<!-- Core Interactive Script for Search Booking Tabs & Flatpickr Calendars -->
<script>
  import flatpickr from 'flatpickr';
  import 'flatpickr/dist/flatpickr.min.css';

  const initApp = () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const serviceTypeInput = document.getElementById('serviceTypeInput');
    const dropoffGroup = document.getElementById('dropoffGroup');
    const dropoffInput = dropoffGroup ? dropoffGroup.querySelector('input') : null;
    const returnGroup = document.getElementById('returnGroup');
    
    // Initialize Flatpickr calendars with premium brand theme and logic
    const pickupFP = flatpickr("#pickupDatePicker", {
      minDate: "today",
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "F j, Y",
      disableMobile: true,
      onChange: function(selectedDates, dateStr, instance) {
        if (returnFP) {
          returnFP.set('minDate', dateStr || "today");
        }
      }
    });

    const returnFP = flatpickr("#returnDatePicker", {
      minDate: "today",
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "F j, Y",
      disableMobile: true
    });

    // Remove required attribute from original hidden input elements to avoid Chrome's focus error
    const pickupInput = document.getElementById('pickupDatePicker');
    const returnInput = document.getElementById('returnDatePicker');
    if (pickupInput) pickupInput.removeAttribute('required');
    if (returnInput) returnInput.removeAttribute('required');

    // Set required attribute on flatpickr's visible text inputs
    if (pickupFP && pickupFP.altInput) {
      pickupFP.altInput.setAttribute('required', 'true');
    }
    if (returnFP && returnFP.altInput) {
      returnFP.altInput.setAttribute('required', 'true');
    }

    // Open native time picker when clicking anywhere on the time inputs (instead of having to click strictly on the clock icon)
    const timeInputs = document.querySelectorAll('.booking-form input[type="time"]');
    timeInputs.forEach(input => {
      if (input instanceof HTMLInputElement) {
        input.style.cursor = 'pointer';
        input.addEventListener('click', () => {
          try {
            if (typeof input.showPicker === 'function') {
              input.showPicker();
            }
          } catch (err) {
            console.warn('HTMLInputElement.showPicker() is not supported on this browser:', err);
          }
        });
      }
    });

    // ==================== GEOLOCATION & MAP SELECTION LOGIC ====================
    const pickupLocInput = document.getElementById('pickupLocationInput');
    const dropoffLocInput = document.getElementById('dropoffLocationInput');
    const pickupCurrentLocBtn = document.getElementById('pickupCurrentLocBtn');
    const dropoffCurrentLocBtn = document.getElementById('dropoffCurrentLocBtn');
    
    // Reusable function to handle geolocation reverse-geocoding
    const handleGeolocation = (btnElement, inputField) => {
      if (!btnElement || !inputField) return;
      
      btnElement.addEventListener('click', (e) => {
        e.preventDefault();
        
        if (!navigator || !navigator.geolocation) {
          alert("Geolocation is not supported by your browser or connection.\n\nNote: Modern browsers strictly require a secure context (such as https:// or http://localhost) to access location data. If you are accessing this page using an IP address (like 127.0.0.1 or a local network IP), the browser will block the sensor for security.");
          return;
        }

        const originalHTML = btnElement.innerHTML;
        btnElement.disabled = true;
        btnElement.innerHTML = `
          <svg class="animate-spin w-4 h-4 text-emerald-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        `;
        
        navigator.geolocation.getCurrentPosition(
          async (position) => {
            const lat = position.coords.latitude;
            const lon = position.coords.longitude;
            
            try {
              const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`);
              const data = await res.json();
              if (data && data.display_name) {
                inputField.value = data.display_name;
              } else {
                inputField.value = `Current Location (${lat.toFixed(5)}, ${lon.toFixed(5)})`;
              }
            } catch (err) {
              inputField.value = `Current Location (${lat.toFixed(5)}, ${lon.toFixed(5)})`;
            }
            btnElement.disabled = false;
            btnElement.innerHTML = originalHTML;
          },
          (error) => {
            console.error("Geolocation error:", error);
            let errMsg = "Could not retrieve current location. Please verify location permissions in your browser settings.";
            if (error.code === error.PERMISSION_DENIED) {
              errMsg = "Location request was denied. Please click the padlock or settings icon on the left of your browser address bar and change 'Location' permission to 'ALLOW' for this website.";
            } else if (error.code === error.POSITION_UNAVAILABLE) {
              errMsg = "Location information is unavailable. Please make sure Location Services are enabled in your operating system's settings.";
            } else if (error.code === error.TIMEOUT) {
              errMsg = "Location request timed out. Please check your network connection and try again.";
            }
            alert(errMsg);
            btnElement.disabled = false;
            btnElement.innerHTML = originalHTML;
          },
          { enableHighAccuracy: true, timeout: 6000 }
        );
      });
    };

    // Bind both buttons separately
    handleGeolocation(pickupCurrentLocBtn, pickupLocInput);
    handleGeolocation(dropoffCurrentLocBtn, dropoffLocInput);

    // 2. Leaflet Map Selection
    const mapModal = document.getElementById('mapModal');
    const pickupMapBtn = document.getElementById('pickupMapBtn');
    const dropoffMapBtn = document.getElementById('dropoffMapBtn');
    const closeMapModalBtn = document.getElementById('closeMapModalBtn');
    const confirmMapLocationBtn = document.getElementById('confirmMapLocationBtn');
    const addressPreview = document.getElementById('addressPreview');
    
    let activeInputTarget = null;
    let leafletMap = null;
    let leafletMarker = null;
    let selectedCoords = null;
    
    const fetchAddressFromMap = async (coords) => {
      addressPreview.innerText = "Resolving address details...";
      confirmMapLocationBtn.disabled = true;
      try {
        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${coords.lat}&lon=${coords.lng}`);
        const data = await res.json();
        if (data && data.display_name) {
          addressPreview.innerText = data.display_name;
          confirmMapLocationBtn.disabled = false;
        } else {
          addressPreview.innerText = `Coordinates: ${coords.lat.toFixed(5)}, ${coords.lng.toFixed(5)}`;
          confirmMapLocationBtn.disabled = false;
        }
      } catch (err) {
        addressPreview.innerText = `Coordinates: ${coords.lat.toFixed(5)}, ${coords.lng.toFixed(5)}`;
        confirmMapLocationBtn.disabled = false;
      }
    };
    
    const openMapModal = (targetInput) => {
      activeInputTarget = targetInput;
      addressPreview.innerText = "Click on the map to choose a location...";
      confirmMapLocationBtn.disabled = true;
      selectedCoords = null;
      
      if (mapModal) {
        mapModal.classList.add('active');
      }
      
      setTimeout(() => {
        if (typeof window.L === 'undefined') {
          console.error("Leaflet is not loaded yet.");
          return;
        }
        
        const defaultBangalore = [12.9716, 77.5946];
        
        if (!leafletMap) {
          leafletMap = window.L.map('mapContainer').setView(defaultBangalore, 12);
          window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
          }).addTo(leafletMap);
          
          leafletMap.on('click', async (e) => {
            const { lat, lng } = e.latlng;
            selectedCoords = { lat, lng };
            
            if (leafletMarker) {
              leafletMarker.setLatLng(e.latlng);
            } else {
              leafletMarker = window.L.marker(e.latlng, { draggable: true }).addTo(leafletMap);
              leafletMarker.on('dragend', async (ev) => {
                const markerLatLng = ev.target.getLatLng();
                selectedCoords = { lat: markerLatLng.lat, lng: markerLatLng.lng };
                await fetchAddressFromMap(selectedCoords);
              });
            }
            await fetchAddressFromMap(selectedCoords);
          });
        } else {
          leafletMap.invalidateSize();
          leafletMap.setView(defaultBangalore, 12);
          if (leafletMarker) {
            leafletMap.removeLayer(leafletMarker);
            leafletMarker = null;
          }
        }
        
        // Auto-detect current position to center map
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              const currentLatLng = [pos.coords.latitude, pos.coords.longitude];
              leafletMap.setView(currentLatLng, 15);
              if (leafletMarker) {
                leafletMarker.setLatLng(currentLatLng);
              } else {
                leafletMarker = window.L.marker(currentLatLng, { draggable: true }).addTo(leafletMap);
              }
              selectedCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude };
              fetchAddressFromMap(selectedCoords);
            },
            () => {
              console.log("Geolocation prompt dismissed or errored, defaulting map position.");
            }
          );
        }
      }, 350);
    };
    
    const closeMapModal = () => {
      if (mapModal) {
        mapModal.classList.remove('active');
      }
    };
    
    if (pickupMapBtn && pickupLocInput) {
      pickupMapBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openMapModal(pickupLocInput);
      });
    }
    
    if (dropoffMapBtn && dropoffLocInput) {
      dropoffMapBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openMapModal(dropoffLocInput);
      });
    }
    
    if (closeMapModalBtn) {
      closeMapModalBtn.addEventListener('click', (e) => {
        e.preventDefault();
        closeMapModal();
      });
    }
    
    if (confirmMapLocationBtn) {
      confirmMapLocationBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (activeInputTarget && addressPreview.innerText) {
          activeInputTarget.value = addressPreview.innerText;
          closeMapModal();
        }
      });
    }

    if (tabs && serviceTypeInput) {
      tabs.forEach(tab => {
        tab.addEventListener('click', (e) => {
          e.preventDefault();
          
          // Remove active class from all tabs
          tabs.forEach(t => t.classList.remove('active'));
          
          // Add active class to clicked tab
          tab.classList.add('active');
          
          const selectedService = tab.getAttribute('data-service') || 'Outstation';
          
          // Update hidden input
          serviceTypeInput.value = selectedService;
          
          // Toggle return date visibility (only show for Outstation roundtrip)
          if (returnGroup) {
            const dateAltInput = returnFP ? returnFP.altInput : null;
            const timeInput = returnGroup.querySelector('input[type="time"]');

            if (selectedService === 'Outstation') {
              returnGroup.style.display = 'flex';
              if (dateAltInput) dateAltInput.setAttribute('required', 'true');
              if (timeInput) timeInput.setAttribute('required', 'true');
            } else {
              returnGroup.style.display = 'none';
              if (dateAltInput) dateAltInput.removeAttribute('required');
              if (timeInput) timeInput.removeAttribute('required');
              if (returnFP) returnFP.clear();
            }
          }
          
          // Toggle dropoff visibility (Airport & Local don't strictly require drops)
          if (dropoffGroup && dropoffInput) {
            if (selectedService === 'Local') {
              dropoffGroup.style.display = 'none';
              dropoffInput.removeAttribute('required');
            } else {
              dropoffGroup.style.display = 'flex';
              dropoffInput.setAttribute('required', 'true');
            }
          }
        });
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initApp);
  } else {
    initApp();
  }
</script>
