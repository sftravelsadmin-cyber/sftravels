    <!-- ═══════════════════════════════════════════════════════════════
         SUCCESS MODAL
    ═══════════════════════════════════════════════════════════════ -->
    <div id="successModal" class="form-success-overlay">
      <div class="form-success-card">
        <div class="success-icon-circle">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="success-title text-2xl font-bold mb-3">Enquiry Received!</h3>
        <p id="successModalMessage" class="success-message mb-6">Your booking request has been successfully submitted. Our team will contact you in a few minutes.</p>
        <div class="success-actions flex flex-col gap-3">
          <a id="successModalWhatsAppBtn" href="#" target="_blank" rel="noopener noreferrer" class="btn-wa-success w-full bg-[#1E2D5A] hover:bg-[#D97706] text-white font-bold h-12 rounded-lg flex items-center justify-center gap-2 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            Confirm on WhatsApp
          </a>
          <button id="successModalCloseBtn" class="btn-close-success w-full border border-slate-200 hover:bg-slate-50 text-slate-600 font-bold h-12 rounded-lg transition-all">
            Dismiss
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       ALL JAVASCRIPT — fully preserved
  ═══════════════════════════════════════════════════════════════ -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Flatpickr
      let pickupFP, returnFP;
      if (typeof flatpickr !== 'undefined') {
        pickupFP = flatpickr("#pickupDatePicker", { enableTime: false, dateFormat: "Y-m-d", minDate: "today" });
        returnFP = flatpickr("#returnDatePicker", { enableTime: false, dateFormat: "Y-m-d", minDate: "today" });
      }

      // 2. Service Tabs
      const tabs = document.querySelectorAll('#serviceTabs .tab-btn');
      const serviceTypeInput = document.getElementById('serviceTypeInput');
      const dropoffGroup = document.getElementById('dropoffGroup');
      const returnGroup = document.getElementById('returnGroup');

      if (tabs && serviceTypeInput) {
        tabs.forEach(tab => {
          tab.addEventListener('click', (e) => {
            e.preventDefault();
            tabs.forEach(t => {
              t.classList.remove('bg-[#1E2D5A]', 'text-white', 'shadow');
              t.classList.add('bg-white', 'text-slate-600', 'border', 'border-slate-200');
            });
            tab.classList.add('bg-[#1E2D5A]', 'text-white', 'shadow');
            tab.classList.remove('bg-white', 'text-slate-600', 'border', 'border-slate-200');

            const selectedService = tab.getAttribute('data-service') || 'Outstation';
            serviceTypeInput.value = selectedService;

            if (returnGroup) {
              if (selectedService === 'Outstation') {
                returnGroup.style.display = 'block';
                returnGroup.querySelector('input').setAttribute('required', 'true');
              } else {
                returnGroup.style.display = 'none';
                returnGroup.querySelector('input').removeAttribute('required');
                if (returnFP) returnFP.clear();
              }
            }
            if (dropoffGroup) {
              if (selectedService === 'Local') {
                dropoffGroup.style.display = 'none';
                dropoffGroup.querySelector('input').removeAttribute('required');
              } else {
                dropoffGroup.style.display = 'block';
                dropoffGroup.querySelector('input').setAttribute('required', 'true');
              }
            }
          });
        });
      }

      // 3. Fleet tabs
      const fleetTabBtns = document.querySelectorAll('.fleet-tab-btn');
      const fleetPanels = document.querySelectorAll('.fleet-panel');

      fleetTabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-tab-target');
          fleetTabBtns.forEach(b => {
            b.classList.remove('bg-[#1E2D5A]', 'text-white', 'border-[#1E2D5A]');
            b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
          });
          btn.classList.add('bg-[#1E2D5A]', 'text-white', 'border-[#1E2D5A]');
          btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
          fleetPanels.forEach(panel => {
            if (panel.id === target) {
              panel.classList.remove('hidden');
              panel.classList.add('block');
              // Re-init slider for the newly shown panel
              setupSlider(panel);
            } else {
              panel.classList.add('hidden');
              panel.classList.remove('block');
            }
          });
        });
      });

      // 4. Slider setup
      const setupSlider = (sliderContainer) => {
        const wrapper = sliderContainer.querySelector('.flex.transition-transform');
        const prevBtn = sliderContainer.querySelector('button[aria-label="Previous slide"]');
        const nextBtn = sliderContainer.querySelector('button[aria-label="Next slide"]');
        if (!wrapper || !prevBtn || !nextBtn) return;

        let currentIndex = 0;
        const getVisibleCardsCount = () => {
          if (window.innerWidth < 640) return 1;
          if (window.innerWidth < 1024) return 2;
          return 3;
        };

        const updateSlider = () => {
          const items = wrapper.children;
          const visibleCards = getVisibleCardsCount();
          const maxIndex = Math.max(0, items.length - visibleCards);
          if (currentIndex > maxIndex) currentIndex = maxIndex;
          if (currentIndex < 0) currentIndex = 0;
          const cardWidthPercent = 100 / visibleCards;
          Array.from(items).forEach(item => { item.style.width = `${cardWidthPercent}%`; });
          wrapper.style.transform = `translateX(${-currentIndex * cardWidthPercent}%)`;
          prevBtn.disabled = currentIndex === 0;
          nextBtn.disabled = currentIndex >= maxIndex;
        };

        prevBtn.onclick = (e) => { e.preventDefault(); if (currentIndex > 0) { currentIndex--; updateSlider(); } };
        nextBtn.onclick = (e) => {
          e.preventDefault();
          const visibleCards = getVisibleCardsCount();
          const maxIndex = Math.max(0, wrapper.children.length - visibleCards);
          if (currentIndex < maxIndex) { currentIndex++; updateSlider(); }
        };

        window.addEventListener('resize', updateSlider);
        updateSlider();
      };

      document.querySelectorAll('.group-slider').forEach(container => {
        if (!container.classList.contains('hidden')) setupSlider(container);
      });

      // 5. Book Now modal trigger
      const successModal = document.getElementById('successModal');
      const successModalMessage = document.getElementById('successModalMessage');
      const successModalCloseBtn = document.getElementById('successModalCloseBtn');
      const successModalWhatsAppBtn = document.getElementById('successModalWhatsAppBtn');

      // 6. Web3Forms
      const bookingForm = document.getElementById('homepageBookingForm');
      if (bookingForm && successModal) {
        bookingForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const botcheck = bookingForm.querySelector('input[name="botcheck"]');
          if (botcheck && botcheck.checked) return;

          const submitBtn = bookingForm.querySelector('button[type="submit"]');
          const formElements = bookingForm.querySelectorAll('input, select, textarea, button');
          if (submitBtn) submitBtn.classList.add('btn-loading');
          const formData = new FormData(bookingForm);
          formElements.forEach(el => el.setAttribute('disabled', 'true'));

          fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData })
            .then(async (response) => {
              const json = await response.json();
              if (response.status === 200) {
                const fullName = formData.get('fullName') || '';
                const phoneNumber = formData.get('phoneNumber') || '';
                const pickup = formData.get('pickupLocation') || '';
                const dropoff = formData.get('dropoffLocation') || '';
                const date = formData.get('pickupDate') || '';
                const time = formData.get('pickupTime') || '';
                const service = formData.get('service-type') || 'Cab Booking';
                const vehicle = formData.get('vehicleType') || '';
                const returnDate = formData.get('returnDate') || '';
                const returnTime = formData.get('returnTime') || '';

                if (successModalMessage) {
                  successModalMessage.innerHTML = `Thank you, <strong>${fullName}</strong>! Your enquiry for a <strong>${service}</strong> ride (${vehicle}) has been successfully sent. We will call you at <strong>${phoneNumber}</strong> within 15 minutes.`;
                }

                let waText = `Hi SF Travels, I would like to book a cab:\n- *Name*: ${fullName}\n- *Phone*: ${phoneNumber}\n- *Service*: ${service}\n- *Vehicle*: ${vehicle}\n- *Pickup*: ${pickup}\n`;
                if (dropoff) waText += `- *Dropoff*: ${dropoff}\n`;
                waText += `- *Date & Time*: ${date} at ${time}\n`;
                if (service === 'Outstation' && returnDate) waText += `- *Return*: ${returnDate} at ${returnTime}\n`;

                if (successModalWhatsAppBtn) {
                  successModalWhatsAppBtn.href = `https://wa.me/919353966815?text=${encodeURIComponent(waText)}`;
                  successModalWhatsAppBtn.style.display = 'inline-flex';
                }
                successModal.classList.add('active');
                formElements.forEach(el => el.removeAttribute('disabled'));
                bookingForm.reset();
                if (pickupFP) pickupFP.clear();
                if (returnFP) returnFP.clear();
              } else {
                alert(json.message || "Something went wrong. Please try again.");
                formElements.forEach(el => el.removeAttribute('disabled'));
              }
            })
            .catch(error => {
              console.error(error);
              alert("Form submission failed. Please check your connection and try again.");
              formElements.forEach(el => el.removeAttribute('disabled'));
            })
            .finally(() => { if (submitBtn) submitBtn.classList.remove('btn-loading'); });
        });
      }

      if (successModalCloseBtn && successModal) {
        successModalCloseBtn.addEventListener('click', (e) => { e.preventDefault(); successModal.classList.remove('active'); });
      }

      // 7. Map modal
      const pickupMapBtn = document.getElementById('pickupMapBtn');
      const dropoffMapBtn = document.getElementById('dropoffMapBtn');
      const pickupLocInput = document.getElementById('pickupLocationInput');
      const dropoffLocInput = document.getElementById('dropoffLocationInput');

      let mapModal;
      let leafletMapModal = null;
      let leafletMarkerModal = null;
      let activeInputTarget = null;
      const defaultBangalore = [12.9716, 77.5946];

      const createMapModalDOM = () => {
        if (document.getElementById('mapModal')) return;
        const modalHtml = `
          <div id="mapModal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-black/60 p-4 backdrop-blur-sm">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col relative" style="max-height: 90vh;">
              <div class="flex-none bg-white border-b border-gray-100 px-4 py-3 flex items-center justify-between">
                <h3 id="mapPickerTitle" class="text-sm md:text-base font-bold text-gray-900">Pick Location on Map</h3>
                <button type="button" id="closeMapModalBtn" class="p-1.5 hover:bg-gray-100 rounded-full transition-colors text-gray-500" aria-label="Close map picker">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                </button>
              </div>
              <div class="flex-1 overflow-y-auto p-3 flex flex-col gap-3 min-h-0 text-gray-700">
                <div class="relative flex-grow border border-gray-200 rounded-lg overflow-hidden bg-gray-50 min-h-[260px] md:min-h-[320px]">
                  <div id="leafletMapContainerModal" class="w-full h-full relative z-10"></div>
                  <button type="button" id="mapModalLocateBtn" class="absolute bottom-3 right-3 z-20 bg-white p-2 rounded-full shadow-md text-[#1E2D5A] hover:text-blue-800 border border-gray-200 transition-colors flex items-center justify-center" title="Locate me">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line></svg>
                  </button>
                </div>
                <div class="p-3 bg-gray-50 border border-gray-100 rounded-md">
                  <div class="text-[10px] font-bold text-gray-400 uppercase tracking-wide">SELECTED LOCATION</div>
                  <div class="relative mt-1.5 flex items-center bg-white border border-gray-200 rounded-md px-3 py-2 text-gray-800">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-500 mr-2 shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    <div id="mapSelectedAddress" class="text-xs font-semibold text-gray-600 truncate w-full select-all">Click on map to select location</div>
                  </div>
                </div>
              </div>
              <div class="flex-none p-3 border-t border-gray-100 bg-gray-50 flex justify-end gap-2.5">
                <button type="button" id="cancelMapModalBtn" class="rounded-md px-4 py-2 border border-gray-300 bg-white hover:bg-gray-100 text-gray-700 font-bold text-xs md:text-sm shadow-sm transition-colors">Cancel</button>
                <button type="button" id="confirmMapLocationBtn" disabled class="rounded-md px-4 py-2 bg-[#1E2D5A] hover:bg-[#D97706] disabled:bg-gray-300 disabled:cursor-not-allowed text-white font-bold text-xs md:text-sm shadow-sm flex items-center justify-center gap-1.5 transition-colors border-none">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  Confirm Location
                </button>
              </div>
            </div>
          </div>`;
        document.body.insertAdjacentHTML('beforeend', modalHtml);
      };

      const openMapModal = (inputField, fieldName) => {
        createMapModalDOM();
        mapModal = document.getElementById('mapModal');
        const closeMapModalBtn = document.getElementById('closeMapModalBtn');
        const cancelMapModalBtn = document.getElementById('cancelMapModalBtn');
        const confirmMapLocationBtn = document.getElementById('confirmMapLocationBtn');
        const mapPickerTitle = document.getElementById('mapPickerTitle');
        const mapSelectedAddress = document.getElementById('mapSelectedAddress');

        if (mapPickerTitle) mapPickerTitle.textContent = fieldName === 'pickup' ? 'Select Pickup Location' : 'Select Drop Location';
        activeInputTarget = inputField;
        let selectedMapAddress = '';

        const placeMarker = (latlng, updateAddress = true) => {
          if (typeof window !== 'undefined' && window.L) {
            const L = window.L;
            if (leafletMarkerModal) { leafletMarkerModal.setLatLng(latlng); }
            else {
              leafletMarkerModal = L.marker(latlng, { draggable: true }).addTo(leafletMapModal);
              leafletMarkerModal.on('dragend', () => { const pos = leafletMarkerModal.getLatLng(); fetchReverseGeocode(pos.lat, pos.lng); });
            }
            if (updateAddress) fetchReverseGeocode(latlng.lat, latlng.lng);
          }
        };

        const fetchReverseGeocode = async (lat, lng) => {
          if (mapSelectedAddress) mapSelectedAddress.textContent = 'Fetching address...';
          try {
            const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`);
            const data = await res.json();
            const address = data.display_name || `Location at ${lat.toFixed(4)}, ${lng.toFixed(4)}`;
            selectedMapAddress = address;
            if (mapSelectedAddress) mapSelectedAddress.textContent = address;
            if (confirmMapLocationBtn) confirmMapLocationBtn.removeAttribute('disabled');
          } catch (err) {
            const address = `${lat.toFixed(5)}, ${lng.toFixed(5)} (Pin Coordinates)`;
            selectedMapAddress = address;
            if (mapSelectedAddress) mapSelectedAddress.textContent = address;
            if (confirmMapLocationBtn) confirmMapLocationBtn.removeAttribute('disabled');
          }
        };

        if (mapSelectedAddress) mapSelectedAddress.textContent = 'Click on map to select location';
        if (confirmMapLocationBtn) confirmMapLocationBtn.setAttribute('disabled', 'true');

        mapModal.classList.remove('hidden');
        mapModal.classList.add('flex');

        setTimeout(() => {
          if (typeof window !== 'undefined' && window.L) {
            const L = window.L;
            if (!leafletMapModal) {
              leafletMapModal = L.map('leafletMapContainerModal', { zoomControl: true }).setView(defaultBangalore, 13);
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap contributors' }).addTo(leafletMapModal);
              leafletMapModal.on('click', (e) => { placeMarker(e.latlng); });
            } else { leafletMapModal.invalidateSize(); }
            placeMarker({ lat: defaultBangalore[0], lng: defaultBangalore[1] }, false);
            leafletMapModal.setView(defaultBangalore, 13);
          }
        }, 150);

        const mapModalLocateBtn = document.getElementById('mapModalLocateBtn');
        if (mapModalLocateBtn) {
          mapModalLocateBtn.onclick = () => {
            if (navigator.geolocation && leafletMapModal) {
              navigator.geolocation.getCurrentPosition(
                (pos) => { const latlng = { lat: pos.coords.latitude, lng: pos.coords.longitude }; leafletMapModal.setView([latlng.lat, latlng.lng], 15); placeMarker(latlng, true); },
                (err) => { console.warn("Geolocation modal failed:", err); alert("Unable to retrieve your current location."); }
              );
            }
          };
        }

        const closeModal = () => { mapModal.classList.add('hidden'); mapModal.classList.remove('flex'); };
        if (closeMapModalBtn) closeMapModalBtn.onclick = (e) => { e.preventDefault(); closeModal(); };
        if (cancelMapModalBtn) cancelMapModalBtn.onclick = (e) => { e.preventDefault(); closeModal(); };
        if (confirmMapLocationBtn) {
          confirmMapLocationBtn.onclick = (e) => {
            e.preventDefault();
            if (activeInputTarget && selectedMapAddress) activeInputTarget.value = selectedMapAddress;
            closeModal();
          };
        }
      };

      if (pickupMapBtn && pickupLocInput) pickupMapBtn.addEventListener('click', (e) => { e.preventDefault(); openMapModal(pickupLocInput, 'pickup'); });
      if (dropoffMapBtn && dropoffLocInput) dropoffMapBtn.addEventListener('click', (e) => { e.preventDefault(); openMapModal(dropoffLocInput, 'drop'); });

      // 8. Current location button
      const pickupCurrentLocBtn = document.getElementById('pickupCurrentLocBtn');
      if (pickupCurrentLocBtn && pickupLocInput) {
        pickupCurrentLocBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const svg = pickupCurrentLocBtn.querySelector('svg');
          if (svg) svg.classList.add('animate-spin');
          pickupCurrentLocBtn.setAttribute('disabled', 'true');
          const setAddress = (address) => {
            pickupLocInput.value = address;
            if (svg) svg.classList.remove('animate-spin');
            pickupCurrentLocBtn.removeAttribute('disabled');
          };
          if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
              (position) => { setAddress(`Detected Location (Lat: ${position.coords.latitude.toFixed(4)}, Lng: ${position.coords.longitude.toFixed(4)}) - MG Road Area, Bengaluru`); },
              (error) => { setTimeout(() => { setAddress("Tech Corridor, Outer Ring Rd, Bellandur, Bengaluru (Detected Location)"); }, 800); },
              { timeout: 5000 }
            );
          } else {
            setTimeout(() => { setAddress("Tech Corridor, Outer Ring Rd, Bellandur, Bengaluru (Detected Location)"); }, 800);
          }
        });
      }

      // 9. "Book Now" buttons on fleet cards — open modal (data-book-now)
      document.querySelectorAll('[data-book-now]').forEach(btn => {
        btn.addEventListener('click', () => {
          const vehicle = btn.getAttribute('data-vehicle') || '';
          const category = btn.getAttribute('data-category') || '';
          // Scroll to booking form and pre-select vehicle if possible
          const formSection = document.getElementById('homepageBookingForm');
          const vehicleSelect = formSection ? formSection.querySelector('select[name="vehicleType"]') : null;
          if (vehicleSelect) {
            const opt = Array.from(vehicleSelect.options).find(o => o.value === vehicle);
            if (opt) vehicleSelect.value = vehicle;
          }
          if (formSection) {
            formSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        });
      });
    });
  </script>

</Layout>
