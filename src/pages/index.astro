---
import Layout from '../layouts/Layout.astro';
import { blogPosts } from '../data/blog.js';

// SF Travels - Premium Homepage
// Pull 3 featured posts for the homepage blog preview
const homeBlogPosts = blogPosts.slice(0, 3);
---

<Layout 
  title="SF Travels | Smooth Ride On Time - Corporate & Luxury Cabs Bangalore"
  description="Experience executive corporate mobility, professional airport transfers, and outstation trips with SF Travels in Bangalore. Transparent slab rate billing and verified chauffeurs."
>
  <!-- Leaflet CSS & JS for Interactive Map Selection -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
  <!-- ==================== HERO & BOOKING SECTION ==================== -->
  <section class="hero-section">
    <!-- Overlay & Background -->
    <div class="hero-overlay"></div>
    
    <div class="container hero-container">
      <div class="hero-text-content">
        <h1 class="hero-title">
          Looking for a <span class="gold-text">vehicle</span>?<br />You're at the right place.
        </h1>
      </div>

      <!-- Quick Enquiry Booking Card (Wide Dashboard Layout) -->
      <div class="booking-card glass-card">
        <div class="booking-sidebar">
          <h3 class="booking-sidebar-title">Service</h3>
          <!-- Interactive Service Tabs -->
          <div class="service-tabs">
            <button type="button" class="tab-btn active" data-service="Outstation">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="tab-icon"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <span>Outstation</span>
            </button>
            <button type="button" class="tab-btn" data-service="Airport">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="tab-icon"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path></svg>
              <span>Airport Transfer</span>
            </button>
            <button type="button" class="tab-btn" data-service="OneWay">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="tab-icon"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              <span>One Way</span>
            </button>
            <button type="button" class="tab-btn" data-service="Local">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="tab-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              <span>Local Hourly</span>
            </button>
          </div>
        </div>

        <div class="booking-body">
          <!-- Dynamic Lead Capture Form -->
          <form class="booking-form" name="homepage-inquiry" data-netlify="true" action="/success" method="POST">
            <input type="hidden" name="form-name" value="homepage-inquiry" />
            <!-- Active Tab State (hidden input) -->
            <input type="hidden" name="service-type" id="serviceTypeInput" value="Outstation" />

            <div class="form-grid">
              <!-- Full Name -->
              <div class="input-group">
                <label>Full Name <span class="accent-gold">*</span></label>
                <div class="input-wrapper">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                  <input type="text" name="fullName" placeholder="Your Full Name" required />
                </div>
              </div>

              <!-- Phone Number -->
              <div class="input-group">
                <label>Phone Number <span class="accent-gold">*</span></label>
                <div class="input-wrapper">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  <input type="tel" name="phoneNumber" placeholder="10-digit number" required />
                </div>
              </div>

              <!-- Pickup Location -->
              <div class="input-group">
                <label>Pick Up Location <span class="accent-gold">*</span></label>
                <div class="location-input-row">
                  <div class="input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    <input type="text" id="pickupLocationInput" name="pickupLocation" placeholder="Enter pickup address" required />
                    <button type="button" class="current-loc-btn" id="pickupCurrentLocBtn" title="Use current location">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="2" y1="12" x2="5" y2="12"></line><line x1="19" y1="12" x2="22" y2="12"></line><line x1="12" y1="2" x2="12" y2="5"></line><line x1="12" y1="19" x2="12" y2="22"></line><circle cx="12" cy="12" r="7"></circle></svg>
                    </button>
                  </div>
                  <button type="button" class="map-pick-btn" id="pickupMapBtn" title="Pick on Map">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
                  </button>
                </div>
              </div>

              <!-- Drop Off Location -->
              <div class="input-group" id="dropoffGroup">
                <label>Drop Off Location <span class="accent-gold">*</span></label>
                <div class="location-input-row">
                  <div class="input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    <input type="text" id="dropoffLocationInput" name="dropoffLocation" placeholder="Enter destination address" required />
                    <button type="button" class="current-loc-btn" id="dropoffCurrentLocBtn" title="Use current location">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="2" y1="12" x2="5" y2="12"></line><line x1="19" y1="12" x2="22" y2="12"></line><line x1="12" y1="2" x2="12" y2="5"></line><line x1="12" y1="19" x2="12" y2="22"></line><circle cx="12" cy="12" r="7"></circle></svg>
                    </button>
                  </div>
                  <button type="button" class="map-pick-btn" id="dropoffMapBtn" title="Pick on Map">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
                  </button>
                </div>
              </div>

              <!-- Dates / Times -->
              <div class="input-group">
                <label>Pick Up Date & Time <span class="accent-gold">*</span></label>
                <div class="datetime-grid">
                  <div class="input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    <input type="text" id="pickupDatePicker" name="pickupDate" placeholder="Select Pick Up Date" required />
                  </div>
                  <input type="time" name="pickupTime" required />
                </div>
              </div>

              <!-- Return Details (only for Outstation roundtrip) -->
              <div class="input-group" id="returnGroup">
                <label>Return Date & Time <span class="accent-gold">*</span></label>
                <div class="datetime-grid">
                  <div class="input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    <input type="text" id="returnDatePicker" name="returnDate" placeholder="Select Return Date" />
                  </div>
                  <input type="time" name="returnTime" />
                </div>
              </div>

              <!-- Select Vehicle -->
              <div class="input-group span-full">
                <label>Select Vehicle <span class="accent-gold">*</span></label>
                <div class="input-wrapper select-wrapper">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path><circle cx="7" cy="17" r="2"></circle><path d="M9 17h6"></path><circle cx="17" cy="17" r="2"></circle></svg>
                  <select name="vehicleType" required>
                    <option value="" disabled selected>Select a vehicle type</option>
                    <optgroup label="Executive Cars">
                      <option value="Hatchback">Hatchback (Dzire / Etios)</option>
                      <option value="Sedan">Sedan (Executive Sedan)</option>
                    </optgroup>
                    <optgroup label="Slab-Duty SUVs & MPVs">
                      <option value="SUV">Standard SUV (Ertiga)</option>
                      <option value="Innova Crysta">Toyota Innova Crysta</option>
                      <option value="Innova Hycross">Toyota Innova Hycross</option>
                    </optgroup>
                    <optgroup label="Luxury Coaches & Vans">
                      <option value="Force Urbania Deluxe">Force Urbania Deluxe (9-14 seats)</option>
                      <option value="Force Urbania Luxury">Force Urbania Luxury (Maharaj Edition)</option>
                      <option value="Tempo Traveller">Premium Tempo Traveller</option>
                    </optgroup>
                    <optgroup label="Heavy Coaches & Buses">
                      <option value="Mini Bus">Mini Bus (21-30 seater)</option>
                      <option value="Volvo Coach">Luxury Volvo Coach (45 seater)</option>
                      <option value="Transit Bus">Large Transit Bus (50 seater)</option>
                    </optgroup>
                  </select>
                </div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn-gold submit-btn span-full">
                <span>Request Quote Instantly</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="submit-icon"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </button>

            </div>
          </form>
        </div>
      </div>

      <!-- ==================== HERO 4-STEPS BANNER ==================== -->
      <div class="hero-steps-banner span-full">
        <div class="steps-grid">
          <div class="step-item group">
            <div class="step-number">1</div>
            <h3 class="step-title">Choose a Vehicle</h3>
            <p class="step-desc">Find the perfect ride from our diverse fleet, custom-selected to make your next road trip comfortable and memorable.</p>
          </div>
          <div class="step-item group">
            <div class="step-number">2</div>
            <h3 class="step-title">Pick Location</h3>
            <p class="step-desc">Select your pickup spot and travel date—we'll handle all the logistics and routing details for you.</p>
          </div>
          <div class="step-item group">
            <div class="step-number">3</div>
            <h3 class="step-title">Make a Booking</h3>
            <p class="step-desc">Confirm your ride in a few simple taps. Our booking process is quick, direct, and completely hassle-free.</p>
          </div>
          <div class="step-item group">
            <div class="step-number">4</div>
            <h3 class="step-title">Sit Back & Relax</h3>
            <p class="step-desc">Unwind and enjoy a stress-free travel experience while our friendly, professional chauffeur does the driving.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ==================== TRUST PILLARS (WHY CHOOSE US - LIGHT & SPACIOUS) ==================== -->
  <section class="section-padding trust-section">
    <div class="container text-center">
      <span class="gold-subtitle">SF TRAVELS STANDARDS</span>
      <h2 class="section-title text-dark">A Fresh Approach to Travel</h2>
      <p class="section-desc text-muted max-w-3xl">
        Experience seamless travel with our high standards of safety, extreme punctuality, and straightforward slab pricing tailored for your daily commutes.
      </p>

      <div class="features-layout-grid">
        <!-- Left Side: 2 Features Stacked -->
        <div class="features-col">
          <!-- Feature 1 -->
          <div class="feature-card-spacious text-right-desktop">
            <div class="feature-icon-wrapper align-right-desktop">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
            </div>
            <h3 class="feature-card-title">Absolute Safety First</h3>
            <p class="feature-card-desc">Your safety is our top priority. We thoroughly inspect and clean every vehicle, and use live GPS tracking to keep your ride secure.</p>
          </div>
          
          <!-- Feature 2 -->
          <div class="feature-card-spacious text-right-desktop">
            <div class="feature-icon-wrapper align-right-desktop">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <h3 class="feature-card-title">Extreme Punctuality</h3>
            <p class="feature-card-desc">We value your time. Our dedicated chauffeurs make it a point to arrive at your pickup point at least 10 minutes early, ensuring a perfectly smooth departure.</p>
          </div>
        </div>

        <!-- Center: Gorgeous Premium Transparent Car PNG -->
        <div class="features-car-center">
          <div class="car-glow-blur"></div>
          <img src="https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/af218ffd783e5838777bc2ff78950efa.png" alt="Premium Toyota Car Service" class="car-image-effect" />
        </div>

        <!-- Right Side: 2 Features Stacked -->
        <div class="features-col text-left-desktop">
          <!-- Feature 3 -->
          <div class="feature-card-spacious">
            <div class="feature-icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line></svg>
            </div>
            <h3 class="feature-card-title">Transparent Slab Rates</h3>
            <p class="feature-card-desc">Say goodbye to sudden price surges or hidden fees. What you see on our rate cards is exactly what you pay—no dynamic pricing spikes or post-trip surprises.</p>
          </div>

          <!-- Feature 4 -->
          <div class="feature-card-spacious">
            <div class="feature-icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <h3 class="feature-card-title">Free Pick-Up & Drop-Off</h3>
            <p class="feature-card-desc">Enjoy maximum convenience with complimentary doorstep pickup and drop-off service for all executive travels and outstation trips within city limits.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ==================== STATS OVERLAY SECTION ==================== -->
  <section class="stats-section section-padding">
    <div class="stats-overlay"></div>
    <div class="container relative z-10">
      <div class="stats-header-grid">
        <h2 class="stats-title gold-text">SF Travels offers premium executive transits across Bangalore and beyond.</h2>
        <p class="stats-desc text-light">
          At SF Travels, we are committed to providing safe, comfortable, and reliable transportation services. Our fleet of pristine, modern vehicles and highly professional chauffeurs ensures a smooth journey whether you're catching a flight, traveling outstation, or managing corporate employee transport.
        </p>
      </div>

      <div class="counters-grid">
        <div class="counter-card glass-card">
          <h3 class="counter-num">15,425+</h3>
          <p class="counter-label">Completed Orders</p>
        </div>
        <div class="counter-card glass-card">
          <h3 class="counter-num">8,745+</h3>
          <p class="counter-label">Happy Customers</p>
        </div>
        <div class="counter-card glass-card">
          <h3 class="counter-num">235+</h3>
          <p class="counter-label">Active Fleet Vehicles</p>
        </div>
        <div class="counter-card glass-card">
          <h3 class="counter-num">15+ Yrs</h3>
          <p class="counter-label">Combined Experience</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PREMIUM FLEET SHOWCASE (SPACIOUS LIGHT SECTION) ==================== -->
  <section class="section-padding fleet-section">
    <div class="container">
      <div class="text-center">
        <span class="gold-subtitle">EXQUISITE CHAUFFEURED FLEET</span>
        <h2 class="section-title text-dark">Explore Our Fleet</h2>
        <p class="section-desc text-muted max-w-3xl">
          From daily city runs to premium corporate transits and group getaways, we have a perfectly maintained vehicle ready to make your journey pleasant.
        </p>
      </div>

      <!-- CATEGORY 1: CARS FLEET -->
      <div class="fleet-category-block">
        <h3 class="category-heading">Cars Fleet</h3>
        <div class="fleet-grid">
          <!-- Vehicle 1 -->
          <div class="fleet-card">
            <div class="fleet-image-wrapper">
              <img src="https://images.unsplash.com/photo-1549399542-7e3f8b79c341?q=80&w=600&auto=format&fit=crop" alt="Hatchback (Dzire/Etios)" />
              <div class="fleet-tag">Executive Hatchback</div>
            </div>
            <div class="fleet-info">
              <h3 class="fleet-name">Dzire / Etios</h3>
              <div class="fleet-specs">
                <span class="spec-item">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spec-icon"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                  4 Seats
                </span>
                <span class="spec-item">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spec-icon"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                  1-2 Bags
                </span>
              </div>
              <div class="fleet-divider"></div>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-label">Slab Rates</span>
                  <span class="price-value">Starts ₹600</span>
                </div>
                <button class="btn-gold book-btn">Book Now</button>
              </div>
            </div>
          </div>

          <!-- Vehicle 2 -->
          <div class="fleet-card">
            <div class="fleet-image-wrapper">
              <img src="https://images.unsplash.com/photo-1550355291-bbee04a92027?q=80&w=600&auto=format&fit=crop" alt="Executive Sedan" />
              <div class="fleet-tag">Corporate Sedan</div>
            </div>
            <div class="fleet-info">
              <h3 class="fleet-name">Executive Sedan</h3>
              <div class="fleet-specs">
                <span class="spec-item">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spec-icon"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                  4 Seats
                </span>
                <span class="spec-item">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spec-icon"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                  2 Bags
                </span>
              </div>
              <div class="fleet-divider"></div>
              <div class="fleet-footer">
                <div class="fleet-price">
                  <span class="price-label">Corporate Rates</span>
                  <span class="price-value">Starts ₹600</span>
                </div>
                <button class="btn-gold book-btn">Book Now</button>
              </div>
            </div>
          </div>

          <!-- Vehicle 3 -->
          <div class="fleet-card">
            <div class="fleet-image-wrapper">
              <img src="https://images.unsplash.com/photo-1617788138017-80ad40651399?q=80&w=600&auto=format&fit=crop" alt="Standard SUV (Ertiga)" />
              <div class="fleet-tag">Slab SUV</div>
            </div>
            <div class="fleet-info">
              <h3 class="fleet-name">Suzuki Ertiga</h3>
              <div class="fleet-specs">
