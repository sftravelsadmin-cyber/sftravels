---

<Layout 
  title="SF Travels | Smooth Ride On Time - Corporate & Luxury Cabs Bangalore"
  description="Experience executive corporate mobility, professional airport transfers, and outstation trips with SF Travels in Bangalore. Transparent slab rate billing and verified chauffeurs."
>
  <!-- Flatpickr for Date Inputs -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr" is:inline></script>

  <div class="text-slate-800 font-sans bg-white">
    <!-- ==================== HERO & BOOKING SECTION ==================== -->
    <section class="relative min-h-screen flex flex-col justify-center pt-24 pb-16 sm:pt-32 sm:pb-20 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0 pointer-events-none"
        style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/ab7702efc63872ff2604f2ffe7b6a2c0.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
      </div>
      <!-- Background Navy Radial Fade Gradient -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#050814]/30 via-[#050814]/75 to-[#050814] z-10 pointer-events-none"></div>
      
      <!-- Colored Backdrop Orbs for Modern Glow -->
      <div class="absolute top-1/4 left-1/4 w-[350px] h-[350px] bg-emerald-500/10 rounded-full blur-[100px] z-10 pointer-events-none animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-blue-600/10 rounded-full blur-[120px] z-10 pointer-events-none animate-pulse" style="animation-delay: 2s;"></div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-20 flex flex-col items-center gap-8 sm:gap-12 py-4 h-auto overflow-visible">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold text-white mb-4 sm:mb-6 leading-tight drop-shadow-lg">
            Looking for a <span class="bg-gradient-to-r from-[#10b981] to-[#2563eb] bg-clip-text text-transparent font-extrabold">vehicle</span>? <br>You're at the right place.
          </h1>
        </div>

        <!-- Booking enquiry form -->
        <div class="w-full max-w-4xl">
          <div class="relative z-50 bg-white/90 backdrop-blur-xl rounded-2xl shadow-2xl w-full mx-auto overflow-hidden flex flex-col border border-slate-200 text-sm max-w-[100vw] lg:max-w-4xl">
            <!-- Top Horizontal tabs -->
            <div class="w-full bg-slate-50/80 p-3 sm:p-4 flex flex-row flex-wrap justify-center items-center gap-2 border-b border-slate-200" id="serviceTabs">
              <button type="button" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-full text-xs sm:text-sm font-bold transition-all duration-200 bg-gradient-to-r from-[#10b981] to-[#2563eb] text-white shadow-lg" data-service="Outstation">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 sm:w-4 sm:h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span class="leading-none whitespace-nowrap">Outstation</span>
              </button>
              <button type="button" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-full text-xs sm:text-sm font-bold transition-all duration-200 bg-slate-100 text-slate-600 hover:bg-slate-200 hover:text-slate-900 border border-slate-200/50" data-service="Airport">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 sm:w-4 sm:h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path></svg>
                <span class="leading-none whitespace-nowrap">Airport</span>
              </button>
              <button type="button" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-full text-xs sm:text-sm font-bold transition-all duration-200 bg-slate-100 text-slate-600 hover:bg-slate-200 hover:text-slate-900 border border-slate-200/50" data-service="OneWay">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 sm:w-4 sm:h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path></svg>
                <span class="leading-none whitespace-nowrap">One Way</span>
              </button>
              <button type="button" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-full text-xs sm:text-sm font-bold transition-all duration-200 bg-slate-100 text-slate-600 hover:bg-slate-200 hover:text-slate-900 border border-slate-200/50" data-service="Local">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 sm:w-4 sm:h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="leading-none whitespace-nowrap">Local</span>
              </button>
            </div>

            <!-- Form Content -->
            <div class="flex-1 p-4 sm:p-6 lg:p-8">
              <form id="homepageBookingForm" class="flex flex-col gap-3 sm:gap-4 lg:gap-5">
                <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || "e2691c76-e159-4d9e-803f-cdf2fa4bebbe"} />
                <input type="hidden" name="subject" value="New Website Booking Enquiry - SF Travels" />
                <input type="hidden" name="from_name" value="SF Travels Website" />
                <input type="hidden" name="service-type" id="serviceTypeInput" value="Outstation" />
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5">
                  <!-- Full Name -->
                  <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide ml-1 mb-1.5">Full Name <span class="text-red-500">*</span></label>
                    <div class="relative">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                      <input type="text" name="fullName" placeholder="Your Full Name" required class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-3 py-2" value="Test User">
                    </div>
                  </div>

                  <!-- Phone Number -->
                  <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide ml-1 mb-1.5">Phone Number <span class="text-red-500">*</span></label>
                    <div class="relative">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                      <input type="tel" name="phoneNumber" placeholder="10-digit number" required class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-3 py-2" value="9876543210">
                    </div>
                  </div>

                  <!-- Pickup Location -->
                  <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide ml-1 mb-1.5">Pick Up Location <span class="text-red-500">*</span></label>
                    <div class="relative flex gap-2 items-center">
                      <div class="relative flex-grow min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-400 pointer-events-none z-10"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="pickupLocation" id="pickupLocationInput" placeholder="Enter pickup location" class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-10 py-2 truncate" value="Majestic Metro Station, Bangalore">
                        <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 hover:bg-slate-100 rounded-md text-[#10b981] transition-colors z-20" id="pickupCurrentLocBtn" title="Use current location">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253"></path></svg>
                        </button>
                      </div>
                      <button type="button" class="flex-shrink-0 h-11 sm:h-12 w-11 sm:w-12 flex items-center justify-center bg-slate-50 border border-slate-200 rounded-lg hover:bg-gradient-to-r hover:from-[#10b981] hover:to-[#2563eb] hover:text-white transition-colors text-slate-600" id="pickupMapBtn" title="Pick on Map">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
                      </button>
                    </div>
                  </div>

                  <!-- Drop Off Location -->
                  <div id="dropoffGroup">
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide ml-1 mb-1.5">Drop Off Location <span class="text-red-500">*</span></label>
                    <div class="relative flex gap-2 items-center">
                      <div class="relative flex-grow min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-400 pointer-events-none z-10"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="dropoffLocation" id="dropoffLocationInput" placeholder="Enter dropoff location" class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-3 py-2 truncate" value="Kempegowda International Airport, Bangalore">
                      </div>
                      <button type="button" class="flex-shrink-0 h-11 sm:h-12 w-11 sm:w-12 flex items-center justify-center bg-slate-50 border border-slate-200 rounded-lg hover:bg-gradient-to-r hover:from-[#10b981] hover:to-[#2563eb] hover:text-white transition-colors text-slate-600" id="dropoffMapBtn" title="Pick on Map">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" x2="9" y1="3" x2="9" y2="18"></line><line x1="15" x2="15" y1="6" x2="15" y2="21"></line></svg>
                      </button>
                    </div>
                  </div>

                  <!-- Pick Up Date & Time -->
                  <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide ml-1 mb-1.5">Pick Up Date & Time <span class="text-red-500">*</span></label>
                    <div class="flex items-center gap-2">
                      <div class="relative flex-[3] min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <input type="text" name="pickupDate" id="pickupDatePicker" placeholder="Select pickup date" class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-3 py-2">
                      </div>
                      <div class="relative flex-[2] min-w-[35%] sm:min-w-[120px]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <input type="time" name="pickupTime" class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-3 py-2" value="10:00" style="color-scheme: light;">
                      </div>
                    </div>
                  </div>

                  <!-- Return Date & Time -->
                  <div id="returnGroup">
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wide ml-1 mb-1.5">Return Date & Time <span class="text-red-500">*</span></label>
                    <div class="flex items-center gap-2">
                      <div class="relative flex-[3] min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <input type="text" name="returnDate" id="returnDatePicker" placeholder="Select return date" class="w-full bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#10b981] focus:border-transparent outline-none transition-all text-slate-800 font-medium placeholder:text-slate-400 h-11 sm:h-12 text-sm sm:text-base pl-9 pr-3 py-2">
                      </div>
