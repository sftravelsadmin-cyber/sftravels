            { img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/c546d70b81b63a89e48d86a7306db1a4.jpg", date: "15 MAR", tag: "Safety", title: "Safety Tips for Outstation Cab Travel", desc: "Essential tips for safe outstation travel — from vehicle checks to route tracking.", bg: "bg-green-50" }
          ].map(post => (
            <article class={`group border border-white rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col ${post.bg}`}>
              <div class="relative h-56 overflow-hidden">
                <img src={post.img} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <div class="absolute top-4 left-4 bg-[#1E2D5A] text-white text-xs font-bold px-3 py-1.5 rounded-full">{post.date}</div>
              </div>
              <div class="p-7 flex flex-col flex-grow">
                <span class="text-[#D97706] text-sm font-bold uppercase tracking-wide mb-3">{post.tag}</span>
                <h3 class="text-xl font-bold text-[#1a1f36] mb-3 leading-snug group-hover:text-[#1E2D5A] transition-colors line-clamp-2">{post.title}</h3>
                <p class="text-slate-600 text-base leading-relaxed mb-5 flex-grow line-clamp-2">{post.desc}</p>
                <a href="/blog" class="inline-flex items-center gap-2 text-[#1E2D5A] font-bold text-base hover:text-[#D97706] transition-colors mt-auto">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5 group-hover:translate-x-1 transition-transform"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CTA BANNER — Left-aligned, warm indigo + amber accent
    ═══════════════════════════════════════════════════════════════ -->
    <section class="py-0">
      <div class="bg-[#1E2D5A] relative overflow-hidden">
        <!-- Decorative accent -->
        <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-[#D97706]/10 to-transparent pointer-events-none"></div>
        <div class="absolute right-20 bottom-0 w-64 h-64 bg-[#D97706]/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="container mx-auto px-4 py-16 relative z-10">
          <div class="flex flex-col lg:flex-row items-center justify-between gap-10">
            <div>
              <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">Ready to Book Your Premium Ride?</h2>
              <p class="text-white/70 text-lg">Get started today — our team confirms within 15 minutes.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0">
              <button class="inline-flex items-center justify-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold px-10 py-5 rounded-2xl text-lg transition-all shadow-lg" data-book-now data-vehicle="Premium Cab" data-category="General Booking">
                Book a Cab Now
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </button>
              <a href="tel:9353966815" class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/25 hover:bg-white/20 text-white font-bold px-10 py-5 rounded-2xl text-lg transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                Call 9353966815
              </a>
            </div>
          </div>
        </div>
      </div>
