---

<Layout
  title="SF Travels | Smooth Ride On Time - Corporate & Luxury Cabs Bangalore"
  description="Experience executive corporate mobility, professional airport transfers, and outstation trips with SF Travels in Bangalore. Transparent slab rate billing and verified chauffeurs."
>
  <!-- Flatpickr for Date Inputs -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr" is:inline></script>

  <div class="font-sans bg-white text-slate-800">

    <!-- ═══════════════════════════════════════════════════════════════
         HERO SECTION — Split Layout: Left copy + Right form
    ═══════════════════════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center overflow-hidden pt-20">
      <!-- Full-bleed background -->
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80'); background-size: cover; background-position: center;">
      </div>
      <!-- Overlay — heavier on right for form readability, lighter on left -->
      <div class="absolute inset-0 z-10 bg-gradient-to-r from-[#0d1629]/85 via-[#0d1629]/70 to-[#0d1629]/55"></div>
      <!-- Warm amber glow top-right -->
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#D97706]/10 rounded-full blur-[120px] z-10 pointer-events-none"></div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-20 py-10 lg:py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">

          <!-- ── LEFT: Copy & Trust Signals ── -->
          <div class="text-white">
            <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-5 py-2 text-base font-semibold text-white/90 mb-7 backdrop-blur-sm">
              <span class="w-2.5 h-2.5 rounded-full bg-[#D97706] animate-pulse"></span>
              Bangalore's Trusted Travel Partner
            </div>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.12] mb-6">
              Premium Rides,<br>
              <span class="text-[#D97706]">On Your Schedule</span>
            </h1>
            <p class="text-xl text-white/80 leading-relaxed mb-8 max-w-lg">
              Corporate cabs, airport transfers, outstation trips — with verified chauffeurs, transparent pricing and 24/7 support across Bangalore.
            </p>

            <!-- Trust badges row -->
            <div class="grid grid-cols-2 gap-3 mb-9">
              {[
                { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", label: "Verified Drivers" },
                { icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", label: "24/7 Support" },
                { icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", label: "Transparent Pricing" },
                { icon: "M5 13l4 4L19 7", label: "15+ Years Experience" }
              ].map(b => (
                <div class="flex items-center gap-3 bg-white/10 border border-white/15 rounded-xl px-4 py-3.5 backdrop-blur-sm">
                  <div class="w-9 h-9 rounded-lg bg-[#D97706]/25 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#D97706" stroke-width="2" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d={b.icon}></path>
                    </svg>
                  </div>
                  <span class="text-base font-semibold text-white">{b.label}</span>
                </div>
              ))}
            </div>

            <!-- Quick stats strip -->
            <div class="flex flex-wrap gap-8 text-white/90">
              <div>
                <div class="text-4xl font-extrabold text-white">15,400+</div>
                <div class="text-sm text-white/60 mt-1 uppercase tracking-wide font-medium">Happy Rides</div>
              </div>
              <div class="w-px bg-white/20 self-stretch"></div>
              <div>
                <div class="text-4xl font-extrabold text-white">235</div>
                <div class="text-sm text-white/60 mt-1 uppercase tracking-wide font-medium">Fleet Size</div>
              </div>
              <div class="w-px bg-white/20 self-stretch"></div>
              <div>
                <div class="text-4xl font-extrabold text-white">15 yrs</div>
                <div class="text-sm text-white/60 mt-1 uppercase tracking-wide font-medium">Experience</div>
              </div>
            </div>
          </div>

          <!-- ── RIGHT: Booking Form ── -->
          <div class="w-full">
            <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-100">
              <!-- Tab bar -->
              <div class="bg-slate-50 px-4 py-3 border-b border-slate-200 flex flex-wrap gap-2" id="serviceTabs">
                <button type="button" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-bold transition-all bg-[#1E2D5A] text-white shadow" data-service="Outstation">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  Outstation
                </button>
                <button type="button" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-100" data-service="Airport">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path></svg>
                  Airport
                </button>
                <button type="button" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-100" data-service="OneWay">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path></svg>
                  One Way
                </button>
                <button type="button" class="tab-btn flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-100" data-service="Local">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  Local
                </button>
              </div>

              <!-- Form body -->
              <div class="p-6 sm:p-7">
                <form id="homepageBookingForm" class="flex flex-col gap-5">
                  <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || "e2691c76-e159-4d9e-803f-cdf2fa4bebbe"} />
                  <input type="hidden" name="subject" value="New Website Booking Enquiry - SF Travels" />
                  <input type="hidden" name="from_name" value="SF Travels Website" />
                  <input type="hidden" name="service-type" id="serviceTypeInput" value="Outstation" />
                  <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

                  <!-- Row 1: Name + Phone -->
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-bold text-slate-600 mb-2">Full Name <span class="text-red-400">*</span></label>
                      <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        <input type="text" name="fullName" placeholder="Your name" required class="w-full h-12 pl-10 pr-3 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium">
                      </div>
                    </div>
                    <div>
                      <label class="block text-sm font-bold text-slate-600 mb-2">Phone <span class="text-red-400">*</span></label>
                      <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        <input type="tel" name="phoneNumber" placeholder="10-digit number" required class="w-full h-12 pl-10 pr-3 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium">
                      </div>
                    </div>
                  </div>

                  <!-- Row 2: Pickup -->
                  <div>
                    <label class="block text-sm font-bold text-slate-600 mb-2">Pick Up Location <span class="text-red-400">*</span></label>
                    <div class="relative flex gap-2 items-center">
                      <div class="relative flex-grow min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none z-10"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="pickupLocation" id="pickupLocationInput" placeholder="Enter pickup location" class="w-full h-12 pl-11 pr-10 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium truncate">
                        <button type="button" class="absolute right-2.5 top-1/2 -translate-y-1/2 p-1.5 hover:bg-slate-100 rounded-lg text-[#D97706] transition-colors z-20" id="pickupCurrentLocBtn" title="Use current location">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253"></path></svg>
                        </button>
                      </div>
                      <button type="button" class="flex-shrink-0 h-12 w-12 flex items-center justify-center bg-slate-50 border border-slate-200 rounded-xl hover:bg-[#1E2D5A] hover:text-white hover:border-[#1E2D5A] transition-all text-slate-500" id="pickupMapBtn" title="Pick on Map">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
                      </button>
                    </div>
                  </div>

                  <!-- Row 3: Drop Off -->
                  <div id="dropoffGroup">
                    <label class="block text-sm font-bold text-slate-600 mb-2">Drop Off Location <span class="text-red-400">*</span></label>
                    <div class="relative flex gap-2 items-center">
                      <div class="relative flex-grow min-w-0">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none z-10"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <input type="text" name="dropoffLocation" id="dropoffLocationInput" placeholder="Enter dropoff location" class="w-full h-12 pl-11 pr-3 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium truncate">
                      </div>
                      <button type="button" class="flex-shrink-0 h-12 w-12 flex items-center justify-center bg-slate-50 border border-slate-200 rounded-xl hover:bg-[#1E2D5A] hover:text-white hover:border-[#1E2D5A] transition-all text-slate-500" id="dropoffMapBtn" title="Pick on Map">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" x2="9" y1="3" x2="9" y2="18"></line><line x1="15" x2="15" y1="6" x2="15" y2="21"></line></svg>
                      </button>
                    </div>
                  </div>

                  <!-- Row 4: Date + Time -->
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-bold text-slate-600 mb-2">Pick Up Date <span class="text-red-400">*</span></label>
                      <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <input type="text" name="pickupDate" id="pickupDatePicker" placeholder="Select date" class="w-full h-12 pl-11 pr-3 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium">
                      </div>
                    </div>
                    <div>
                      <label class="block text-sm font-bold text-slate-600 mb-2">Pick Up Time <span class="text-red-400">*</span></label>
                      <div class="relative">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <input type="time" name="pickupTime" class="w-full h-12 pl-11 pr-3 bg-slate-50 border border-slate-200 rounded-xl text-base text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-[#D97706] focus:border-transparent outline-none transition-all font-medium" value="10:00" style="color-scheme: light;">
                      </div>
                    </div>
                  </div>

                  <!-- Return Date (Outstation only) -->
                  <div id="returnGroup">
                    <label class="block text-sm font-bold text-slate-600 mb-2">Return Date & Time <span class="text-red-400">*</span></label>
                    <div class="grid grid-cols-2 gap-4">
