---
import Layout from '../../layouts/Layout.astro';
import { blogPosts, featuredPosts, allCategories } from '../../data/blog.js';
---

<Layout
  title="Travel Blog | SF Travels Bangalore — Tips, Guides & Road Trip Stories"
  description="Expert travel tips, road trip guides, airport taxi advice, and corporate travel insights from SF Travels Bangalore. Plan smarter journeys across South India."
>

  <!-- ==================== HERO ==================== -->
  <section class="blog-hero">
    <div class="hero-overlay"></div>
    <div class="container blog-hero-content">
      <div class="blog-badge-pill">📝 Travel Insights & Guides</div>
      <h1 class="blog-hero-title">
        Your Journey Starts<br />
        <span class="gold-text">With the Right Information.</span>
      </h1>
      <p class="blog-hero-desc">
        Expert road trip guides, airport taxi tips, corporate travel insights, and South India destination advice from the SF Travels team.
      </p>
      <div class="blog-hero-meta">
        <span class="meta-pill">📚 {blogPosts.length} Articles</span>
        <span class="meta-pill">🗺️ {allCategories.length} Categories</span>
        <span class="meta-pill">✍️ Updated Weekly</span>
      </div>
    </div>
  </section>

  <!-- ==================== FEATURED POSTS ==================== -->
  <section class="section-padding featured-section">
    <div class="container">
      <div class="section-label">Editor's Picks</div>
      <h2 class="section-title">Featured <span class="gold-text">Articles</span></h2>
      <div class="featured-grid">
        {featuredPosts.map((post, i) => (
          <a href={`/blog/${post.slug}`} class={`featured-card glass-card ${i === 0 ? 'featured-large' : ''}`}>
            <div class="featured-img-wrap">
              <img src={post.image} alt={post.title} class="featured-img" loading={i === 0 ? 'eager' : 'lazy'} />
              <div class="featured-img-overlay"></div>
              <span class="post-category-badge" style={`background:${post.categoryColor}`}>{post.category}</span>
            </div>
            <div class="featured-body">
              <div class="post-meta-row">
                <span class="post-date">📅 {post.dateFormatted}</span>
                <span class="post-read">🕐 {post.readTime}</span>
              </div>
              <h3 class="featured-title">{post.title}</h3>
              <p class="featured-excerpt">{post.excerpt}</p>
              <div class="post-tags">
                {post.tags.map(tag => <span class="post-tag">{tag}</span>)}
              </div>
              <div class="read-more">Read Article <span class="arrow">→</span></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== ALL POSTS GRID ==================== -->
  <section class="section-padding all-posts-section bg-navy-gradient">
    <div class="container">
      <div class="posts-header">
        <div>
          <div class="section-label">All Articles</div>
          <h2 class="section-title">Latest <span class="gold-text">Posts</span></h2>
        </div>
        <!-- Category Filter Pills -->
        <div class="category-filters">
          <button class="cat-filter active" data-cat="all">All</button>
          {allCategories.map(cat => (
            <button class="cat-filter" data-cat={cat}>{cat}</button>
          ))}
        </div>
      </div>

      <div class="posts-grid" id="postsGrid">
        {blogPosts.map(post => (
          <a
            href={`/blog/${post.slug}`}
            class="post-card glass-card"
            data-category={post.category}
          >
            <div class="post-img-wrap">
              <img src={post.image} alt={post.title} class="post-img" loading="lazy" />
              <span class="post-category-badge" style={`background:${post.categoryColor}`}>{post.category}</span>
            </div>
            <div class="post-body">
              <div class="post-meta-row">
                <span class="post-date">📅 {post.dateFormatted}</span>
                <span class="post-read">🕐 {post.readTime}</span>
              </div>
              <h3 class="post-title">{post.title}</h3>
              <p class="post-excerpt">{post.excerpt}</p>
              <div class="post-footer">
                <div class="post-tags">
                  {post.tags.slice(0, 2).map(tag => <span class="post-tag">{tag}</span>)}
                </div>
                <span class="post-arrow">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div id="noResults" class="no-results" style="display:none;">
        <p>No articles found in this category yet. Check back soon!</p>
      </div>
    </div>
  </section>

  <!-- ==================== NEWSLETTER / CTA ==================== -->
  <section class="section-padding newsletter-section">
    <div class="container">
      <div class="newsletter-card glass-card">
        <div class="newsletter-content">
          <div class="nl-icon">✈️</div>
          <h2 class="nl-title">Planning Your Next Trip from Bangalore?</h2>
          <p class="nl-desc">Get a personalised cab quote in under 5 minutes. Our dispatch team is available 24/7 for instant bookings.</p>
          <div class="nl-actions">
            <a href="tel:+919187232348" class="btn-gold">📞 Call: 9187232348</a>
            <a href="https://wa.me/919187232348?text=Hi%2C%20I%20read%20your%20travel%20blog%20and%20need%20a%20cab%20booking." target="_blank" rel="noopener" class="btn-outline">💬 WhatsApp Us</a>
          </div>
        </div>
        <div class="newsletter-visual">
          <div class="nl-stat">
            <span class="stat-num">8+</span>
            <span class="stat-label">Travel Guides</span>
          </div>
          <div class="nl-stat">
            <span class="stat-num">50+</span>
            <span class="stat-label">Destinations</span>
          </div>
          <div class="nl-stat">
            <span class="stat-num">24/7</span>
            <span class="stat-label">Cab Support</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ======= HERO ======= */
.blog-hero {
  position: relative;
  min-height: 480px;
  display: flex;
  align-items: center;
  background-image: url('https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=1400&q=80');
  background-size: cover;
  background-position: center;
  overflow: hidden;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(5,13,26,0.94) 0%, rgba(5,13,26,0.80) 100%);
}
.blog-hero-content {
  position: relative;
  z-index: 2;
  padding: 120px 20px 80px;
  max-width: 760px;
}
.blog-badge-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(16,185,129,0.15);
  border: 1px solid rgba(16,185,129,0.3);
  color: #10b981;
  padding: 6px 16px;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.5px;
  margin-bottom: 20px;
}
.blog-hero-title {
  font-size: clamp(2rem, 5vw, 3rem);
  color: #fff;
  line-height: 1.15;
  margin-bottom: 18px;
}
.blog-hero-desc {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.75);
  line-height: 1.7;
  margin-bottom: 28px;
  max-width: 600px;
}
.blog-hero-meta {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.meta-pill {
  background: rgba(16,185,129,0.12);
  border: 1px solid rgba(16,185,129,0.25);
  color: #a7f3d0;
  padding: 5px 14px;
  border-radius: 50px;
  font-size: 0.82rem;
  font-weight: 500;
}

/* ======= FEATURED SECTION ======= */
.featured-section { background: var(--bg-primary); }
.featured-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: auto auto;
  gap: 24px;
  margin-top: 40px;
}
.featured-large {
  grid-row: 1 / 3;
}
.featured-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.featured-card:hover { transform: translateY(-4px); }
.featured-img-wrap {
  position: relative;
  overflow: hidden;
}
.featured-large .featured-img-wrap { height: 320px; }
.featured-card:not(.featured-large) .featured-img-wrap { height: 180px; }
.featured-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.featured-card:hover .featured-img { transform: scale(1.05); }
.featured-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(5,13,26,0.5) 0%, transparent 60%);
}
.post-category-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  color: #fff;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 50px;
  letter-spacing: 0.3px;
  z-index: 1;
}
.featured-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}
.post-meta-row {
  display: flex;
  gap: 14px;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
}
.featured-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: #fff;
  line-height: 1.35;
}
.featured-large .featured-title { font-size: 1.4rem; }
.featured-excerpt {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.62);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.post-tag {
  font-size: 0.72rem;
  padding: 3px 9px;
  border-radius: 50px;
  background: rgba(16,185,129,0.1);
  border: 1px solid rgba(16,185,129,0.15);
  color: #a7f3d0;
}
.read-more {
  font-size: 0.88rem;
  font-weight: 600;
  color: #10b981;
  margin-top: auto;
  display: flex;
  align-items: center;
  gap: 6px;
}
.arrow { transition: transform 0.2s ease; }
.featured-card:hover .arrow { transform: translateX(4px); }

/* ======= ALL POSTS SECTION ======= */
.all-posts-section { background: var(--bg-secondary); }
.posts-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
.category-filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.cat-filter {
  padding: 7px 16px;
  border-radius: 50px;
  border: 1px solid rgba(16,185,129,0.25);
  background: transparent;
  color: rgba(255,255,255,0.6);
  font-size: 0.82rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}
.cat-filter:hover,
.cat-filter.active {
  background: rgba(16,185,129,0.15);
  border-color: rgba(16,185,129,0.5);
  color: #10b981;
}
.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.post-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
  transition: transform 0.3s ease;
}
.post-card:hover { transform: translateY(-4px); }
.post-img-wrap { position: relative; height: 200px; overflow: hidden; }
.post-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
.post-card:hover .post-img { transform: scale(1.06); }
.post-body {
  padding: 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.post-title {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.post-excerpt {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.58);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}
.post-arrow {
  color: #10b981;
  font-size: 1.1rem;
  font-weight: 700;
  transition: transform 0.2s;
}
.post-card:hover .post-arrow { transform: translateX(4px); }
.no-results {
  text-align: center;
  padding: 60px 20px;
  color: rgba(255,255,255,0.5);
  font-size: 1rem;
}
/* Filtered-out cards */
.post-card.hidden {
  display: none;
}

/* ======= NEWSLETTER CTA ======= */
.newsletter-section { background: var(--bg-primary); }
.newsletter-card {
  display: flex;
  gap: 48px;
  padding: 48px 52px;
  align-items: center;
}
.newsletter-content { flex: 1; }
.nl-icon { font-size: 2.8rem; margin-bottom: 14px; }
.nl-title {
  font-size: clamp(1.4rem, 3vw, 2rem);
  color: #fff;
  margin-bottom: 12px;
  font-weight: 700;
  line-height: 1.3;
}
.nl-desc { font-size: 1rem; color: rgba(255,255,255,0.65); margin-bottom: 24px; line-height: 1.6; }
.nl-actions { display: flex; gap: 14px; flex-wrap: wrap; }
.newsletter-visual {
  display: flex;
  gap: 32px;
  flex-shrink: 0;
}
.nl-stat { text-align: center; }
.stat-num { display: block; font-size: 2.2rem; font-weight: 800; color: #10b981; font-family: var(--font-heading); }
.stat-label { font-size: 0.8rem; color: rgba(255,255,255,0.5); font-weight: 500; white-space: nowrap; }

/* ======= SHARED ======= */
.section-label { font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #10b981; margin-bottom: 10px; }
.section-title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: #fff; margin-bottom: 0; }

/* ======= RESPONSIVE ======= */
@media (max-width: 1100px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
  .featured-grid { grid-template-columns: 1fr; }
  .featured-large { grid-row: auto; }
  .newsletter-card { flex-direction: column; padding: 32px 28px; }
  .newsletter-visual { justify-content: center; }
}
@media (max-width: 640px) {
  .posts-grid { grid-template-columns: 1fr; }
  .posts-header { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
// Category filter functionality
const filters = document.querySelectorAll('.cat-filter');
const cards = document.querySelectorAll('.post-card');
const noResults = document.getElementById('noResults');

filters.forEach(btn => {
  btn.addEventListener('click', () => {
    // Update active state
    filters.forEach(f => f.classList.remove('active'));
    btn.classList.add('active');

    const selected = btn.dataset.cat;

    let visible = 0;
    cards.forEach(card => {
      const category = card.dataset.category;
      if (selected === 'all' || category === selected) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  });
});
</script>
