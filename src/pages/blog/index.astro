---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog.js';
---

<Layout 
  title="Travel Blog | SF Travels Bangalore — Tips, Guides & Road Trip Stories"
  description="Expert travel tips, road trip guides, airport taxi advice, and corporate travel insights from SF Travels Bangalore. Plan smarter journeys across South India."
>
  <!-- Load Tailwind CDN on this page only to render classes without interfering with global.css -->
  <script src="https://cdn.tailwindcss.com" is:inline></script>
  <script is:inline>
    tailwind.config = {
      corePlugins: {
        preflight: false,
      },
      theme: {
        extend: {
          colors: {
            primaryGreen: '#1ecb15',
            hoverGreen: '#19b512'
          }
        }
      }
    }
  </script>

  <main class="bg-gray-50 min-h-screen overflow-x-hidden pt-12 text-slate-800">
    <section class="relative min-h-[50vh] flex items-center justify-center pt-20 overflow-hidden">
        <div class="absolute inset-0 z-0"
            style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/bda0fdb8b258bf205c0653b2583c1ec0.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat;">
        </div>
        <div
            class="absolute inset-0 bg-black/65 bg-gradient-to-b from-black/80 via-black/50 to-black/70 z-10 pointer-events-none">
        </div>
        <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight drop-shadow-lg">Our Blog
            </h1>
            <p
                class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed drop-shadow-md">
                Inspiration, guides, and tips for your next journey</p>
        </div>
    </section>

    <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {blogPosts.map(post => (
                  <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col h-full">
                      <div class="relative h-48 overflow-hidden shrink-0">
                          <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                          <div class="absolute top-4 left-4 bg-[#1ecb15] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                              {post.category}
                          </div>
                      </div>
                      <div class="p-6 flex-grow flex flex-col justify-between">
                          <div>
                              <div class="flex items-center text-gray-500 text-sm mb-4 space-x-4">
                                  <div class="flex items-center">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1">
                                          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                                          <line x1="16" x2="16" y1="2" y2="6"></line>
                                          <line x1="8" x2="8" y1="2" y2="6"></line>
                                          <line x1="3" x2="21" y1="10" y2="10"></line>
                                      </svg>
                                      {post.dateFormatted}
                                  </div>
                                  <div class="flex items-center">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1">
                                          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                                          <circle cx="12" cy="7" r="4"></circle>
                                      </svg>
                                      SF Travels Team
                                  </div>
                              </div>
                              <a href={`/blog/${post.slug}`} class="block">
                                  <h2 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2 hover:text-[#1ecb15] transition-colors cursor-pointer">
                                      {post.title}
                                  </h2>
                              </a>
                              <p class="text-gray-600 mb-6 text-sm line-clamp-3 leading-relaxed">
                                  {post.excerpt}
                              </p>
                          </div>
                          <a class="inline-flex items-center text-[#1ecb15] font-semibold hover:text-[#19b512] transition-colors mt-auto" href={`/blog/${post.slug}`}>
                              Read More 
                              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-1">
                                  <path d="M5 12h14"></path>
                                  <path d="m12 5 7 7-7 7"></path>
                              </svg>
                          </a>
                      </div>
                  </article>
                ))}
            </div>
        </div>
    </section>

    <!-- Newsletter section -->
    <section class="py-16 bg-white">
        <div class="container mx-auto px-4">
            <div class="max-w-3xl mx-auto text-center bg-gray-900 rounded-2xl p-8 md:p-12">
                <h2 class="text-3xl font-bold text-white mb-4">Subscribe to Our Newsletter</h2>
                <p class="text-gray-400 mb-8">Get the latest travel tips, exclusive offers, and destination guides delivered directly to your inbox.</p>
                <form class="flex flex-col md:flex-row gap-4 max-w-lg mx-auto" id="newsletterForm">
                    <input type="email" placeholder="Enter your email address" class="flex-grow px-5 py-3 rounded-lg border border-gray-800 bg-gray-950 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-[#1ecb15] focus:border-[#1ecb15]" required />
                    <button type="submit" class="bg-[#1ecb15] hover:bg-[#19b512] text-white px-8 py-3 rounded-lg font-semibold transition-colors duration-300">Subscribe</button>
                </form>
            </div>
        </div>
    </section>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const newsletterForm = document.getElementById('newsletterForm');
      if (newsletterForm) {
        newsletterForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const emailInput = newsletterForm.querySelector('input[type="email"]');
          alert(`Thank you for subscribing with ${emailInput.value}!`);
          emailInput.value = '';
        });
      }
    });
  </script>
</Layout>
