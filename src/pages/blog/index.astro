---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog.js';
---

<Layout 
  title="Travel Blog | SF Travels Bangalore — Tips, Guides & Road Trip Stories"
  description="Expert travel tips, road trip guides, airport taxi advice, and corporate travel insights from SF Travels Bangalore. Plan smarter journeys across South India."
>

  <main class="bg-white min-h-screen overflow-x-hidden pt-12 text-slate-800">

    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/bda0fdb8b258bf205c0653b2583c1ec0.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat; background-attachment: fixed;">
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-[#050914]/95 via-[#0A1128]/85 to-[#050914]/95 z-10 pointer-events-none"></div>
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <span class="font-bold text-sm uppercase tracking-[0.25em] block mb-4 drop-shadow" style="color: #ffffff !important;">SF Travels</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md" style="color: #ffffff !important;">
          Travel Guides &amp; <br />
          <span style="color: #fbbf24 !important;" class="drop-shadow-md">Road Trip Stories</span>
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-semibold drop-shadow-md" style="color: #ffffff !important;">
          Expert tips, outstation guides, airport travel advice, and corporate mobility insights from our team in Bangalore.
        </p>
        <div class="inline-block bg-[#D97706]/20 border border-[#D97706]/40 text-[#fbbf24] font-bold text-xs md:text-sm uppercase tracking-widest px-6 py-2.5 rounded-full shadow-md backdrop-blur-sm">
          <span>"Smooth Ride On Time"</span>
        </div>
      </div>
    </section>

    <!-- ===== BLOG POSTS GRID ===== -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#D97706] font-bold text-sm uppercase tracking-[0.25em] block mb-3">Our Blog</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-5">Latest Articles</h2>
          <p class="text-slate-500 max-w-2xl mx-auto text-lg leading-relaxed">Inspiration, guides, and tips for your next journey across Bangalore and beyond.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {blogPosts.map(post => (
            <article class="group bg-[#fafaf8] hover:bg-white rounded-3xl border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl hover:-translate-y-1 overflow-hidden transition-all duration-300 flex flex-col h-full">
              <!-- Card Image -->
              <div class="relative h-52 overflow-hidden shrink-0">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#1E2D5A]/80 via-[#1E2D5A]/20 to-transparent"></div>
                <!-- Category badge -->
                <div class="absolute top-4 left-4">
                  <span class="bg-[#D97706] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                    {post.category}
                  </span>
                </div>
              </div>

              <!-- Card Body -->
              <div class="p-7 flex-grow flex flex-col gap-4">
                <!-- Meta -->
                <div class="flex items-center gap-4 text-slate-400 text-xs">
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                    {post.dateFormatted}
                  </div>
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    {post.readTime}
                  </div>
                </div>

                <!-- Title -->
                <a href={`/blog/${post.slug}`} class="block flex-grow">
                  <h2 class="text-lg font-extrabold text-[#1a1f36] leading-snug mb-3 line-clamp-2 group-hover:text-[#1E2D5A] transition-colors">
                    {post.title}
                  </h2>
                  <p class="text-slate-500 text-sm leading-relaxed line-clamp-3">
                    {post.excerpt}
                  </p>
                </a>

                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mt-1">
                  {post.tags.slice(0, 3).map(tag => (
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[#1E2D5A] bg-[#1E2D5A]/8 border border-[#1E2D5A]/15 px-2.5 py-1 rounded-full">{tag}</span>
                  ))}
                </div>

                <!-- Read More -->
                <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-2 text-[#D97706] font-bold text-sm hover:text-[#b45309] transition-colors mt-auto pt-4 border-t border-slate-100">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CTA BANNER (matches home page) ===== -->
    <section class="relative overflow-hidden py-16 bg-[#0d1629]">
      <!-- Background image with deep brand overlay -->
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://images.unsplash.com/photo-1608340173813-afedec884f1f?w=1920&q=80'); background-size: cover; background-position: center;">
      </div>
      <div class="absolute inset-0 bg-slate-950/80 z-10"></div>

      <div class="container mx-auto px-4 relative z-20">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-10">
          <div class="text-center lg:text-left">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4" style="color: #ffffff !important;">Ready to Book Your Premium Ride?</h2>
            <p class="text-white/80 text-lg" style="color: rgba(255, 255, 255, 0.8) !important;">Get started today — our team confirms within 15 minutes.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0 items-center lg:items-start">
            <a href="tel:9353966815" class="inline-flex items-center justify-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold px-10 py-5 rounded-2xl text-lg transition-all shadow-lg">
              Book a Cab Now
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
            <a href="tel:9353966815" class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/25 hover:bg-white/20 text-white font-bold px-10 py-5 rounded-2xl text-lg transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              Call 9353966815
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

</Layout>
