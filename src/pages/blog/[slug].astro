---
import Layout from '../../layouts/Layout.astro';
import { blogPosts, getPostBySlug, getRelatedPosts } from '../../data/blog.js';

// Generate static paths for all posts
export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug);
const relatedPosts = getRelatedPosts(slug, 3);

// Fallback if post not found
if (!post) {
  return Astro.redirect('/blog');
}
---

<Layout
  title={`${post.title} | SF Travels Blog`}
  description={post.excerpt}
>

  <!-- ===== BREADCRUMB ===== -->
  <div class="bg-[#fafaf8] border-b border-slate-100" style="padding-top: 84px;">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center gap-2 flex-wrap text-sm">
        <a href="/" class="text-slate-500 hover:text-[#D97706] transition-colors font-medium">Home</a>
        <span class="text-slate-300">›</span>
        <a href="/blog" class="text-slate-500 hover:text-[#D97706] transition-colors font-medium">Blog</a>
        <span class="text-slate-300">›</span>
        <span class="text-[#1a1f36] font-semibold truncate max-w-xs">{post.title}</span>
      </div>
    </div>
  </div>

  <!-- ===== ARTICLE LAYOUT ===== -->
  <div class="bg-white py-14 pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="article-grid">

        <!-- MAIN ARTICLE COLUMN -->
        <article class="min-w-0">

          <!-- Article Hero Header -->
          <div class="mb-8">
            <span class="inline-block text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-5" style={`background: ${post.categoryColor}`}>
              {post.category}
            </span>
            <h1 class="text-3xl md:text-4xl font-extrabold text-[#1a1f36] leading-tight mb-5" style="color: #1a1f36 !important;">
              {post.title}
            </h1>
            <div class="flex flex-wrap gap-5 text-slate-500 text-sm">
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                {post.author}
              </span>
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                {post.dateFormatted}
              </span>
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {post.readTime}
              </span>
            </div>
          </div>

          <!-- Hero Image -->
          <div class="rounded-3xl overflow-hidden mb-10 h-80 md:h-[420px] shadow-lg">
            <img src={post.image} alt={post.title} class="w-full h-full object-cover" loading="eager" />
          </div>

          <!-- Article Body -->
          <div class="article-body">
            {post.content.map(block => {
              if (block.type === 'intro') {
                return <p class="text-base md:text-lg text-slate-600 leading-relaxed border-l-4 border-[#D97706] pl-5 mb-6 italic">{block.text}</p>;
              }
              if (block.type === 'h2') {
                return <h2 class="text-xl md:text-2xl font-extrabold text-[#1a1f36] mt-10 mb-4 pb-2 border-b border-slate-100" style="color: #1a1f36 !important;">{block.text}</h2>;
              }
              if (block.type === 'p') {
                return <p class="text-slate-600 text-sm md:text-base leading-relaxed mb-4" set:html={block.text.replace(/\n/g, '<br/>').replace(/\*\*(.*?)\*\*/g, '<strong class="text-[#1a1f36] font-bold">$1</strong>').replace(/•/g, '&#8226;')}></p>;
              }
              if (block.type === 'cta') {
                return (
                  <div class="bg-[#1E2D5A]/5 border border-[#1E2D5A]/15 rounded-3xl p-8 flex flex-col gap-4 mt-10">
                    <p class="text-slate-700 font-semibold text-sm leading-relaxed">Ready to book your ride? SF Travels offers premium, transparent cab services across Bangalore and South India.</p>
                    <a href={block.href} class="inline-flex items-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold px-6 py-3 rounded-xl text-sm transition-all duration-300 shadow hover:shadow-lg w-fit">
                      {block.text}
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                    </a>
                  </div>
                );
              }
              return null;
            })}
          </div>

          <!-- Tags -->
          <div class="flex items-center gap-3 flex-wrap mt-10 pt-8 border-t border-slate-100">
            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Tagged:</span>
            <div class="flex gap-2 flex-wrap">
              {post.tags.map(tag => (
                <span class="text-xs font-bold uppercase tracking-wider text-[#1E2D5A] bg-[#1E2D5A]/8 border border-[#1E2D5A]/15 px-3 py-1.5 rounded-full">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Share Bar -->
          <div class="flex items-center gap-4 flex-wrap mt-6 p-6 rounded-2xl bg-[#fafaf8] border border-slate-100">
            <span class="text-sm font-bold text-slate-500">Share this article:</span>
            <div class="flex gap-3 flex-wrap">
              <a
                href={`https://wa.me/?text=${encodeURIComponent(post.title + ' — Read on SF Travels Blog: https://sftravels.in/blog/' + post.slug)}`}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 text-xs font-bold px-4 py-2 rounded-lg bg-green-50 border border-green-200 text-green-700 hover:bg-green-100 transition-colors"
                aria-label="Share on WhatsApp"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent('https://sftravels.in/blog/' + post.slug)}`}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 text-xs font-bold px-4 py-2 rounded-lg bg-slate-50 border border-slate-200 text-slate-600 hover:bg-slate-100 transition-colors"
                aria-label="Share on X/Twitter"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.733-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Tweet
              </a>
              <button
                class="inline-flex items-center gap-2 text-xs font-bold px-4 py-2 rounded-lg bg-slate-50 border border-slate-200 text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer"
                id="copyUrlBtn"
                data-url={`https://sftravels.in/blog/${post.slug}`}
                aria-label="Copy link"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                <span id="copyLabel">Copy Link</span>
              </button>
            </div>
          </div>

        </article>

        <!-- SIDEBAR -->
        <aside class="sidebar-sticky flex flex-col gap-6">

          <!-- Quick Booking Card -->
          <div class="bg-[#1E2D5A] rounded-3xl p-7 text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#D97706]/20 flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#fbbf24]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
            </div>
            <h3 class="text-white font-extrabold text-lg mb-2" style="color: #ffffff !important;">Book a Cab Now</h3>
            <p class="text-slate-300 text-sm mb-5 leading-relaxed">Ready to travel? Our dispatch is live 24/7 for any booking.</p>
            <div class="flex flex-col gap-3">
              <a href="tel:+919353966815" class="w-full inline-flex items-center justify-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold py-3 px-4 rounded-xl text-sm transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                Call: 9353966815
              </a>
              <a href="https://wa.me/919353966815" target="_blank" rel="noopener" class="w-full inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold py-3 px-4 rounded-xl text-sm transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                WhatsApp Us
              </a>
            </div>
          </div>

          <!-- Services Quick Links -->
          <div class="bg-[#fafaf8] border border-slate-100 rounded-3xl p-6">
            <h3 class="font-extrabold text-[#1a1f36] mb-4 text-base" style="color: #1a1f36 !important;">Our Services</h3>
            <div class="flex flex-col gap-1">
              <a href="/services/airport-taxi" class="flex items-center gap-2.5 text-sm text-slate-600 hover:text-[#D97706] px-3 py-2.5 rounded-xl hover:bg-[#D97706]/8 transition-all">
                <span>✈️</span> Airport Taxi Bangalore
              </a>
              <a href="/services/outstation-cabs" class="flex items-center gap-2.5 text-sm text-slate-600 hover:text-[#D97706] px-3 py-2.5 rounded-xl hover:bg-[#D97706]/8 transition-all">
                <span>🗺️</span> Outstation Cabs
              </a>
              <a href="/services/one-way-taxi" class="flex items-center gap-2.5 text-sm text-slate-600 hover:text-[#D97706] px-3 py-2.5 rounded-xl hover:bg-[#D97706]/8 transition-all">
                <span>🏢</span> One Way Taxi
              </a>
              <a href="/services/local-hire" class="flex items-center gap-2.5 text-sm text-slate-600 hover:text-[#D97706] px-3 py-2.5 rounded-xl hover:bg-[#D97706]/8 transition-all">
                <span>🕐</span> Local Hourly Hire
              </a>
              <a href="/more-services/bus-rental" class="flex items-center gap-2.5 text-sm text-slate-600 hover:text-[#D97706] px-3 py-2.5 rounded-xl hover:bg-[#D97706]/8 transition-all">
                <span>🚌</span> Bus Rental
              </a>
              <a href="/more-services/wedding-transport" class="flex items-center gap-2.5 text-sm text-slate-600 hover:text-[#D97706] px-3 py-2.5 rounded-xl hover:bg-[#D97706]/8 transition-all">
                <span>💍</span> Wedding Transport
              </a>
            </div>
          </div>

          <!-- Article Info -->
          <div class="bg-[#fafaf8] border border-slate-100 rounded-3xl p-6">
            <h3 class="font-extrabold text-[#1a1f36] mb-4 text-base" style="color: #1a1f36 !important;">Article Info</h3>
            <div class="space-y-3">
              <div class="flex justify-between text-sm py-2 border-b border-slate-100">
                <span class="text-slate-400 font-medium">Category</span>
                <span class="font-bold" style={`color: ${post.categoryColor}`}>{post.category}</span>
              </div>
              <div class="flex justify-between text-sm py-2 border-b border-slate-100">
                <span class="text-slate-400 font-medium">Published</span>
                <span class="text-slate-700 font-semibold">{post.dateFormatted}</span>
              </div>
              <div class="flex justify-between text-sm py-2 border-b border-slate-100">
                <span class="text-slate-400 font-medium">Read Time</span>
                <span class="text-slate-700 font-semibold">{post.readTime}</span>
              </div>
              <div class="flex justify-between text-sm py-2">
                <span class="text-slate-400 font-medium">Author</span>
                <span class="text-slate-700 font-semibold">{post.author}</span>
              </div>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </div>

  <!-- ===== RELATED POSTS ===== -->
  {relatedPosts.length > 0 && (
    <section class="py-24 bg-[#fafaf8] border-t border-slate-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <span class="text-[#D97706] font-bold text-sm uppercase tracking-[0.25em] block mb-3">You Might Also Like</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36]">Related <span class="text-[#D97706]">Articles</span></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {relatedPosts.map(rp => (
            <a href={`/blog/${rp.slug}`} class="group bg-white rounded-3xl border border-slate-100 hover:border-slate-200 hover:shadow-xl hover:-translate-y-1 overflow-hidden transition-all duration-300 flex flex-col">
              <div class="relative h-44 overflow-hidden">
                <img src={rp.image} alt={rp.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#1E2D5A]/70 to-transparent"></div>
                <span class="absolute top-3 left-3 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider" style={`background: ${rp.categoryColor}`}>{rp.category}</span>
              </div>
              <div class="p-6 flex flex-col gap-3 flex-grow">
                <div class="flex gap-4 text-xs text-slate-400">
                  <span>{rp.dateFormatted}</span>
                  <span>{rp.readTime}</span>
                </div>
                <h3 class="font-extrabold text-[#1a1f36] text-base leading-snug line-clamp-2 group-hover:text-[#1E2D5A] transition-colors" style="color: #1a1f36 !important;">{rp.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed line-clamp-2 flex-grow">{rp.excerpt}</p>
                <div class="inline-flex items-center gap-1.5 text-[#D97706] font-bold text-sm mt-auto pt-3 border-t border-slate-100">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== BACK TO BLOG ===== -->
  <section class="py-10 bg-white border-t border-slate-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm font-bold text-[#1E2D5A] hover:text-[#D97706] border border-slate-200 hover:border-[#D97706]/40 px-5 py-3 rounded-xl transition-all duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 19l-7-7 7-7"></path></svg>
        Back to All Articles
      </a>
    </div>
  </section>

</Layout>

<style>
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    align-items: start;
  }
  .sidebar-sticky {
    position: sticky;
    top: 104px;
  }
  @media (max-width: 1024px) {
    .article-grid { grid-template-columns: 1fr; }
    .sidebar-sticky { position: static; }
  }
</style>

<script>
  // Copy URL functionality
  const copyBtn = document.getElementById('copyUrlBtn');
  const copyLabel = document.getElementById('copyLabel');
  if (copyBtn && copyLabel) {
    copyBtn.addEventListener('click', async () => {
      const url = (copyBtn as HTMLElement).dataset.url;
      try {
        await navigator.clipboard.writeText(url || '');
        copyLabel.textContent = 'Copied!';
        setTimeout(() => { copyLabel.textContent = 'Copy Link'; }, 2000);
      } catch {
        copyLabel.textContent = 'Copy failed';
      }
    });
  }
</script>
