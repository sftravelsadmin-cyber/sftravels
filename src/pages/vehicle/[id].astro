---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allVehicles = [
    // Cars
    { id: "hatchback", name: "Hatchback", seats: "4+1", luggage: "1-2 Bags", category: "Car", type: "Standard Comfort", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/hatchback-1770872540052-15.png" },
    { id: "sedan", name: "Sedan", seats: "4+1", luggage: "2 Bags", category: "Car", type: "Standard Comfort", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/sedan-1770872682504-18.png" },
    { id: "ertiga", name: "Ertiga", seats: "6+1", luggage: "3 Bags", category: "MPV", type: "Family Travel", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/ertiga-1770870707273-12.png" },
    { id: "innova", name: "Innova", seats: "7+1", luggage: "4 Bags", category: "MPV", type: "Premium Tourer", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-1770870734987-27.png" },
    { id: "innova-crysta", name: "Innova Crysta", seats: "7+1", luggage: "4 Bags", category: "MPV", type: "Executive Class", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-crysta-1770870762832-21.png" },
    { id: "innova-hycross", name: "Innova Hycross", seats: "7+1", luggage: "4 Bags", category: "MPV", type: "Luxury Hybrid Class", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-hycross-1770870785541-24.png" },
    
    // Force Urbania
    { id: "force-urbania-deluxe", name: "Force Urbania Deluxe", seats: "9", luggage: "6-8 Bags", category: "Van", type: "Premium Cruiser", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-deluxe-1770870970157-1.png" },
    { id: "force-urbania-luxury", name: "Force Urbania Luxury", seats: "12", luggage: "8-10 Bags", category: "Van", type: "Royal Luxury Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-luxury-1770870993546-3.png" },
    { id: "force-urbania-maharaj", name: "Force Urbania Maharaj", seats: "14", luggage: "10-12 Bags", category: "Van", type: "Maharaj Edition", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-maharaj-1770871014554-6.png" },
    
    // Tempo Traveller
    { id: "tempo-traveller-12", name: "Tempo Traveller 12", seats: "12", luggage: "8 Bags", category: "Van", type: "Standard Tourist Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-12-1770871044575-9.png" },
    { id: "tempo-traveller-13", name: "Tempo Traveller 13", seats: "13", luggage: "9 Bags", category: "Van", type: "Standard Tourist Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-13-1770871064897-30.png" },
    { id: "tempo-traveller-14", name: "Tempo Traveller 14", seats: "14", luggage: "10 Bags", category: "Van", type: "Executive Group Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-14-1770871083292-33.png" },
    
    // Buses
    { id: "mini-bus-21", name: "Mini Bus 21", seats: "21", luggage: "15-20 Bags", category: "Bus", type: "Mini Group Travel", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-21-1770871153503-36.png" },
    { id: "mini-bus-25", name: "Mini Bus 25", seats: "25", luggage: "20-25 Bags", category: "Bus", type: "Premium Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-25-1770871172403-39.png" },
    { id: "mini-bus-30", name: "Mini Bus 30", seats: "30", luggage: "25-30 Bags", category: "Bus", type: "Corporate Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-30-1770871190798-42.png" },
    { id: "bus-33", name: "Bus 33", seats: "33", luggage: "30 Bags", category: "Bus", type: "Standard Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-33-1770871212474-45.png" },
    { id: "bus-40", name: "Bus 40", seats: "40", luggage: "35-40 Bags", category: "Bus", type: "Large Group Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-40-1770871824256-47.png" },
    { id: "volvo-bus-45", name: "Volvo Bus 45", seats: "45", luggage: "40-45 Bags", category: "Bus", type: "Volvo Premium Class", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/volvo-bus-45-1770872238415-49.png" },
    { id: "bus-50-seater", name: "Bus 50 Seater", seats: "50", luggage: "45-50 Bags", category: "Bus", type: "Ultra High Capacity Coach", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-50-1770872267131-52.png" }
  ];

  return allVehicles.map(v => ({
    params: { id: v.id },
    props: { vehicle: v }
  }));
}

const { vehicle } = Astro.props;
const placeholderImage = "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/hatchback-1770872540052-15.png";
---

<Layout 
  title={`${vehicle.name} - SF Travels Bangalore`}
  description={`Book premium ${vehicle.name} (${vehicle.seats} seats) with professional drivers for airport transfers, outstation tours and local corporate mobility in Bangalore.`}
>
  
  <main class="bg-[#fafaf8] min-h-screen overflow-x-hidden text-slate-800">
    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden bg-[#0d1629]">
      <!-- Full-bleed background matching home page -->
      <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.unsplash.com/photo-1608340173813-afedec884f1f?w=1920&q=80');">
      </div>
      <div class="absolute inset-0 bg-black/60 z-10 pointer-events-none"></div>
      
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <button
          onclick="history.back()"
          class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-md hover:text-[#fbbf24] hover:border-[#fbbf24] hover:bg-white/10 transition-all mb-8 shadow-sm"
          style="color: #ffffff !important;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-white">
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          <span class="font-bold text-xs uppercase tracking-wider" style="color: #ffffff !important;">Back to Fleet</span>
        </button>
        
        <span class="font-bold text-xs sm:text-sm uppercase tracking-[0.25em] block mb-4 drop-shadow text-[#fbbf24]" style="color: #fbbf24 !important;">{vehicle.category} FLEET</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md text-white" style="color: #ffffff !important;">
          {vehicle.name}
        </h1>
        <div class="flex flex-wrap items-center justify-center gap-3 text-xs sm:text-sm md:text-base">
          <span class="bg-[#D97706]/20 border border-[#D97706]/40 text-[#fbbf24] px-4 py-1.5 rounded-full font-bold text-xs uppercase tracking-wider" style="color: #fbbf24 !important;">{vehicle.seats} Seater</span>
          <span class="w-1.5 h-1.5 rounded-full bg-gray-500"></span>
          <span class="font-semibold text-gray-300" style="color: #d1d5db !important;">{vehicle.type}</span>
        </div>
      </div>
    </section>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 relative z-20">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Column: Image and Specs -->
        <div class="lg:col-span-2 space-y-8 w-full min-w-0">
          
          <!-- Vehicle Image -->
          <div class="bg-white p-4 sm:p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 w-full">
            <div class="relative h-64 sm:h-80 md:h-[450px] w-full rounded-2xl overflow-hidden bg-[#fafaf8] border border-slate-100 shadow-inner group">
              <img 
                src={vehicle.image || placeholderImage} 
                alt={vehicle.name} 
                class="w-full h-full object-cover transform duration-500 group-hover:scale-[1.02]" 
              />
              <div class="absolute top-4 left-4 bg-slate-900/80 backdrop-blur-md px-4 py-2 rounded-xl border border-white/10 text-white text-xs font-bold uppercase tracking-wider">
                {vehicle.category}
              </div>
            </div>
          </div>

          <!-- Overview Stats -->
          <div class="bg-white p-6 sm:p-8 rounded-3xl border border-slate-200/50 shadow-sm">
            <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">Vehicle Details</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1a1f36] mb-8 font-heading">Specifications</h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
              
              <!-- Seating Capacity -->
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-[#fafaf8] border border-slate-100 hover:border-[#1E2D5A]/10 transition-colors">
                <div class="bg-[#1E2D5A]/10 p-3 rounded-xl shrink-0 text-[#1E2D5A]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-bold uppercase tracking-wider">Seating Capacity</p>
                  <p class="font-extrabold text-[#1E2D5A] text-base sm:text-lg mt-1">{vehicle.seats} Seater</p>
                </div>
              </div>

              <!-- Luggage Space -->
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-[#fafaf8] border border-slate-100 hover:border-[#1E2D5A]/10 transition-colors">
                <div class="bg-[#1E2D5A]/10 p-3 rounded-xl shrink-0 text-[#1E2D5A]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                    <rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-bold uppercase tracking-wider">Luggage Capacity</p>
                  <p class="font-extrabold text-[#1E2D5A] text-base sm:text-lg mt-1">{vehicle.luggage}</p>
                </div>
              </div>

              <!-- Safety Features -->
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-[#fafaf8] border border-slate-100 hover:border-[#1E2D5A]/10 transition-colors">
                <div class="bg-[#1E2D5A]/10 p-3 rounded-xl shrink-0 text-[#1E2D5A]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-bold uppercase tracking-wider">Safety Standard</p>
                  <p class="font-extrabold text-[#1E2D5A] text-base sm:text-lg mt-1">GPS, First Aid, Fire Ext.</p>
                </div>
              </div>

              <!-- Permit Type -->
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-[#fafaf8] border border-slate-100 hover:border-[#1E2D5A]/10 transition-colors">
                <div class="bg-[#1E2D5A]/10 p-3 rounded-xl shrink-0 text-[#1E2D5A]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-500 font-bold uppercase tracking-wider">Permit Status</p>
                  <p class="font-extrabold text-[#1E2D5A] text-base sm:text-lg mt-1">All India Tourist Permit</p>
                </div>
              </div>

            </div>

            <!-- Key Features -->
            <div class="border-t border-slate-100 pt-8">
              <h3 class="text-lg font-bold text-[#1a1f36] mb-5 font-heading">Included Comforts</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex items-center gap-3">
                  <div class="bg-[#D97706]/10 p-1.5 rounded-lg text-[#D97706] shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                  <span class="text-slate-700 font-semibold text-sm sm:text-base">Air Conditioning (AC)</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="bg-[#D97706]/10 p-1.5 rounded-lg text-[#D97706] shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                  <span class="text-slate-700 font-semibold text-sm sm:text-base">Premium Audio System</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="bg-[#D97706]/10 p-1.5 rounded-lg text-[#D97706] shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                  <span class="text-slate-700 font-semibold text-sm sm:text-base">Professional Uniformed Driver</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="bg-[#D97706]/10 p-1.5 rounded-lg text-[#D97706] shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                  <span class="text-slate-700 font-semibold text-sm sm:text-base">Clean & Sanitized Interior</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Available Services -->
          <div class="bg-white p-6 sm:p-8 rounded-3xl border border-slate-200/50 shadow-sm">
            <h2 class="text-lg sm:text-xl font-extrabold text-[#1a1f36] mb-5 font-heading">Available For Services</h2>
            <div class="flex flex-wrap gap-3">
              {["Local Hire", "Airport Transfers", "Outstation Tours", "One-Way Trips"].map(s => (
                <span class="bg-[#fafaf8] text-[#374151] border border-slate-200/60 px-4 py-2.5 rounded-2xl text-xs sm:text-sm font-semibold hover:border-[#D97706] hover:text-[#D97706] hover:bg-[#D97706]/5 transition-all cursor-default shadow-sm">
                  {s}
                </span>
              ))}
            </div>
          </div>

        </div>

        <!-- Right Column: Sticky Booking Widget -->
        <div class="lg:col-span-1 space-y-6 w-full">
          <div class="bg-[#0d1629] text-white p-6 sm:p-8 rounded-3xl border border-slate-800 shadow-xl sticky top-24 overflow-hidden relative group">
            <!-- Backdrop Glow effects -->
            <div class="absolute -top-20 -right-20 w-40 h-40 bg-[#D97706]/15 rounded-full blur-2xl opacity-80 pointer-events-none"></div>
            <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-[#1E2D5A]/30 rounded-full blur-2xl opacity-60 pointer-events-none"></div>
            
            <div class="relative z-10">
              <span class="text-[#fbbf24] font-bold text-xs uppercase tracking-[0.2em] block mb-3" style="color: #fbbf24 !important;">Live Dispatch Desk</span>
              <h3 class="text-2xl font-extrabold mb-3 leading-snug font-heading" style="color: #ffffff !important;">Book {vehicle.name}</h3>
              <p class="text-slate-400 text-sm mb-6 leading-relaxed" style="color: #94a3b8 !important;">
                Rent this vehicle with an experienced professional driver. Transparent slab rate billing and zero hidden fees.
              </p>
              
              <div class="space-y-3 mb-8">
                <button
                  class="btn-gold w-full py-4 text-base font-bold shadow-lg hover:shadow-[#D97706]/20 transition-all transform hover:-translate-y-0.5 rounded-2xl flex items-center justify-center gap-2 group cursor-pointer"
                  data-book-now
                  data-vehicle={vehicle.name}
                  data-category={`${vehicle.category} Fleet`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                    <line x1="16" x2="16" y1="2" y2="6"></line>
                    <line x1="8" x2="8" y1="2" y2="6"></line>
                    <line x1="3" x2="21" y1="10" y2="10"></line>
                  </svg>
                  <span>Book This Vehicle</span>
                </button>
                
                <a
                  href="https://wa.me/919353966815?text=Hello%20SF%20Travels%2C%20I%20would%20like%20to%20book%20the%20vehicle%3A%20"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full inline-flex items-center justify-center gap-2 border border-white/10 hover:border-[#fbbf24]/50 hover:bg-[#fbbf24]/5 text-white py-4 rounded-2xl text-base font-bold transition-all"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-emerald-400"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                  <span>WhatsApp Booking</span>
                </a>
              </div>
              
              <div class="border-t border-slate-800/80 pt-6">
                <ul class="space-y-3">
                  <li class="flex items-center gap-3 text-xs font-semibold" style="color: #94a3b8 !important;">
                    <svg class="w-4 h-4 text-[#fbbf24] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span style="color: #94a3b8 !important;">24/7 Customer Support</span>
                  </li>
                  <li class="flex items-center gap-3 text-xs font-semibold" style="color: #94a3b8 !important;">
                    <svg class="w-4 h-4 text-[#fbbf24] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span style="color: #94a3b8 !important;">Zero Hidden Fees</span>
                  </li>
                  <li class="flex items-center gap-3 text-xs font-semibold" style="color: #94a3b8 !important;">
                    <svg class="w-4 h-4 text-[#fbbf24] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span style="color: #94a3b8 !important;">Sanitized & Serviced Fleets</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

