---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Outstation Car Rental Bangalore | SF Travels"
  description="Rent premium outstation cars from Bangalore with SF Travels. Transparent pricing to Mysore, Ooty, Coorg, and other major intercity destinations."
>
  <main class="bg-[#fafaf8] min-h-screen overflow-x-hidden text-slate-800">
    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden flex items-center justify-center bg-[#0d1629]">
      <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.unsplash.com/photo-1551952237-954a0e68786c?w=1920&q=80');">
      </div>
      <div class="absolute inset-0 bg-black/60 z-10 pointer-events-none"></div>
      
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <span class="font-bold text-xs sm:text-sm uppercase tracking-[0.25em] block mb-4 drop-shadow text-[#fbbf24]" style="color: #fbbf24 !important;">Intercity Highway Travel</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md text-white" style="color: #ffffff !important;">
          Outstation Car Rentals
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-semibold drop-shadow-md text-white" style="color: #ffffff !important;">
          Set off on intercity adventures or business trips across Karnataka and neighbouring states. Travel in comfort on long drives, family holidays, and scenic road trips.
        </p>
        <div class="inline-block bg-[#D97706]/20 border border-[#D97706]/40 text-[#fbbf24] font-bold text-xs md:text-sm uppercase tracking-widest px-6 py-2.5 rounded-full shadow-md backdrop-blur-sm" style="color: #fbbf24 !important;">
          <span>"Smooth Ride On Time"</span>
        </div>
      </div>
    </section>
    <!-- ===== INTRO & PILLARS ===== -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">Intercity Excursions</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-6 font-heading">Premium Outstation Travel Solutions</h2>
          <p class="text-slate-600 text-base sm:text-lg leading-relaxed">
            Heading to destinations like Mysuru, Coorg, Ooty, or Chikmagalur? Our outstation car rentals deliver the ultimate highway experience. Travel in clean, high-performance vehicles driven by expert highway chauffeurs.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          <!-- Pillar 1 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Flexible Drop-offs</h3>
            <p class="text-sm text-gray-600">Travel to any destination across South India with direct drops or round trips.</p>
          </div>

          <!-- Pillar 2 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Custom Schedules</h3>
            <p class="text-sm text-gray-600">Stop, start, and adjust your tour itinerary whenever and wherever you want.</p>
          </div>

          <!-- Pillar 3 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Verified Chauffeurs</h3>
            <p class="text-sm text-gray-600">Polite, background-verified highway drivers trained in defensive driving.</p>
          </div>

          <!-- Pillar 4 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M17 8h1a4 4 0 1 1 0 8h-1"></path>
                <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
                <line x1="6" x2="6" y1="2" y2="4"></line>
                <line x1="10" x2="10" y1="2" y2="4"></line>
                <line x1="14" x2="14" y1="2" y2="4"></line>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Highway Rest Stops</h3>
            <p class="text-sm text-gray-600">Pause for refreshments or scenic views at any point on the highway.</p>
          </div>
        </div>
      </div>
    </section>
    <!-- ===== FLEET SECTION ===== -->
    <section class="py-24 bg-[#fafaf8] border-y border-slate-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">Outstation Vehicles</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-5 font-heading">Choose Your Outstation Ride</h2>
          <p class="text-slate-600 max-w-2xl mx-auto text-sm sm:text-base">
            Select from our wide range of clean and sanitized vehicles. Choose a compact hatchback for solo trips or a luxury tempo traveller for group tours.
          </p>
        </div>

        <!-- Section 1: Cars & SUVs -->
        <h3 class="text-xl font-bold text-gray-900 mb-8 pl-3 border-l-4 border-[#D97706] font-heading">Cars, SUVs &amp; MPVs</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
          
          <!-- Hatchback -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/hatchback.webp" alt="Hatchback" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">CAR</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Hatchback</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>4+1 Seater</span>
              </div>
              <div class="space-y-1 mb-6 flex-grow text-sm">
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>Professional Uniformed Driver</span></div>
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>AC &amp; Music System</span></div>
              </div>
              <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                <button data-book-now data-vehicle="Hatchback" data-category="Car" class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer">Book Now</button>
                <a href="/vehicle/hatchback" class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all">Details</a>
              </div>
            </div>
          </div>

          <!-- Sedan -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/sedan.webp" alt="Sedan" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">CAR</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Sedan</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>4+1 Seater</span>
              </div>
              <div class="space-y-1 mb-6 flex-grow text-sm">
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>Professional Uniformed Driver</span></div>
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>AC &amp; Music System</span></div>
              </div>
              <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                <button data-book-now data-vehicle="Sedan" data-category="Car" class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer">Book Now</button>
                <a href="/vehicle/sedan" class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all">Details</a>
              </div>
            </div>
          </div>


          <!-- Ertiga -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/ertiga.webp" alt="Ertiga" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">MPV</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Ertiga</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>6+1 Seater</span>
              </div>
              <div class="space-y-1 mb-6 flex-grow text-sm">
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>Professional Uniformed Driver</span></div>
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>AC &amp; Music System</span></div>
              </div>
              <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                <button data-book-now data-vehicle="Ertiga" data-category="MPV" class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer">Book Now</button>
                <a href="/vehicle/ertiga" class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all">Details</a>
              </div>
            </div>
          </div>

          <!-- Innova -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/innova.webp" alt="Innova" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">MPV</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Innova</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>7+1 Seater</span>
              </div>
              <div class="space-y-1 mb-6 flex-grow text-sm">
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>Professional Uniformed Driver</span></div>
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>AC &amp; Music System</span></div>
              </div>
              <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                <button data-book-now data-vehicle="Innova" data-category="MPV" class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer">Book Now</button>
                <a href="/vehicle/innova" class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all">Details</a>
              </div>
            </div>
          </div>

          <!-- Innova Crysta -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/innova-crysta.webp" alt="Innova Crysta" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">MPV</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Innova Crysta</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>7+1 Seater</span>
              </div>
              <div class="space-y-1 mb-6 flex-grow text-sm">
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>Professional Uniformed Driver</span></div>
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>AC &amp; Music System</span></div>
              </div>
              <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                <button data-book-now data-vehicle="Innova Crysta" data-category="MPV" class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer">Book Now</button>
                <a href="/vehicle/innova-crysta" class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all">Details</a>
              </div>
            </div>
          </div>

          <!-- Innova Hycross -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/innova-hycross.webp" alt="Innova Hycross" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">MPV</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Innova Hycross</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>7+1 Seater</span>
              </div>
              <div class="space-y-1 mb-6 flex-grow text-sm">
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>Professional Uniformed Driver</span></div>
                <div class="flex items-center text-slate-600"><span class="text-[#D97706] mr-2 font-bold">✓</span><span>AC &amp; Music System</span></div>
              </div>
              <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                <button data-book-now data-vehicle="Innova Hycross" data-category="MPV" class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer">Book Now</button>
                <a href="/vehicle/innova-hycross" class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all">Details</a>
              </div>
            </div>
          </div>

        </div>

        <!-- Section 2: Tempo Travellers & Buses -->
        <h3 class="text-xl font-bold text-gray-900 mb-8 pl-3 border-l-4 border-[#D97706] font-heading">Tempo Travellers &amp; Buses</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          
          <!-- Force Urbania Deluxe -->
          <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
            <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
              <img src="/images/vehicles/force-urbania-deluxe.webp" alt="Force Urbania Deluxe" class="w-full h-full object-cover transform duration-500 hover:scale-105">
              <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">VAN</div>
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">Force Urbania Deluxe</h3>
              <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                </svg>
                <span>9 Seater</span>
              </div>
