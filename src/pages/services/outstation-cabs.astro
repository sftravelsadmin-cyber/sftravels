---
import Layout from '../../layouts/Layout.astro';
import { fleet } from '../../data/fleet.js';

const outstationVehicles = fleet.filter(v => ['swift-dzire','toyota-innova','innova-crysta','tempo-traveller'].includes(v.id));

const destinations = [
  { city: 'Mysuru', distance: '150 km', time: '3 hrs', icon: '🏰', from: '₹2,800' },
  { city: 'Coorg', distance: '265 km', time: '5 hrs', icon: '🌿', from: '₹4,200' },
  { city: 'Ooty', distance: '270 km', time: '5.5 hrs', icon: '🏔️', from: '₹4,500' },
  { city: 'Goa', distance: '570 km', time: '10 hrs', icon: '🏖️', from: '₹8,500' },
  { city: 'Chennai', distance: '350 km', time: '6.5 hrs', icon: '🌆', from: '₹5,800' },
  { city: 'Hyderabad', distance: '570 km', time: '10 hrs', icon: '🕌', from: '₹9,500' },
  { city: 'Tirupati', distance: '280 km', time: '5 hrs', icon: '🛕', from: '₹4,800' },
  { city: 'Wayanad', distance: '280 km', time: '5.5 hrs', icon: '🌲', from: '₹4,600' },
];

const features = [
  { icon: '📍', title: 'Real-Time GPS', desc: 'Family can track your journey live on Google Maps, mile by mile.' },
  { icon: '⛽', title: 'No Hidden Fuel Surcharge', desc: 'Fuel cost is baked into your flat-rate quote. Zero fuel surprises mid-trip.' },
  { icon: '💺', title: 'Ergonomic Comfort', desc: 'Plush seats designed for long-haul comfort. Lumbar support in all SUVs.' },
  { icon: '🛑', title: 'Free Rest Stops', desc: 'Driver stops at your request. No pressure to hurry through your journey.' },
  { icon: '🌙', title: 'Night Driving Experts', desc: 'Our outstation drivers are specially trained for highway night driving.' },
  { icon: '🔄', title: 'Round Trip Discounts', desc: 'Book return journey at booking time and save 10–15% on the total fare.' },
];

const faqs = [
  { q: 'What is the minimum booking for outstation?', a: 'Minimum distance is 80 km per day for Sedans and 100 km for SUVs and Tempo Travellers.' },
  { q: 'Are tolls and parking included in the price?', a: 'Tolls are charged at actuals. State permits and parking are included for Karnataka routes. Interstate travel may have additional state permit costs.' },
  { q: 'Can I book a one-way outstation trip?', a: 'Yes, one-way outstation trips are available for select routes. Please call our dispatch to confirm availability and pricing for one-way.' },
  { q: 'Is there an overnight driver allowance?', a: 'For trips requiring the driver to stay overnight, a ₹500/night driver allowance is charged. This is disclosed upfront, never as a surprise.' },
  { q: 'Can we stop midway for sightseeing?', a: 'Absolutely. Outstation bookings are per-day packages. The driver will accompany and wait during sightseeing stops.' },
];
---

<Layout
  title="Outstation Cabs Bangalore | SF Travels — Flat Rate Intercity Travel"
  description="Book premium outstation cabs from Bangalore with SF Travels. Flat-rate pricing to Mysuru, Coorg, Ooty, Goa, Chennai, and 50+ destinations. GPS-tracked rides."
>

  <!-- ==================== HERO ==================== -->
  <section class="service-hero outstation-hero">
    <div class="hero-overlay-dark"></div>
    <div class="container service-hero-content">
      <div class="service-badge-pill">🗺️ Outstation Travel</div>
      <h1 class="service-hero-title">
        Weekend Getaway or Long Haul —<br />
        <span class="gold-text">We Drive You There.</span>
      </h1>
      <p class="service-hero-desc">
        Flat-rate intercity rides from Bangalore. No surge pricing. No meter anxiety. Just a trusted chauffeur, a full tank, and the open highway ahead of you.
      </p>
      <div class="service-hero-cta">
        <a href="/contact" class="btn-gold">📞 Get Outstation Quote</a>
        <a href="https://wa.me/919187232348?text=Hi%2C%20I%20need%20an%20outstation%20cab%20from%20Bangalore." target="_blank" rel="noopener" class="btn-outline">💬 WhatsApp Trip Plan</a>
      </div>
      <div class="hero-pills">
        <span class="pill">✓ Flat-rate billing</span>
        <span class="pill">✓ GPS tracked</span>
        <span class="pill">✓ No fuel surcharge</span>
        <span class="pill">✓ 50+ destinations</span>
      </div>
    </div>
  </section>

  <!-- ==================== POPULAR DESTINATIONS ==================== -->
  <section class="section-padding dest-section">
    <div class="container">
      <div class="section-label">Top Routes from Bangalore</div>
      <h2 class="section-title">Popular <span class="gold-text">Destinations</span></h2>
      <p class="section-desc">Prices shown are indicative Sedan (Dzire) fares. Call for exact quotes on SUVs and Tempo Travellers.</p>
      <div class="dest-grid">
        {destinations.map(d => (
          <a
            href={`https://wa.me/919187232348?text=Hi%2C%20I%20need%20an%20outstation%20cab%20from%20Bangalore%20to%20${encodeURIComponent(d.city)}`}
            target="_blank"
            rel="noopener"
            class="dest-card glass-card"
          >
            <div class="dest-icon">{d.icon}</div>
            <h3 class="dest-city">{d.city}</h3>
            <div class="dest-meta">
              <span>📏 {d.distance}</span>
              <span>⏱️ {d.time}</span>
            </div>
            <div class="dest-price">
              <span class="dest-from">From</span>
              <span class="dest-amount">{d.from}</span>
            </div>
            <div class="dest-cta">Get Quote →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FLEET ==================== -->
  <section class="section-padding fleet-section bg-navy-gradient">
    <div class="container">
      <div class="section-label">Our Outstation Fleet</div>
      <h2 class="section-title">Choose Your <span class="gold-text">Journey Ride</span></h2>
      <div class="fleet-grid">
        {outstationVehicles.map(v => (
          <div class="vehicle-card glass-card">
            <div class="vehicle-img-wrap">
              <img src={v.image} alt={v.name} class="vehicle-img" loading="lazy" />
              <span class="vehicle-badge" style={`background:${v.badgeColor}`}>{v.badge}</span>
            </div>
            <div class="vehicle-body">
              <h3 class="vehicle-name">{v.name}</h3>
              <p class="vehicle-tagline">{v.tagline}</p>
              <div class="vehicle-specs">
                <span class="spec-pill">👤 {v.seats} Seats</span>
                <span class="spec-pill">❄️ {v.acType}</span>
                <span class="spec-pill">🧳 {v.luggage}</span>
              </div>
              <div class="vehicle-price">
                <span class="price-label">From</span>
                <span class="price-value">{v.pricePerKm}</span>
              </div>
              <p class="vehicle-min">{v.minimumKm}</p>
              <a href={`https://wa.me/919187232348?text=Hi%2C%20I%20need%20outstation%20cab%20with%20${encodeURIComponent(v.name)}%20from%20Bangalore`} target="_blank" rel="noopener" class="btn-gold vehicle-book-btn">Book Outstation</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FEATURES ==================== -->
  <section class="section-padding features-section">
    <div class="container">
      <div class="section-label">What Makes Us Different</div>
      <h2 class="section-title">The SF Travels <span class="gold-text">Long Haul Promise</span></h2>
      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card glass-card">
            <div class="feature-icon">{f.icon}</div>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== WHAT'S INCLUDED ==================== -->
  <section class="section-padding included-section bg-navy-gradient">
    <div class="container">
      <div class="included-layout">
        <div class="included-content">
          <div class="section-label">Fare Breakdown</div>
          <h2 class="section-title">What's Included in Your <span class="gold-text">Flat Rate?</span></h2>
          <div class="included-list">
            <div class="included-item">✅ <strong>Fuel Cost</strong> — No fuel surcharge, ever.</div>
            <div class="included-item">✅ <strong>Driver Allowance</strong> — For trips under 1 day.</div>
            <div class="included-item">✅ <strong>State Permits</strong> — Karnataka inter-district included.</div>
            <div class="included-item">✅ <strong>GST Invoice</strong> — Proper tax receipt for reimbursement.</div>
            <div class="included-item">✅ <strong>GPS Tracking</strong> — Live share link via WhatsApp.</div>
          </div>
          <div class="excluded-header">What's Charged at Actuals</div>
          <div class="included-list">
            <div class="included-item excluded">🟡 Tolls — Charged at actual highway toll rates.</div>
            <div class="included-item excluded">🟡 Overnight stay (₹500/night driver allowance).</div>
            <div class="included-item excluded">🟡 Interstate state permits (outside Karnataka).</div>
          </div>
        </div>
        <div class="included-visual glass-card">
          <div class="visual-header">Sample Outstation Fare</div>
          <div class="fare-route">Bangalore → Mysuru (150 km)</div>
          <div class="fare-breakdown">
            <div class="fare-row"><span>Base fare (Sedan, 150 km)</span><span>₹2,100</span></div>
            <div class="fare-row"><span>Driver allowance</span><span>₹200</span></div>
            <div class="fare-row"><span>Toll (approx.)</span><span>₹200</span></div>
            <div class="fare-divider"></div>
            <div class="fare-row fare-total"><span>Total (before GST)</span><span class="fare-total-price">₹2,500</span></div>
          </div>
          <p class="fare-note">Exact price confirmed at booking. No last-minute add-ons.</p>
          <a href="https://wa.me/919187232348?text=Hi%2C%20I%20need%20an%20outstation%20cab%20from%20Bangalore" target="_blank" rel="noopener" class="btn-gold" style="width:100%;text-align:center;margin-top:20px;">Get My Quote Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="section-padding faq-section" style="background:#f8fafc;">
    <div class="container">
      <div class="section-label dark-label">Outstation FAQs</div>
      <h2 class="section-title" style="color:#050d1a;">Your Questions, <span style="color:#047857;">Answered</span></h2>
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <div class="faq-item" id={`out-faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`out-faq-answer-${i}`}>
              <span>{faq.q}</span>
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="faq-answer" id={`out-faq-answer-${i}`} hidden>
              <p>{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="cta-banner">
    <div class="container cta-content">
      <h2 class="cta-title">Your Next Trip, Sorted in Under 5 Minutes</h2>
      <p class="cta-subtitle">Tell us your destination, date, and preferred vehicle — we'll send your confirmed fare instantly.</p>
      <div class="cta-actions">
        <a href="tel:+919187232348" class="btn-gold">📞 Call: 9187232348</a>
        <a href="https://wa.me/919187232348?text=Hi%2C%20I%20want%20to%20book%20an%20outstation%20cab%20from%20Bangalore" target="_blank" rel="noopener" class="btn-outline">💬 Plan My Trip</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.service-hero {
  position: relative;
  min-height: 560px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.outstation-hero {
  background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1400&q=80');
  background-size: cover;
  background-position: center;
}
.hero-overlay-dark {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(5,13,26,0.92) 0%, rgba(5,13,26,0.75) 100%);
}
.service-hero-content { position: relative; z-index: 2; padding: 120px 20px 80px; max-width: 720px; }
.service-badge-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3);
  color: #10b981; padding: 6px 16px; border-radius: 50px;
  font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 20px;
}
.service-hero-title { font-size: clamp(2rem, 5vw, 3.2rem); color: #fff; line-height: 1.15; margin-bottom: 18px; }
.service-hero-desc { font-size: 1.1rem; color: rgba(255,255,255,0.78); line-height: 1.7; margin-bottom: 30px; max-width: 580px; }
.service-hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 28px; }
.hero-pills { display: flex; gap: 10px; flex-wrap: wrap; }
.pill { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #a7f3d0; padding: 5px 14px; border-radius: 50px; font-size: 0.82rem; font-weight: 500; }

/* === DESTINATIONS === */
.dest-section { background: var(--bg-primary); }
.dest-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
.dest-card {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  cursor: pointer;
  text-decoration: none;
}
.dest-card:hover { transform: translateY(-4px); }
.dest-icon { font-size: 2.2rem; }
.dest-city { font-size: 1.1rem; font-weight: 700; color: #fff; }
.dest-meta { display: flex; gap: 12px; font-size: 0.82rem; color: rgba(255,255,255,0.55); }
.dest-price { display: flex; align-items: baseline; gap: 6px; }
.dest-from { font-size: 0.75rem; color: rgba(255,255,255,0.45); }
.dest-amount { font-size: 1.25rem; font-weight: 700; color: #10b981; font-family: var(--font-heading); }
.dest-cta { font-size: 0.82rem; font-weight: 600; color: #a7f3d0; margin-top: 4px; }

/* === FLEET === */
.fleet-section { background: var(--bg-secondary); }
.fleet-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; margin-top: 40px; }
.vehicle-card { overflow: hidden; display: flex; flex-direction: column; }
.vehicle-img-wrap { position: relative; height: 180px; overflow: hidden; }
.vehicle-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
.vehicle-card:hover .vehicle-img { transform: scale(1.05); }
.vehicle-badge { position: absolute; top: 10px; right: 10px; color: #fff; font-size: 0.7rem; font-weight: 700; padding: 3px 9px; border-radius: 50px; }
.vehicle-body { padding: 18px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
.vehicle-name { font-size: 1rem; font-weight: 700; color: #fff; }
.vehicle-tagline { font-size: 0.8rem; color: rgba(255,255,255,0.5); }
.vehicle-specs { display: flex; gap: 6px; flex-wrap: wrap; }
.spec-pill { font-size: 0.72rem; padding: 3px 8px; border-radius: 50px; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.2); color: #a7f3d0; }
.vehicle-price { display: flex; align-items: baseline; gap: 6px; }
.price-label { font-size: 0.75rem; color: rgba(255,255,255,0.45); }
.price-value { font-size: 1.15rem; font-weight: 700; color: #10b981; font-family: var(--font-heading); }
.vehicle-min { font-size: 0.75rem; color: rgba(255,255,255,0.4); }
.vehicle-book-btn { width: 100%; text-align: center; margin-top: auto; font-size: 0.85rem; padding: 10px 16px; }

/* === FEATURES === */
.features-section { background: var(--bg-primary); }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 40px; }
.feature-card { padding: 28px 22px; text-align: center; }
.feature-icon { font-size: 2.2rem; margin-bottom: 12px; }
.feature-title { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.feature-desc { font-size: 0.88rem; color: rgba(255,255,255,0.62); line-height: 1.6; }

/* === INCLUDED === */
.included-section { background: var(--bg-secondary); }
.included-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
.included-content { display: flex; flex-direction: column; gap: 8px; }
.included-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
.included-item { font-size: 0.95rem; color: rgba(255,255,255,0.78); display: flex; gap: 10px; align-items: flex-start; line-height: 1.5; }
.excluded { color: rgba(255,255,255,0.55); }
.excluded-header { font-size: 0.85rem; font-weight: 700; color: rgba(255,255,255,0.5); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 8px; margin-top: 4px; }
.included-visual { padding: 28px; }
.visual-header { font-size: 0.82rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #10b981; margin-bottom: 10px; }
.fare-route { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 20px; }
.fare-breakdown { display: flex; flex-direction: column; gap: 10px; }
.fare-row { display: flex; justify-content: space-between; font-size: 0.9rem; color: rgba(255,255,255,0.7); padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.fare-divider { height: 1px; background: rgba(16,185,129,0.3); margin: 4px 0; }
.fare-total { font-weight: 700; color: #fff; }
.fare-total-price { color: #10b981; font-size: 1.2rem; font-weight: 800; }
.fare-note { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-top: 14px; line-height: 1.5; }

/* === FAQ === */
.faq-section { background: #f8fafc; }
.dark-label { color: #047857 !important; }
.faq-list { display: flex; flex-direction: column; gap: 12px; margin-top: 40px; max-width: 800px; margin-left: auto; margin-right: auto; }
.faq-item { border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; background: #fff; }
.faq-question { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; font-size: 0.97rem; font-weight: 600; color: #050d1a; cursor: pointer; gap: 12px; text-align: left; background: transparent; border: none; }
.faq-question:hover { background: #f0fdf4; }
.faq-chevron { width: 18px; height: 18px; flex-shrink: 0; color: #10b981; transition: transform 0.3s; }
.faq-question[aria-expanded="true"] .faq-chevron { transform: rotate(180deg); }
.faq-answer { padding: 0 22px 18px; }
.faq-answer p { font-size: 0.92rem; color: #4b5563; line-height: 1.7; }

/* === CTA === */
.cta-banner { background: linear-gradient(135deg, #0b172a 0%, #051a2c 100%); border-top: 1px solid rgba(16,185,129,0.2); padding: 80px 20px; }
.cta-content { text-align: center; }
.cta-title { font-size: clamp(1.6rem, 4vw, 2.4rem); color: #fff; margin-bottom: 14px; }
.cta-subtitle { color: rgba(255,255,255,0.65); font-size: 1.05rem; margin-bottom: 32px; }
.cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

/* === SHARED === */
.section-label { font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #10b981; margin-bottom: 10px; }
.section-title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: #fff; margin-bottom: 12px; }
.section-desc { font-size: 1rem; color: rgba(255,255,255,0.6); max-width: 600px; }

/* === RESPONSIVE === */
@media (max-width: 1200px) { .dest-grid { grid-template-columns: repeat(2, 1fr); } .fleet-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 900px) { .included-layout { grid-template-columns: 1fr; } .features-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) {
  .dest-grid { grid-template-columns: repeat(2, 1fr); }
  .fleet-grid { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: 1fr; }
  .service-hero-cta { flex-direction: column; }
}
</style>

<script>
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    const answerId = btn.getAttribute('aria-controls');
    const answer = document.getElementById(answerId);
    btn.setAttribute('aria-expanded', String(!expanded));
    if (expanded) answer.setAttribute('hidden', '');
    else answer.removeAttribute('hidden');
  });
});
</script>
