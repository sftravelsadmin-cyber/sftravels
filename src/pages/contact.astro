  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const contactForm = document.getElementById('contactEnquiryForm');
      if (!contactForm) return;

      // Sync reply-to with email input
      const emailInput = document.getElementById('emailAddressInput');
      const replyToInput = document.getElementById('contactReplyToInput');
      if (emailInput && replyToInput) {
        emailInput.addEventListener('input', () => {
          replyToInput.value = emailInput.value;
        });
      }

      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();

        const botcheck = contactForm.querySelector('input[name="botcheck"]');
        if (botcheck && botcheck.checked) return;

        // Strict client-side phone number validation
        const phoneInput = contactForm.querySelector('input[name="phoneNumber"]');
        if (phoneInput) {
          let phoneVal = phoneInput.value.trim();
          // Strip all non-digit characters
          let digits = phoneVal.replace(/\D/g, '');
          // Remove country code prefix if present
          if (digits.startsWith('91') && digits.length > 10) digits = digits.substring(2);
          if (digits.startsWith('0') && digits.length > 10) digits = digits.substring(1);
          // Must be exactly 10 digits starting with 6-9
          if (digits.length !== 10 || !/^[6-9]/.test(digits)) {
            phoneInput.focus();
            alert("Please enter a valid 10-digit Indian mobile number starting with 6, 7, 8, or 9.");
            return;
          }
        }

        const submitBtn = document.getElementById('contactSubmitBtn');
        const formElements = contactForm.querySelectorAll('input, select, textarea, button');

        if (submitBtn) {
          submitBtn.setAttribute('disabled', 'true');
          submitBtn.querySelector('span').innerText = 'Sending...';
        }

        const formData = new FormData(contactForm);
        formElements.forEach(el => el.setAttribute('disabled', 'true'));

        fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData })
          .then(async (response) => {
            const json = await response.json();
            if (response.status === 200) {
              const formCard = contactForm.closest('.form-card');
              if (formCard) {
                formCard.innerHTML = `
                  <div class="text-center py-16 px-4">
                    <div class="w-20 h-20 bg-[#D97706]/10 rounded-full flex items-center justify-center mx-auto mb-6 border-2 border-[#D97706]/30">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" class="w-10 h-10">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </div>
                    <h3 class="text-2xl font-extrabold text-[#1a1f36] mb-4">Message Sent!</h3>
                    <p class="text-slate-600 mb-8 max-w-md mx-auto leading-relaxed">
                      Thank you for reaching out, <strong>${formData.get('fullName')}</strong>. Your enquiry has been routed directly to our mobility desk. A coordinator will contact you within 15 minutes.
                    </p>
                    <a href="https://wa.me/919353966815?text=Hi%20SF%20Travels%2C%20I%20just%20submitted%20an%20enquiry%20on%20your%20website." target="_blank" rel="noopener noreferrer"
                      class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#1E2D5A] hover:bg-[#151f3f] text-white font-bold py-3 px-8 transition-all shadow-md">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                      <span>Connect via WhatsApp · +91 9353966815</span>
                    </a>
                  </div>
                `;
              }
            } else {
              alert(json.message || 'Something went wrong. Please try again.');
              formElements.forEach(el => el.removeAttribute('disabled'));
              if (submitBtn) {
                submitBtn.removeAttribute('disabled');
                submitBtn.querySelector('span').innerText = 'Send Message';
              }
            }
          })
          .catch(error => {
            console.error('Submission error:', error);
            alert('Form submission failed. Please check your connection and try again.');
            formElements.forEach(el => el.removeAttribute('disabled'));
            if (submitBtn) {
              submitBtn.removeAttribute('disabled');
              submitBtn.querySelector('span').innerText = 'Send Message';
            }
          });
      });
    });
  </script>

</Layout>
