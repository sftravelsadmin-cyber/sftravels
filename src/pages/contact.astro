---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us | SF Travels Bangalore - Corporate & Luxury Mobility"
  description="Connect with the SF Travels team in Bangalore. Operational 24/7 for booking dispatch, corporate attachment programs, outstations, and premium travel coordination."
>

  <main class="bg-white min-h-screen overflow-x-hidden pt-12 text-slate-800">

    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://images.unsplash.com/photo-1549399542-7e3f8b79c341?q=80&w=1600&auto=format&fit=crop'); background-size: cover; background-position: center center; background-attachment: fixed;">
      </div>
      <!-- Ultra-premium dark overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#050914]/95 via-[#0A1128]/85 to-[#050914]/95 z-10 pointer-events-none"></div>
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <span class="font-bold text-sm uppercase tracking-[0.25em] block mb-4 drop-shadow" style="color: #ffffff !important;">Contact Us</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md" style="color: #ffffff !important;">
          Connect with the <br />
          <span style="color: #fbbf24 !important;" class="drop-shadow-md">SF Travels</span> Mobility Desk
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-semibold drop-shadow-md" style="color: #ffffff !important;">
          Our dispatch and corporate booking desks are operational 24/7 to manage your travel logistics, business attachments, or custom outstation itineraries.
        </p>
        <div class="inline-block bg-[#D97706]/20 border border-[#D97706]/40 text-[#fbbf24] font-bold text-xs md:text-sm uppercase tracking-widest px-6 py-2.5 rounded-full shadow-md backdrop-blur-sm">
          <span>"Smooth Ride On Time"</span>
        </div>
      </div>
    </section>

    <!-- ===== QUICK CONTACT CTA STRIP ===== -->
    <section class="bg-[#1E2D5A] py-0">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
          <!-- Phone -->
          <a href="tel:9353966815" class="flex items-center justify-center gap-4 py-6 px-6 hover:bg-white/5 transition-colors duration-300 group">
            <div class="w-10 h-10 rounded-full bg-[#D97706]/20 flex items-center justify-center shrink-0 group-hover:bg-[#D97706]/40 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#fbbf24]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Call Directly</p>
              <p class="text-white font-extrabold text-base">+91 9353966815</p>
            </div>
          </a>
          <!-- WhatsApp -->
          <a href="https://wa.me/919353966815?text=Hi%20SF%20Travels%2C%20I%20would%20like%20to%20inquire%20about%20a%20cab%20booking%20or%20service." target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-4 py-6 px-6 hover:bg-white/5 transition-colors duration-300 group">
            <div class="w-10 h-10 rounded-full bg-[#D97706]/20 flex items-center justify-center shrink-0 group-hover:bg-[#D97706]/40 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#fbbf24]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">WhatsApp Chat</p>
              <p class="text-white font-extrabold text-base">+91 9353966815</p>
            </div>
          </a>
          <!-- Email -->
          <a href="mailto:sftravelsadmin@gmail.com" class="flex items-center justify-center gap-4 py-6 px-6 hover:bg-white/5 transition-colors duration-300 group">
            <div class="w-10 h-10 rounded-full bg-[#D97706]/20 flex items-center justify-center shrink-0 group-hover:bg-[#D97706]/40 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#fbbf24]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"></path></svg>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Email Us</p>
              <p class="text-white font-extrabold text-base">sftravelsadmin@gmail.com</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== MAIN CONTACT SECTION (Info Cards + Form) ===== -->
    <section class="py-24 bg-white overflow-hidden">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-16 items-start">

          <!-- ---- LEFT: Contact Information Cards ---- -->
          <div>
            <div class="mb-10">
              <span class="text-[#D97706] font-bold text-sm uppercase tracking-[0.25em] block mb-3">Direct Reach</span>
              <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-5">Get in Touch Instantly</h2>
              <p class="text-slate-500 text-lg leading-relaxed">
                Have an urgent booking, a corporate dispatch requirement, or want to attach your premium commercial vehicle? Tap any channel below to reach our operations desk immediately.
              </p>
            </div>

            <div class="flex flex-col gap-5">

              <!-- Card 1: Phone & WhatsApp -->
              <div class="group bg-[#fafaf8] hover:bg-white border border-slate-100 hover:border-[#D97706]/30 hover:shadow-xl rounded-3xl p-7 flex gap-5 items-start transition-all duration-300 hover:-translate-y-0.5">
                <div class="w-14 h-14 rounded-2xl bg-[#D97706]/10 flex items-center justify-center shrink-0 group-hover:bg-[#D97706] transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#D97706] group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                </div>
                <div class="flex-grow">
                  <h3 class="font-extrabold text-[#1a1f36] text-lg mb-1">Corporate Hotlines</h3>
                  <p class="text-slate-500 text-sm mb-4">Immediate operations support &amp; dispatch — 24/7</p>
                  <div class="flex flex-wrap gap-3">
                    <a href="tel:9353966815" class="inline-flex items-center gap-2 bg-[#1E2D5A] hover:bg-[#151f3f] text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-all duration-300">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                      +91 9353966815
                    </a>
                    <a href="https://wa.me/919353966815?text=Hi%20SF%20Travels%2C%20I%20would%20like%20to%20inquire%20about%20a%20cab%20booking%20or%20service." target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-all duration-300">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                      WhatsApp
                    </a>
                  </div>
                </div>
              </div>

              <!-- Card 2: Email -->
              <div class="group bg-[#fafaf8] hover:bg-white border border-slate-100 hover:border-[#1E2D5A]/20 hover:shadow-xl rounded-3xl p-7 flex gap-5 items-start transition-all duration-300 hover:-translate-y-0.5">
                <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center shrink-0 group-hover:bg-[#1E2D5A] transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#1E2D5A] group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"></path></svg>
                </div>
                <div class="flex-grow">
                  <h3 class="font-extrabold text-[#1a1f36] text-lg mb-1">Official Correspondence</h3>
                  <p class="text-slate-500 text-sm mb-3">For billing, corporate contracts, and vacancy attachments</p>
                  <div class="flex flex-col gap-1.5">
                    <a href="mailto:sftravelsadmin@gmail.com" class="text-[#D97706] hover:text-[#b45309] font-semibold text-sm transition-colors">sftravelsadmin@gmail.com</a>
                  </div>
                </div>
              </div>

              <!-- Card 3: Address -->
              <div class="group bg-[#fafaf8] hover:bg-white border border-slate-100 hover:border-[#D97706]/30 hover:shadow-xl rounded-3xl p-7 flex gap-5 items-start transition-all duration-300 hover:-translate-y-0.5">
                <div class="w-14 h-14 rounded-2xl bg-[#D97706]/10 flex items-center justify-center shrink-0 group-hover:bg-[#D97706] transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#D97706] group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <div class="flex-grow">
                  <h3 class="font-extrabold text-[#1a1f36] text-lg mb-1">Registered Headquarters</h3>
                  <p class="text-slate-500 text-sm leading-relaxed mb-3">
                    Shirke Rd, KHB Colony, Shirke Layout, Kengeri Satellite Town, Bengaluru, Karnataka 560060, India
                  </p>
                  <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-[#D97706] bg-[#D97706]/10 border border-[#D97706]/20 px-3 py-1 rounded-full">Kengeri Satellite Town Desk</span>
                </div>
              </div>

              <!-- Card 4: Operating Hours -->
              <div class="group bg-[#fafaf8] hover:bg-white border border-slate-100 hover:border-[#1E2D5A]/20 hover:shadow-xl rounded-3xl p-7 flex gap-5 items-start transition-all duration-300 hover:-translate-y-0.5">
                <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center shrink-0 group-hover:bg-[#1E2D5A] transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#1E2D5A] group-hover:text-white transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div class="flex-grow">
                  <h3 class="font-extrabold text-[#1a1f36] text-lg mb-3">Operational Hours</h3>
                  <div class="space-y-3">
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Admin &amp; Onboarding Office</p>
                      <p class="text-slate-700 font-semibold text-sm">Open 24 Hours <span class="font-normal text-slate-500">(Mon – Sun)</span></p>
                    </div>
                    <div class="pt-2 border-t border-slate-100">
                      <p class="text-[10px] font-bold uppercase tracking-widest text-[#D97706] mb-1">Emergency Dispatch &amp; Booking</p>
                      <p class="text-[#1E2D5A] font-extrabold text-sm">OPEN 24 HOURS / 365 DAYS</p>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>

          <!-- ---- RIGHT: Enquiry Form ---- -->
          <div class="lg:sticky lg:top-28">
            <div class="form-card bg-white rounded-3xl shadow-xl border border-slate-200/50 p-8 md:p-10">
              <div class="mb-8 pb-6 border-b border-slate-100">
                <span class="text-[#D97706] font-bold text-sm uppercase tracking-[0.25em] block mb-3">Send a Message</span>
                <h2 class="text-2xl font-extrabold text-[#1a1f36] mb-2">Reach Our Operations Desk</h2>
                <p class="text-slate-500 text-sm leading-relaxed">
                  Fill out the enquiry form below. Our operations desk will get in touch within 15 minutes.
                </p>
              </div>

              <!-- Enquiry form (Web3Forms integrated) -->
              <form class="space-y-5" name="contact-enquiry" action="https://api.web3forms.com/submit" method="POST" id="contactEnquiryForm">
                <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || "e2691c76-e159-4d9e-803f-cdf2fa4bebbe"} />
                <input type="hidden" name="subject" value="New Website Enquiry - SF Travels" />
                <input type="hidden" name="from_name" value="SF Travels Website" />
                <input type="hidden" name="replyto" value="" id="contactReplyToInput" />
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

                <!-- Full Name -->
                <div class="flex flex-col gap-2">
                  <label class="font-semibold text-slate-700 text-sm">Your Full Name <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#D97706] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    <input type="text" name="fullName" placeholder="Your Name" required
                      class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-[#fafaf8] focus:outline-none focus:ring-2 focus:ring-[#1E2D5A]/20 focus:border-[#1E2D5A] transition-all text-sm" />
                  </div>
                </div>

                <!-- Phone Number -->
                <div class="flex flex-col gap-2">
                  <label class="font-semibold text-slate-700 text-sm">Phone Number <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#D97706] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                    <input type="tel" name="phoneNumber" placeholder="10-digit number" maxlength="13" inputmode="numeric" pattern="^[6-9]\d{9}$" title="Please enter a valid 10-digit Indian mobile number (e.g. 9876543210)" required
                      class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-[#fafaf8] focus:outline-none focus:ring-2 focus:ring-[#1E2D5A]/20 focus:border-[#1E2D5A] transition-all text-sm" />
                  </div>
                </div>

                <!-- Email Address -->
                <div class="flex flex-col gap-2">
                  <label class="font-semibold text-slate-700 text-sm">Email Address <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#D97706] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"></path></svg>
                    <input type="email" name="emailAddress" placeholder="you@domain.com" required id="emailAddressInput"
                      class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-[#fafaf8] focus:outline-none focus:ring-2 focus:ring-[#1E2D5A]/20 focus:border-[#1E2D5A] transition-all text-sm" />
                  </div>
                </div>

                <!-- Enquiry Type -->
                <div class="flex flex-col gap-2">
                  <label class="font-semibold text-slate-700 text-sm">Enquiry Type <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#D97706] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 002 12v4c0 .6.4 1 1 1h2"></path><circle cx="7" cy="17" r="2"></circle><path d="M9 17h6"></path><circle cx="17" cy="17" r="2"></circle></svg>
                    <select name="enquiryType" required
                      class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-[#fafaf8] focus:outline-none focus:ring-2 focus:ring-[#1E2D5A]/20 focus:border-[#1E2D5A] transition-all text-sm appearance-none cursor-pointer">
                      <option value="" disabled selected>Select an enquiry type</option>
                      <option value="General Cab Booking">General Cab Booking (Local/Airport)</option>
                      <option value="Corporate Travel Attachment">Corporate Travel Attachment (MNC Contracts)</option>
                      <option value="Outstation / Tours Package">Outstation / Holiday Tour Packages</option>
                      <option value="Careers / Vacancy Inquiry">Careers / Chauffeur Vacancies</option>
                    </select>
                    <svg xmlns="http://www.w3.org/2000/svg" class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#D97706] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"></path></svg>
                  </div>
                </div>

                <!-- Message -->
                <div class="flex flex-col gap-2">
                  <label class="font-semibold text-slate-700 text-sm">Your Message <span class="text-red-500">*</span></label>
                  <div class="relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-4 w-4 h-4 text-[#D97706] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path></svg>
                    <textarea name="message" rows="4" placeholder="Write details about your travel query here..." required
                      class="w-full pl-11 pr-4 py-3 rounded-xl border border-slate-200 bg-[#fafaf8] focus:outline-none focus:ring-2 focus:ring-[#1E2D5A]/20 focus:border-[#1E2D5A] transition-all text-sm resize-none"></textarea>
                  </div>
                </div>

                <!-- Submit -->
                <div class="pt-2">
                  <button type="submit" id="contactSubmitBtn" class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-[#1E2D5A] hover:bg-[#151f3f] text-white font-bold py-4 px-6 transition-all duration-300 shadow-md hover:shadow-xl hover:scale-[1.01]">
                    <span>Send Message</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                  </button>
                </div>

                <!-- Quick WhatsApp Alternative -->
                <div class="text-center pt-1">
                  <p class="text-slate-400 text-xs mb-3">— or reach us directly on WhatsApp —</p>
                  <a href="https://wa.me/919353966815?text=Hi%20SF%20Travels%2C%20I%20would%20like%20to%20inquire%20about%20a%20cab%20booking%20or%20service." target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold text-sm px-6 py-3 rounded-xl transition-all duration-300 shadow hover:shadow-lg hover:scale-[1.02]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                    Chat on WhatsApp · +91 9353966815
                  </a>
                </div>

              </form>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== WHY CONTACT US / TRUST BADGES ===== -->
    <section class="py-20 bg-[#fafaf8] border-t border-slate-100 relative overflow-hidden">
      <div class="absolute -top-32 -right-32 w-80 h-80 bg-[#1E2D5A]/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 w-80 h-80 bg-[#D97706]/5 rounded-full blur-3xl"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-12">
