          <div class="group rounded-3xl p-7 border border-slate-100 bg-white hover:shadow-xl hover:border-slate-200/60 text-center transition-all duration-300">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 mx-auto group-hover:bg-[#1E2D5A] transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#1E2D5A] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <h3 class="font-extrabold text-[#1a1f36] mb-2">24/7 Operations</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Dispatch and booking support round the clock, every single day of the year.</p>
          </div>

          <div class="group rounded-3xl p-7 border border-slate-100 bg-white hover:shadow-xl hover:border-slate-200/60 text-center transition-all duration-300">
