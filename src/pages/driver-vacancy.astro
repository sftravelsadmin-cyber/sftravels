                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#1E2D5A] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
