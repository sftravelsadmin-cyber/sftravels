---
import Layout from '../layouts/Layout.astro';

// SF Travels - Driver Careers (Driver Vacancy) Page
---

<Layout 
  title="Driver Vacancy | Join SF Travels Chauffeur Careers Bangalore"
  description="Apply to join the premier executive fleet at SF Travels in Bangalore. Secure rewarding corporate, airport, or outstation duties,flexible shifts, and timely monthly payouts."
>

  <!-- ==================== PAGE HERO HEADER ==================== -->
  <section class="careers-hero-section">
    <div class="hero-overlay"></div>
    <div class="container relative z-10 text-center">
      <span class="gold-subtitle">SF CAREERS</span>
      <h1 class="careers-hero-title">
        Drive Your Career Forward <br />with <span class="gold-text">SF Travels</span>
      </h1>
      <p class="careers-hero-subtitle max-w-3xl mx-auto">
        Join Bangalore's most trusted executive fleet. Secure highly rewarding duties, flexible shifts, clean vehicles, and timely monthly payouts.
      </p>
      <div class="tagline-badge">
        <span>"Drive with Honor. Ride with Pride."</span>
      </div>
    </div>
  </section>

  <!-- ==================== OPEN POSITIONS SECTION ==================== -->
  <section class="section-padding positions-section">
    <div class="container">
      <div class="text-center">
        <span class="gold-subtitle">CHAUFFEUR INTAKE</span>
        <h2 class="section-title text-dark">Open Chauffeur Positions</h2>
        <p class="section-desc text-muted max-w-3xl">
          We are actively looking for professional, polite, and skilled chauffeurs to support our rapidly expanding executive operations.
        </p>
      </div>

      <div class="positions-grid">
        <!-- Position 1 -->
        <div class="position-card group">
          <div class="pos-img-container">
            <img 
              src="https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/320cc7f1dffd78416e551eb18935d5d4.jpg" 
              alt="Corporate Chauffeur" 
              class="pos-card-img" 
            />
            <div class="pos-img-overlay"></div>
            <div class="pos-img-header">
              <span class="pos-badge">Full-Time</span>
              <h3 class="pos-title">Corporate Chauffeur</h3>
            </div>
          </div>
          <div class="pos-body">
            <p class="pos-desc">
              Drive our premium sedans and SUVs (Innova Crysta) for executive MNC commutes, VIP transport, and board-member logistics in Whitefield, ORR, and Electronic City.
            </p>
            <div class="pos-specs">
              <div class="spec-row">
                <span class="spec-lbl">Duties:</span>
                <span class="spec-val">5 to 6 dedicated short-range corporate duties daily.</span>
              </div>
              <div class="spec-row">
                <span class="spec-lbl">Shifts:</span>
                <span class="spec-val">Dedicated Day / Night Shift choices.</span>
              </div>
            </div>
            <div class="pos-actions-panel">
              <a href="tel:9845211281" class="btn-pos-call">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <span>Call</span>
              </a>
              <a 
                href="https://wa.me/919845211281?text=Hi%20SF%20Travels%2C%20I%20am%20interested%20in%20applying%20for%20the%20Corporate%20Chauffeur%20position." 
                target="_blank" 
                rel="noopener noreferrer" 
                class="btn-pos-wa"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                <span>WhatsApp</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Position 2 -->
        <div class="position-card group">
          <div class="pos-img-container">
            <img 
              src="https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/8f11dda95978e3ba5309f98d3ac66e90.jpg" 
              alt="Airport Transfer Specialist" 
              class="pos-card-img" 
            />
            <div class="pos-img-overlay"></div>
            <div class="pos-img-header">
              <span class="pos-badge">Flexible Hours</span>
              <h3 class="pos-title">Airport Specialist</h3>
            </div>
          </div>
          <div class="pos-body">
            <p class="pos-desc">
              Manage round-the-clock airport transfers to Kempegowda International Airport (BLR). Requires excellent navigation skills and absolute punctuality.
            </p>
            <div class="pos-specs">
              <div class="spec-row">
                <span class="spec-lbl">Duties:</span>
                <span class="spec-val">Fixed airport pickup/drop routes. Very high trip consistency.</span>
              </div>
              <div class="spec-row">
                <span class="spec-lbl">Shifts:</span>
                <span class="spec-val">Full-Time or Part-Time choices.</span>
              </div>
            </div>
            <div class="pos-actions-panel">
              <a href="tel:9845211281" class="btn-pos-call">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <span>Call</span>
              </a>
              <a 
                href="https://wa.me/919845211281?text=Hi%20SF%20Travels%2C%20I%20am%20interested%20in%20applying%20for%20the%20Airport%20Specialist%20position." 
                target="_blank" 
                rel="noopener noreferrer" 
                class="btn-pos-wa"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                <span>WhatsApp</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Position 3 -->
        <div class="position-card group">
          <div class="pos-img-container">
            <img 
              src="https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/914cfd226753ba6ca59ea1c7287ed3e1.jpg" 
              alt="Interstate Highway Specialist" 
              class="pos-card-img" 
            />
            <div class="pos-img-overlay"></div>
            <div class="pos-img-header">
              <span class="pos-badge">High Earning</span>
              <h3 class="pos-title">Highway Specialist</h3>
            </div>
          </div>
          <div class="pos-body">
            <p class="pos-desc">
              Lead our outstation packages and multi-day tourist itineraries (Mysore, Ooty, Coorg, Tirupati) using premium SUVs and Force Urbania luxury coaches.
            </p>
            <div class="pos-specs">
              <div class="spec-row">
                <span class="spec-lbl">Duties:</span>
                <span class="spec-val">High-mileage highway driving with certified passenger care.</span>
              </div>
              <div class="spec-row">
                <span class="spec-lbl">Accommodation:</span>
                <span class="spec-val">Meal & lodging allowances paid for outstation duties.</span>
              </div>
            </div>
            <div class="pos-actions-panel">
              <a href="tel:9845211281" class="btn-pos-call">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <span>Call</span>
              </a>
              <a 
                href="https://wa.me/919845211281?text=Hi%20SF%20Travels%2C%20I%20am%20interested%20in%20applying%20for%20the%20Interstate%20Highway%20Specialist%20position." 
                target="_blank" 
                rel="noopener noreferrer" 
                class="btn-pos-wa"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg>
                <span>WhatsApp</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== ELIGIBILITY & BENEFITS (SPLIT GRID) ==================== -->
  <section class="criteria-section section-padding">
    <div class="criteria-overlay"></div>
    <div class="container relative z-10">
      <div class="criteria-benefits-grid">
        
        <!-- Column 1: Eligibility requirements -->
        <div class="criteria-col glass-card">
          <h3 class="criteria-heading">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="heading-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            Professional Requirements
          </h3>
          <p class="criteria-intro">Candidates must fulfill these strict criteria to protect corporate passenger safety:</p>
          
          <ul class="criteria-list">
            <li>
              <strong>Valid Licensing:</strong> Valid Commercial Driving License (Yellow Board badge) with a clean track record (zero major traffic violations).
            </li>
            <li>
              <strong>Commercial Experience:</strong> Minimum of 2–3 years of commercial driving experience in Bangalore. Highway drivers require 5+ years.
            </li>
            <li>
              <strong>Communication Skills:</strong> Polite conversation. Ability to speak Kannada and conversational English or Hindi to assist corporate executives.
            </li>
            <li>
              <strong>Smart Mobility:</strong> Ability to operate basic smartphone maps and GPS tracking dispatch applications.
            </li>
          </ul>
        </div>

        <!-- Column 2: Benefits -->
        <div class="criteria-col glass-card">
          <h3 class="criteria-heading">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="heading-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
            Key Chauffeur Benefits
          </h3>
          <p class="criteria-intro">Why our professional drivers chose SF Travels as their long-term career partner:</p>
          
          <ul class="benefits-list">
            <li>
              <strong>Guaranteed Timely Payments:</strong> Prompt, direct-to-bank monthly payouts with absolute transparency and zero delays.
            </li>
            <li>
              <strong>Attractive Trip Incentives:</strong> Performance bonuses for punctuality, customer satisfaction logs, and accident-free quarters.
            </li>
            <li>
              <strong>Complete Maintenance Support:</strong> All fuel, commercial road tax, permit renewals, and mechanical fleet servicing are managed and paid entirely by SF Travels.
            </li>
            <li>
              <strong>Outstation Accommodation:</strong> Professional meal and clean lodging allowances provided for all outstation duties.
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ==================== CANDIDATE FORM SECTION ==================== -->
  <section class="section-padding onboarding-section">
    <div class="container form-max-width">
      <div class="text-center">
        <span class="gold-subtitle">FLEET ONBOARDING</span>
        <h2 class="section-title text-dark">Apply to Join the SF Fleet</h2>
        <p class="section-desc text-muted">
          Fill out the onboarding application form below. Our HR operations desk will call you within 24 hours to schedule a document check and driving trial.
        </p>
      </div>

      <div class="form-card glass-card">
        <!-- Interactive Web3Forms Onboarding Form -->
        <form class="careers-form" name="driver-application" action="https://api.web3forms.com/submit" method="POST" id="driverApplicationForm">
          <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || "YOUR_ACCESS_KEY_HERE"} />
          <input type="hidden" name="subject" value="New Driver Application - SF Travels" />
          <input type="hidden" name="from_name" value="SF Travels Website" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <div class="careers-form-grid">
            <!-- Driver Name -->
            <div class="form-group">
              <label>Driver's Full Name <span class="req">*</span></label>
              <div class="input-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="input-icon"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                <input type="text" name="driverName" placeholder="Your Full Name" required />
              </div>
            </div>

            <!-- Phone Number -->
            <div class="form-group">
              <label>Phone Number <span class="req">*</span></label>
              <div class="input-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="input-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <input type="tel" name="driverPhone" placeholder="10-digit phone number" required />
              </div>
            </div>

            <!-- Position interest -->
            <div class="form-group">
              <label>Position of Interest <span class="req">*</span></label>
              <div class="input-wrapper select-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="input-icon"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path><circle cx="7" cy="17" r="2"></circle><path d="M9 17h6"></path><circle cx="17" cy="17" r="2"></circle></svg>
                <select name="positionInterest" required>
                  <option value="" disabled selected>Select a position</option>
                  <option value="Corporate Chauffeur">Corporate Chauffeur (Sedans & SUVs)</option>
                  <option value="Airport Specialist">Airport Transfer Specialist</option>
                  <option value="Highway Tourist Chauffeur">Highway Tourist Chauffeur (Outstations & Vans)</option>
                </select>
              </div>
            </div>

            <!-- Years of experience -->
            <div class="form-group">
              <label>Years of Driving Experience <span class="req">*</span></label>
              <div class="input-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="input-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <input type="number" name="yearsExperience" min="0" max="45" placeholder="Years of Experience" required />
              </div>
            </div>

            <!-- Commercial License Number -->
            <div class="form-group span-full">
              <label>Commercial License Number <span class="req">*</span></label>
              <div class="input-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="input-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                <input type="text" name="licenseNumber" placeholder="E.g., KA-03-2023XXXX" required />
              </div>
            </div>

            <!-- Languages -->
            <div class="form-group span-full">
              <label>Languages Spoken <span class="req">*</span></label>
              <div class="checkbox-grid">
                <label class="checkbox-wrapper">
                  <input type="checkbox" name="languages" value="Kannada" />
                  <span>Kannada</span>
                </label>
                <label class="checkbox-wrapper">
                  <input type="checkbox" name="languages" value="English" />
                  <span>English</span>
                </label>
                <label class="checkbox-wrapper">
                  <input type="checkbox" name="languages" value="Hindi" />
                  <span>Hindi</span>
                </label>
                <label class="checkbox-wrapper">
                  <input type="checkbox" name="languages" value="Telugu" />
                  <span>Telugu</span>
                </label>
                <label class="checkbox-wrapper">
                  <input type="checkbox" name="languages" value="Tamil" />
                  <span>Tamil</span>
                </label>
              </div>
            </div>

            <!-- Action submits -->
            <div class="form-actions span-full">
              <button type="submit" class="btn-gold submit-btn">
                <span>Submit Chauffeur Application</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </button>
            </div>
            
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ACCORDION SECTION ==================== -->
  <section class="section-padding faq-section">
    <div class="container faq-container">
      <div class="text-center">
        <span class="gold-subtitle">HAVE QUESTIONS?</span>
        <h2 class="section-title text-dark">Frequently Asked Questions</h2>
        <p class="section-desc text-muted max-w-3xl">
          Got questions about driving with SF Travels? Find clear answers on licensing, payouts, shifts, and outstation allowances below.
        </p>
      </div>

      <div class="faq-accordion max-w-3xl mx-auto">
        <!-- FAQ 1 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>What are the basic eligibility requirements?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>You must possess a valid Indian Commercial Driving License (yellow board badge), have a minimum of 2–3 years of local driving experience in Bangalore, be familiar with smartphone maps/navigation, and have clean record sheets with no active major violations. Punctual habits and a courteous customer-facing attitude are highly valued.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>What is the expected salary range?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>We offer competitive, industry-leading payout structures. Full-time corporate chauffeurs earn base salaries ranging from ₹22,000 to ₹28,000 per month, supplemented by regular duty bonuses, night allowances, and performance incentives. Experienced outstation highway drivers have high earning potential based on distance slabs.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 3 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>Do you provide training for new drivers?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Yes, absolutely. Every chauffeur onboarding at SF Travels undergoes a comprehensive professional grooming and skill development program. This includes coaching in safety protocols, executive defensive driving, soft skills/corporate communication etiquettes, and navigating our specialized GPS dispatch apps.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 4 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>What are the typical working hours?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>We provide highly flexible shifts to support your lifestyle. You can choose dedicated Day Shifts (mostly corporate commutes), Night Shifts (ideal for airport runs and corporate shifts), or flexible hours for airport transfers. Shift timing preferences can be locked in during your onboarding interview.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 5 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>Is accommodation provided for outstation drivers?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Yes. For outstation highway duties and multi-day tourist itineraries, SF Travels provides generous daily outstation allowances that fully cover clean lodging and healthy meal expenses. Chauffeur comfort during outstation stays is a top priority for client and road safety.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 6 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>What documents are required for the application?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>You will need to present your valid Commercial Driving License, Aadhaar Card, PAN Card, current address proof, two passport-sized photographs, and a bank passbook or cancelled check for direct monthly salary transfers. A previous employer reference letter is beneficial if available.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 7 -->
        <div class="faq-item">
          <button class="faq-question-btn" aria-expanded="false">
            <span>Do I need to own a vehicle?</span>
            <span class="faq-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="icon-svg"><path d="m6 9 6 6 6-6"></path></svg>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>No, you do not. SF Travels owns and fully maintains an expansive premium fleet of luxury sedans, Innova Crystas, Force Urbanias, and luxury coaches. We manage all fuel expenses, permits, tax renewals, and routine mechanical servicing. You only need to bring your professional driving skills and service excellence!</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Accordion Toggle JavaScript -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const faqButtons = document.querySelectorAll('.faq-question-btn');
      
      faqButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const faqItem = btn.parentElement;
          const isActive = faqItem.classList.contains('active');
          
          // Close all open items first for a clean single-accordion look
          document.querySelectorAll('.faq-item').forEach(item => {
            item.classList.remove('active');
            item.querySelector('.faq-question-btn').setAttribute('aria-expanded', 'false');
            const answer = item.querySelector('.faq-answer');
            answer.style.maxHeight = '0px';
          });
          
          if (!isActive) {
            faqItem.classList.add('active');
            btn.setAttribute('aria-expanded', 'true');
            const answer = faqItem.querySelector('.faq-answer');
            const innerContentHeight = faqItem.querySelector('.faq-answer-content').offsetHeight;
            answer.style.maxHeight = innerContentHeight + 40 + 'px'; // add padding offset
          }
        });
      });

      // ==================== WEB3FORMS SUBMISSION LOGIC ====================
      const driverForm = document.getElementById('driverApplicationForm');
      if (driverForm) {
        driverForm.addEventListener('submit', (e) => {
          e.preventDefault();

          // Honeypot spam check
          const botcheck = driverForm.querySelector('input[name="botcheck"]') as HTMLInputElement;
          if (botcheck && botcheck.checked) {
            console.warn("Spam submission blocked.");
            return;
          }

          const submitBtn = driverForm.querySelector('button[type="submit"]');
          const formElements = driverForm.querySelectorAll('input, select, textarea, button');

          if (submitBtn) submitBtn.classList.add('btn-loading');
          formElements.forEach(el => el.setAttribute('disabled', 'true'));

          const formData = new FormData(driverForm);

          fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
          })
          .then(async (response) => {
            const json = await response.json();
            if (response.status === 200) {
              // Success: replace form content with a premium inline success card
              const formCard = driverForm.closest('.form-card');
              if (formCard) {
                formCard.innerHTML = `
                  <div class="form-success-inline">
                    <div class="success-icon-circle">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width: 36px; height: 36px;">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </div>
                    <h3 class="success-title">Application Submitted!</h3>
                    <p class="success-message">
                      Thank you for applying, <strong>${formData.get('driverName')}</strong>. Your onboarding profile has been received. Our HR team will call you at <strong>${formData.get('driverPhone')}</strong> within 24 hours to arrange document verification and a driving test.
                    </p>
                    <div class="success-actions">
                      <a href="https://wa.me/919187232348?text=Hi%20SF%20Travels%2C%20I%20just%20submitted%20my%20driver%20onboarding%20application%20on%20your%20website." target="_blank" rel="noopener noreferrer" class="btn-wa-success">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width: 18px; height: 18px;" stroke-linecap="round" stroke-linejoin="round">
                          <path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path>
                        </svg>
                        <span>Connect via WhatsApp</span>
                      </a>
                    </div>
                  </div>
                `;
              }
            } else {
              alert(json.message || "Something went wrong. Please check your form details and try again.");
              formElements.forEach(el => el.removeAttribute('disabled'));
            }
          })
          .catch(error => {
            console.error("Submission error:", error);
            alert("Form submission failed. Please check your internet connection and try again.");
            formElements.forEach(el => el.removeAttribute('disabled'));
          })
          .finally(() => {
            if (submitBtn) submitBtn.classList.remove('btn-loading');
          });
        });
      }
    });
  </script>

</Layout>

