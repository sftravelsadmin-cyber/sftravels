---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Driver Vacancy | Join SF Travels Chauffeur Careers Bangalore"
  description="Apply to join the premier executive fleet at SF Travels in Bangalore. Secure rewarding corporate, airport, or outstation duties, flexible shifts, and timely monthly payouts."
>

  <main class="bg-white min-h-screen overflow-x-hidden pt-12 text-slate-800">

    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden flex items-center justify-center min-h-[85vh]">
      <!-- Background: zoomed-in driver image -->
      <div class="absolute inset-0 z-0">
        <img
          src="/driver_hero_cockpit.png"
          alt="SF Travels Professional Chauffeur"
          class="w-full h-full object-cover object-center scale-105"
          style="filter: brightness(0.45);"
        />
      </div>
      <!-- Ultra-premium gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#050914]/80 via-[#0A1128]/60 to-[#050914]/90 z-10 pointer-events-none"></div>

      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <span class="inline-block font-bold text-sm uppercase tracking-[0.25em] mb-5 px-5 py-1.5 rounded-full border border-[#D97706]/50 bg-[#D97706]/15 backdrop-blur-sm drop-shadow" style="color: #fbbf24 !important;">
          Careers at SF Travels
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md" style="color: #ffffff !important;">
          Drive Your Career <br />
          <span style="color: #fbbf24 !important;" class="drop-shadow-md">Forward With Us</span>
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-semibold drop-shadow-md" style="color: #ffffff !important;">
          Join Bangalore's most trusted executive fleet. Competitive pay, flexible shifts, professional training, and a company that values its chauffeurs above all.
        </p>
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#open-positions" class="inline-flex items-center justify-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold px-8 py-4 rounded-xl shadow-lg transition-all duration-300 hover:scale-[1.03]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            View Open Positions
          </a>
          <a href="#apply-now" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/30 text-white font-bold px-8 py-4 rounded-xl backdrop-blur-sm transition-all duration-300 hover:scale-[1.03]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 13l-3 3m0 0l-3-3m3 3V8m0 13a9 9 0 110-18 9 9 0 010 18z"></path></svg>
            Apply Now
          </a>
        </div>
      </div>
      <!-- Stats bar at bottom -->
      <div class="absolute bottom-0 left-0 right-0 z-20">
        <div class="container mx-auto px-4 sm:px-6">
          <div class="bg-white/10 backdrop-blur-md border-t border-white/20 grid grid-cols-3 divide-x divide-white/20">
            <div class="py-5 text-center">
              <p class="text-2xl font-extrabold" style="color: #fbbf24 !important;">₹22K+</p>
              <p class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: #e2e8f0 !important;">Monthly Base Pay</p>
            </div>
            <div class="py-5 text-center">
              <p class="text-2xl font-extrabold" style="color: #fbbf24 !important;">3 Roles</p>
              <p class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: #e2e8f0 !important;">Open Positions</p>
            </div>
            <div class="py-5 text-center">
              <p class="text-2xl font-extrabold" style="color: #fbbf24 !important;">24hr</p>
              <p class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: #e2e8f0 !important;">Response Guarantee</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== OPEN POSITIONS ===== -->
    <section id="open-positions" class="py-24 bg-white overflow-hidden">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#D97706] font-bold text-sm uppercase tracking-[0.25em] block mb-3">Join the Fleet</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-5">Open Positions</h2>
          <p class="text-slate-500 max-w-2xl mx-auto text-lg leading-relaxed">Find the perfect driving role that suits your experience and lifestyle.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

          <!-- Position 1: Taxi/Cab Driver -->
          <div class="group rounded-3xl border border-slate-100 bg-[#fafaf8] hover:bg-white hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col h-full">
            <div class="h-52 relative overflow-hidden shrink-0">
              <img src="https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/320cc7f1dffd78416e551eb18935d5d4.jpg" alt="Taxi/Cab Driver" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
              <div class="absolute inset-0 bg-gradient-to-t from-[#1E2D5A]/90 via-[#1E2D5A]/30 to-transparent"></div>
              <div class="absolute bottom-4 left-4 right-4 text-white">
                <span class="bg-[#D97706] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-2 inline-block">Full-time / Part-time</span>
                <h3 class="text-xl font-extrabold" style="color: #ffffff !important;">Taxi / Cab Driver</h3>
              </div>
            </div>
            <div class="p-7 flex-grow flex flex-col gap-5">
              <p class="text-slate-600 leading-relaxed text-sm">Join our core fleet to provide reliable daily transportation for local residents and corporate clients. We need punctual professionals who know city routes well.</p>
              <div class="space-y-4 flex-grow">
                <div>
                  <h4 class="font-bold text-[#1E2D5A] mb-3 pb-2 border-b border-slate-100 text-sm uppercase tracking-widest">Requirements</h4>
                  <ul class="space-y-2">
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Valid Commercial Driving License</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Minimum 2 years local driving experience</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Good communication in local languages</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#D97706] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Clean driving record</span>
                    </li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-bold text-[#1E2D5A] mb-3 pb-2 border-b border-slate-100 text-sm uppercase tracking-widest">Key Benefits</h4>
                  <ul class="space-y-2">
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#1E2D5A] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Flexible shift timings</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#1E2D5A] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Performance incentives</span>
                    </li>
                    <li class="flex items-start gap-2 text-sm text-slate-600">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#1E2D5A] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                      <span>Regular vehicle maintenance provided</span>
                    </li>
                  </ul>
                </div>
              </div>
              <div class="mt-auto pt-5 border-t border-slate-100">
                <div class="flex gap-3">
                  <a href="tel:9353966815" class="flex-1 inline-flex items-center justify-center gap-2 bg-[#1E2D5A] hover:bg-[#151f3f] text-white font-bold py-3 px-4 rounded-xl text-sm transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg>
                    Call
                  </a>
                  <a href="https://wa.me/919353966815?text=Hi%20SF%20Travels%2C%20I%20am%20interested%20in%20applying%20for%20the%20Taxi%2FCab%20Driver%20position." target="_blank" rel="noopener noreferrer" class="flex-1 inline-flex items-center justify-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold py-3 px-4 rounded-xl text-sm transition-all duration-300">
