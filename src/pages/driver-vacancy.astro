  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const faqButtons = document.querySelectorAll('.faq-question-btn');
      
      faqButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const faqItem = btn.parentElement;
          const isActive = faqItem.classList.contains('active');
          const answer = faqItem.querySelector('.faq-answer');
          const icon = btn.querySelector('svg');
          
          // Close all open items first for a clean single-accordion look
          document.querySelectorAll('.faq-item').forEach(item => {
            item.classList.remove('active');
            item.querySelector('.faq-question-btn').setAttribute('aria-expanded', 'false');
            const ans = item.querySelector('.faq-answer');
            ans.style.maxHeight = '0px';
            const sv = item.querySelector('.faq-question-btn svg');
            if (sv) sv.style.transform = 'rotate(0deg)';
          });
          
          if (!isActive) {
            faqItem.classList.add('active');
            btn.setAttribute('aria-expanded', 'true');
            const innerContentHeight = faqItem.querySelector('.faq-answer-content').offsetHeight;
            answer.style.maxHeight = innerContentHeight + 40 + 'px'; // add padding offset
            if (icon) icon.style.transform = 'rotate(180deg)';
          }
        });
      });

      // ==================== WEB3FORMS SUBMISSION LOGIC ====================
      const driverForm = document.getElementById('driverApplicationForm');
      if (driverForm) {
        driverForm.addEventListener('submit', (e) => {
          e.preventDefault();

          // Honeypot spam check
          const botcheck = driverForm.querySelector('input[name="botcheck"]');
          if (botcheck && botcheck.checked) {
            console.warn("Spam submission blocked.");
            return;
          }

          const submitBtn = driverForm.querySelector('button[type="submit"]');
          const formElements = driverForm.querySelectorAll('input, select, checkbox, button');

          if (submitBtn) {
            submitBtn.setAttribute('disabled', 'true');
            submitBtn.innerText = "Submitting...";
          }

          const formData = new FormData(driverForm);
          formElements.forEach(el => el.setAttribute('disabled', 'true'));

          fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
          })
          .then(async (response) => {
            const json = await response.json();
            if (response.status === 200) {
              const formCard = driverForm.closest('.form-card');
              if (formCard) {
                formCard.innerHTML = `
                  <div class="text-center py-10 px-4">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6 text-green-500">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-8 h-8">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Application Submitted!</h3>
                    <p class="text-gray-600 mb-8 max-w-md mx-auto">
                      Thank you for applying, <strong>${formData.get('driverName')}</strong>. Your onboarding profile has been received. Our HR team will call you at <strong>${formData.get('driverPhone')}</strong> within 24 hours to arrange document verification and a driving test.
                    </p>
                    <div>
                      <a href="https://wa.me/919353966815?text=Hi%20SF%20Travels%2C%20I%20just%20submitted%20my%20driver%20onboarding%20application%20on%20your%20website." target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-lg bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 transition-all shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5 mr-2">
                          <path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path>
                        </svg>
                        <span>Connect via WhatsApp</span>
                      </a>
                    </div>
                  </div>
                `;
              }
            } else {
              alert(json.message || "Something went wrong. Please check your form details and try again.");
              formElements.forEach(el => el.removeAttribute('disabled'));
              if (submitBtn) {
                submitBtn.removeAttribute('disabled');
                submitBtn.innerHTML = `
                  <span>Submit Chauffeur Application</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                `;
              }
            }
          })
          .catch(error => {
            console.error("Submission error:", error);
            alert("Form submission failed. Please check your internet connection and try again.");
            formElements.forEach(el => el.removeAttribute('disabled'));
            if (submitBtn) {
              submitBtn.removeAttribute('disabled');
              submitBtn.innerHTML = `
                <span>Submit Chauffeur Application</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              `;
            }
          });
        });
      }
    });
  </script>
</Layout>
