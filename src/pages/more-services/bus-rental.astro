---
import Layout from '../../layouts/Layout.astro';
import { fleet } from '../../data/fleet.js';

const busVehicles = fleet.filter(v => ['tempo-traveller','force-urbania','luxury-bus'].includes(v.id));

const useCases = [
  { icon: '🎉', title: 'Corporate Events', desc: 'Offsite team outings, annual parties, and employee retreats with coordinated fleet.' },
  { icon: '🛕', title: 'Pilgrimage Tours', desc: 'Tirupati, Shirdi, Srisailam — devotional group travel handled with care.' },
  { icon: '🎓', title: 'School & College Trips', desc: 'Safe, insured, and driver-verified coaches for academic and excursion trips.' },
  { icon: '💍', title: 'Wedding Processions', desc: 'Baraat buses, guest shuttles, and wedding convoy coaches with decorated options.' },
  { icon: '🏭', title: 'Factory Staff Shuttles', desc: 'Daily route-based staff transport for manufacturing units and industrial parks.' },
  { icon: '🌐', title: 'Conference Transport', desc: 'Hotel-to-venue shuttle services for business conferences and trade fairs.' },
];

const faqs = [
  { q: 'How far in advance must I book a bus?', a: 'For 12–17 seater Tempo/Force Urbania, 24 hours notice is ideal. For 35-seater coaches, a minimum of 3–5 days advance booking is recommended.' },
  { q: 'Are the buses decorated for weddings?', a: 'Basic floral decoration for the baraat bus can be arranged for an additional charge. Please mention this at the time of booking.' },
  { q: 'Do you provide buses for outstation group travel?', a: 'Yes. All bus and tempo traveller bookings can cover outstation routes. Pricing is customized based on distance, duration, and number of passengers.' },
  { q: 'Is there a minimum booking period for the luxury coach?', a: 'The 35-seater coach has a minimum booking of 200 km or 1 full day, whichever is higher. Contact us for custom duration pricing.' },
  { q: 'Do the buses have luggage storage?', a: 'Tempo Travellers have roof carriers. Force Urbania has rear cargo bays. Luxury coaches have large under-carriage storage compartments.' },
];
---

<Layout
  title="Bus Rental Services Bangalore | SF Travels — Group Travel Coaches"
  description="Rent Tempo Travellers, Force Urbania, and 35-seater luxury coaches in Bangalore with SF Travels. Ideal for corporate events, pilgrimages, weddings, and school tours."
>

  <!-- ==================== HERO ==================== -->
  <section class="service-hero bus-hero">
    <div class="hero-overlay-dark"></div>
    <div class="container service-hero-content">
      <div class="service-badge-pill">🚌 Bus & Coach Rentals</div>
      <h1 class="service-hero-title">
        Group Travel, Zero Headaches —<br />
        <span class="gold-text">We Move Everyone Together.</span>
      </h1>
      <p class="service-hero-desc">
        From 12-seater Tempo Travellers to luxury 35-seater coaches, SF Travels offers full fleet solutions for corporate events, pilgrimages, weddings, and more.
      </p>
      <div class="service-hero-cta">
        <a href="/contact" class="btn-gold">📞 Get Group Quote</a>
        <a href="https://wa.me/918073110973?text=Hi%2C%20I%20need%20a%20bus%20or%20coach%20rental%20in%20Bangalore." target="_blank" rel="noopener" class="btn-outline">💬 WhatsApp Fleet Enquiry</a>
      </div>
      <div class="hero-pills">
        <span class="pill">✓ 12–35 seater options</span>
        <span class="pill">✓ GPS tracked</span>
        <span class="pill">✓ Verified drivers</span>
        <span class="pill">✓ Full-day & outstation</span>
      </div>
    </div>
  </section>

  <!-- ==================== BUS FLEET ==================== -->
  <section class="section-padding fleet-section">
    <div class="container">
      <div class="section-label">Our Bus Fleet</div>
      <h2 class="section-title">Choose Your <span class="gold-text">Group Vehicle</span></h2>
      <p class="section-desc">All coaches are air-conditioned, GPS-tracked, and driven by verified professional drivers.</p>
      <div class="bus-fleet-grid">
        {busVehicles.map(v => (
          <div class="bus-card glass-card">
            <div class="bus-img-wrap">
              <img src={v.image} alt={v.name} class="bus-img" loading="lazy" />
              <span class="bus-badge" style={`background:${v.badgeColor}`}>{v.badge}</span>
            </div>
            <div class="bus-body">
              <h3 class="bus-name">{v.name}</h3>
              <p class="bus-tagline">{v.tagline}</p>
              <div class="bus-specs">
                <span class="spec-pill">👥 {v.seats} Seats</span>
                <span class="spec-pill">❄️ {v.acType}</span>
                <span class="spec-pill">🧳 {v.luggage}</span>
              </div>
              <div class="bus-features">
                {v.features.map(f => (
                  <span class="feature-tag">✓ {f}</span>
                ))}
              </div>
              <div class="bus-price">
                <span class="price-label">Rate</span>
                <span class="price-value">{v.pricePerKm}</span>
                <span class="min-label">Min {v.minimumKm}</span>
              </div>
              <div class="bus-best-for">
                <span class="best-for-label">Best For:</span>
                <div class="best-for-tags">
                  {v.bestFor.map(b => <span class="best-tag">{b}</span>)}
                </div>
              </div>
              <a href={`https://wa.me/918073110973?text=Hi%2C%20I%20need%20to%20rent%20a%20${encodeURIComponent(v.name)}%20in%20Bangalore`} target="_blank" rel="noopener" class="btn-gold bus-book-btn">Enquire & Book</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== USE CASES ==================== -->
  <section class="section-padding usecases-section bg-navy-gradient">
    <div class="container">
      <div class="section-label">We Serve All Group Needs</div>
      <h2 class="section-title">What Are You <span class="gold-text">Planning?</span></h2>
      <div class="usecases-grid">
        {useCases.map(uc => (
          <div class="usecase-card glass-card">
            <div class="uc-icon">{uc.icon}</div>
            <h3 class="uc-title">{uc.title}</h3>
            <p class="uc-desc">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PROCESS ==================== -->
  <section class="section-padding process-section">
    <div class="container">
      <div class="section-label">Simple Booking Process</div>
      <h2 class="section-title">How to <span class="gold-text">Book Your Coach</span></h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-circle">1</div>
          <div class="step-content">
            <h3>Share Requirements</h3>
            <p>Tell us group size, date, route, and event type via WhatsApp or phone.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-circle">2</div>
          <div class="step-content">
            <h3>Get Custom Quote</h3>
            <p>We confirm vehicle availability and send a fixed, all-inclusive fare quote.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-circle">3</div>
          <div class="step-content">
            <h3>Confirm Booking</h3>
            <p>Pay a small advance. Receive driver details and trip plan on WhatsApp.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-circle">4</div>
          <div class="step-content">
            <h3>Enjoy the Journey</h3>
            <p>Coach arrives on time, professionally driven. Balance payable at trip end.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="section-padding faq-section" style="background:#f8fafc;">
    <div class="container">
      <div class="section-label dark-label">Bus Rental FAQs</div>
      <h2 class="section-title" style="color:#050d1a;">Common <span style="color:#047857;">Questions</span></h2>
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <div class="faq-item" id={`bus-faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`bus-faq-answer-${i}`}>
              <span>{faq.q}</span>
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="faq-answer" id={`bus-faq-answer-${i}`} hidden>
              <p>{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="cta-banner">
    <div class="container cta-content">
      <h2 class="cta-title">Planning a Group Trip?</h2>
      <p class="cta-subtitle">Tell us your group size and destination. We'll match you with the perfect coach and send a quote in minutes.</p>
      <div class="cta-actions">
        <a href="tel:+919187232348" class="btn-gold">📞 Call: 9187232348</a>
        <a href="https://wa.me/918073110973?text=Hi%2C%20I%20need%20a%20bus%20rental%20for%20a%20group%20event" target="_blank" rel="noopener" class="btn-outline">💬 WhatsApp Group Plan</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.service-hero { position: relative; min-height: 560px; display: flex; align-items: center; overflow: hidden; }
.bus-hero {
  background-image: url('https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?w=1400&q=80');
  background-size: cover;
  background-position: center;
}
.hero-overlay-dark { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(5,13,26,0.93) 0%, rgba(5,13,26,0.78) 100%); }
.service-hero-content { position: relative; z-index: 2; padding: 120px 20px 80px; max-width: 720px; }
.service-badge-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: #10b981; padding: 6px 16px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 20px; }
.service-hero-title { font-size: clamp(2rem, 5vw, 3.2rem); color: #fff; line-height: 1.15; margin-bottom: 18px; }
.service-hero-desc { font-size: 1.1rem; color: rgba(255,255,255,0.78); line-height: 1.7; margin-bottom: 30px; max-width: 580px; }
.service-hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 28px; }
.hero-pills { display: flex; gap: 10px; flex-wrap: wrap; }
.pill { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #a7f3d0; padding: 5px 14px; border-radius: 50px; font-size: 0.82rem; font-weight: 500; }

/* === FLEET === */
.fleet-section { background: var(--bg-primary); }
.bus-fleet-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 44px; }
.bus-card { overflow: hidden; display: flex; flex-direction: column; }
.bus-img-wrap { position: relative; height: 220px; overflow: hidden; }
.bus-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
.bus-card:hover .bus-img { transform: scale(1.05); }
.bus-badge { position: absolute; top: 12px; right: 12px; color: #fff; font-size: 0.75rem; font-weight: 700; padding: 4px 10px; border-radius: 50px; }
.bus-body { padding: 24px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
.bus-name { font-size: 1.15rem; font-weight: 700; color: #fff; }
.bus-tagline { font-size: 0.85rem; color: rgba(255,255,255,0.55); }
.bus-specs { display: flex; gap: 8px; flex-wrap: wrap; }
.spec-pill { font-size: 0.78rem; padding: 4px 10px; border-radius: 50px; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.2); color: #a7f3d0; }
.bus-features { display: flex; flex-wrap: wrap; gap: 6px; }
.feature-tag { font-size: 0.78rem; color: rgba(255,255,255,0.65); }
.bus-price { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
.price-label { font-size: 0.78rem; color: rgba(255,255,255,0.45); }
.price-value { font-size: 1.25rem; font-weight: 700; color: #10b981; font-family: var(--font-heading); }
.min-label { font-size: 0.75rem; color: rgba(255,255,255,0.35); }
.bus-best-for { display: flex; flex-direction: column; gap: 8px; }
.best-for-label { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.5px; }
.best-for-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.best-tag { font-size: 0.75rem; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.15); color: #a7f3d0; padding: 3px 9px; border-radius: 50px; }
.bus-book-btn { width: 100%; text-align: center; margin-top: auto; }

/* === USE CASES === */
.usecases-section { background: var(--bg-secondary); }
.usecases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 40px; }
.usecase-card { padding: 28px 22px; text-align: center; }
.uc-icon { font-size: 2.2rem; margin-bottom: 12px; }
.uc-title { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.uc-desc { font-size: 0.88rem; color: rgba(255,255,255,0.62); line-height: 1.6; }

/* === PROCESS === */
.process-section { background: var(--bg-primary); }
.process-steps {
  display: flex;
  align-items: flex-start;
  gap: 0;
  margin-top: 48px;
  flex-wrap: nowrap;
  overflow-x: auto;
  padding-bottom: 10px;
}
.process-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  min-width: 200px;
  flex: 1;
  text-align: center;
  padding: 0 12px;
}
.step-circle {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, #10b981 0%, #047857 100%);
  color: #fff;
  font-size: 1.3rem;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(16,185,129,0.3);
}
.step-content h3 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
.step-content p { font-size: 0.85rem; color: rgba(255,255,255,0.6); line-height: 1.5; }
.process-connector {
  height: 2px;
  background: linear-gradient(to right, #10b981, rgba(16,185,129,0.2));
  flex: 0.3;
  margin-top: 26px;
  min-width: 30px;
}

/* === FAQ === */
.faq-section { background: #f8fafc; }
.dark-label { color: #047857 !important; }
.faq-list { display: flex; flex-direction: column; gap: 12px; margin-top: 40px; max-width: 800px; margin-left: auto; margin-right: auto; }
.faq-item { border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; background: #fff; }
.faq-question { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; font-size: 0.97rem; font-weight: 600; color: #050d1a; cursor: pointer; gap: 12px; text-align: left; background: transparent; border: none; }
.faq-question:hover { background: #f0fdf4; }
.faq-chevron { width: 18px; height: 18px; flex-shrink: 0; color: #10b981; transition: transform 0.3s; }
.faq-question[aria-expanded="true"] .faq-chevron { transform: rotate(180deg); }
.faq-answer { padding: 0 22px 18px; }
.faq-answer p { font-size: 0.92rem; color: #4b5563; line-height: 1.7; }

/* === CTA === */
.cta-banner { background: linear-gradient(135deg, #0b172a 0%, #051a2c 100%); border-top: 1px solid rgba(16,185,129,0.2); padding: 80px 20px; }
.cta-content { text-align: center; }
.cta-title { font-size: clamp(1.6rem, 4vw, 2.4rem); color: #fff; margin-bottom: 14px; }
.cta-subtitle { color: rgba(255,255,255,0.65); font-size: 1.05rem; margin-bottom: 32px; }
.cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

/* === SHARED === */
.section-label { font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #10b981; margin-bottom: 10px; }
.section-title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: #fff; margin-bottom: 12px; }
.section-desc { font-size: 1rem; color: rgba(255,255,255,0.6); max-width: 580px; }

/* === RESPONSIVE === */
@media (max-width: 1024px) { .bus-fleet-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 900px) { .usecases-grid { grid-template-columns: repeat(2, 1fr); } .process-steps { flex-direction: column; align-items: center; } .process-connector { width: 2px; height: 30px; background: linear-gradient(to bottom, #10b981, rgba(16,185,129,0.2)); margin-top: 0; min-width: unset; } }
@media (max-width: 640px) { .bus-fleet-grid { grid-template-columns: 1fr; } .usecases-grid { grid-template-columns: 1fr; } .service-hero-cta { flex-direction: column; } }
</style>

<script>
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    const answerId = btn.getAttribute('aria-controls');
    const answer = document.getElementById(answerId);
    btn.setAttribute('aria-expanded', String(!expanded));
    if (expanded) answer.setAttribute('hidden', '');
    else answer.removeAttribute('hidden');
  });
});
</script>
