---
import Layout from '../../layouts/Layout.astro';

const placeholderImage = "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/hatchback-1770872540052-15.png";

const busFleet = [
  { id: "mini-bus-21", name: "Mini Bus 21", seats: "21", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-21-1770871153503-36.png" },
  { id: "mini-bus-25", name: "Mini Bus 25", seats: "25", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-25-1770871172403-39.png" },
  { id: "mini-bus-30", name: "Mini Bus 30", seats: "30", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/mini-bus-30-1770871190798-42.png" },
  { id: "bus-33", name: "Bus 33", seats: "33", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-33-1770871212474-45.png" },
  { id: "bus-40", name: "Bus 40", seats: "40", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-40-1770871824256-47.png" },
  { id: "volvo-bus-45", name: "Volvo Bus 45", seats: "45", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/volvo-bus-45-1770872238415-49.png" },
  { id: "bus-50-seater", name: "Bus 50 Seater", seats: "50", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/bus-50-1770872267131-52.png" }
];
---

<Layout 
  title="Bus Rental Service Bangalore - SF Travels"
  description="Premium bus rental for groups. Mini buses, Volvo coaches, and luxury buses for all corporate events, weddings, tours in Bangalore."
>
  

  <main class="bg-gray-50 min-h-screen overflow-x-hidden pt-12 text-slate-800">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center pt-20 overflow-hidden">
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/bda0fdb8b258bf205c0653b2583c1ec0.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat;">
      </div>
      <div class="absolute inset-0 bg-black/65 bg-gradient-to-b from-black/80 via-black/50 to-black/70 z-10 pointer-events-none"></div>
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight drop-shadow-lg">Bus Rental Service</h1>
        <p class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed drop-shadow-md">
          Premium bus rental for groups. Mini buses, Volvo coaches, and luxury buses for all occasions.
        </p>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Group Transportation Solutions</h2>
          <p class="text-gray-600 mb-4">Our bus rental service in Bangalore provides comfortable and reliable transportation for large groups. Whether you're organizing a corporate event, wedding, educational tour, or pilgrimage, we have the perfect bus for your needs.</p>
          <p class="text-gray-600 mb-4">Choose from our fleet of mini buses (21-30 seater), standard buses (33-40 seater), Volvo luxury coaches (45 seater), and large buses (50 seater). All vehicles are well-maintained, air-conditioned, and come with experienced drivers who prioritize safety and comfort.</p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <path d="M8 6v6"></path>
                <path d="M15 6v6"></path>
                <path d="M2 12h19.6"></path>
                <path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"></path>
                <circle cx="7" cy="18" r="2"></circle>
                <path d="M9 18h5"></path>
                <circle cx="16" cy="18" r="2"></circle>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Wide Fleet</h3>
              <p class="text-sm text-gray-600">21 to 50 seaters</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Large Groups</h3>
              <p class="text-sm text-gray-600">Perfect for teams</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Safe Travel</h3>
              <p class="text-sm text-gray-600">Experienced drivers</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Flexible Plans</h3>
              <p class="text-sm text-gray-600">Daily & monthly rentals</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Fleet Cards Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Our Bus Fleet</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {busFleet.map(c => (
            <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col h-full w-full">
              <div class="relative aspect-[16/10] overflow-hidden bg-gray-50">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover" />
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm">
                  {c.category.toUpperCase()}
                </div>
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-grow">
                <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-2">{c.name}</h3>
                <div class="flex items-center text-gray-500 mb-3 text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5 text-[#1E2D5A]">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                  </svg>
                  <span>{c.seats} Seater</span>
                </div>
                <div class="space-y-1 mb-4 flex-grow text-sm">
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#1E2D5A] mr-1.5 font-bold">✓</span>
                    <span>Professional Driver</span>
                  </div>
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#1E2D5A] mr-1.5 font-bold">✓</span>
                    <span>AC & Music System</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <div class="grid grid-cols-2 gap-2 sm:gap-3">
                    <button 
                      class="inline-flex items-center justify-center rounded-md px-4 bg-[#1E2D5A] hover:bg-[#151f3f] text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                      data-book-now 
                      data-vehicle={c.name} 
                      data-category="Bus Fleet"
                    >
                      Book Now
                    </button>
                    <a 
                      href={`/vehicle/${c.id}`} 
                      class="inline-flex items-center justify-center rounded-md border border-[#1E2D5A] text-[#1E2D5A] hover:bg-[#1E2D5A] hover:text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                    >
                      Details
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Perfect For Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Perfect For</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Corporate Events</h3>
            <p class="text-gray-600">Employee transportation for conferences, team outings, and company events.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Wedding Transportation</h3>
            <p class="text-gray-600">Comfortable travel for wedding guests between venues and hotels.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Educational Tours</h3>
            <p class="text-gray-600">Safe and supervised transportation for school and college trips.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Pilgrimages</h3>
            <p class="text-gray-600">Religious tours to temples and holy places across India.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
