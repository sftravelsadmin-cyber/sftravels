---
import Layout from '../../layouts/Layout.astro';

const tempoFleet = [
  { id: "tempo-traveller-12", name: "Tempo Traveller 12", seats: "12", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-12-1770871044575-9.png" },
  { id: "tempo-traveller-13", name: "Tempo Traveller 13", seats: "13", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-13-1770871064897-30.png" },
  { id: "tempo-traveller-14", name: "Tempo Traveller 14", seats: "14", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-14-1770871083292-33.png" }
];
---

<Layout 
  title="Luxury Tempo Traveller Rental Bangalore | SF Travels"
  description="Hire 12, 13, and 14-seater Tempo Travellers in Bangalore. Sanitized cabins, ergonomic pushback seating, dual AC, and expert drivers for family outings and pilgrimages."
>
  <main class="bg-[#fafaf8] min-h-screen overflow-x-hidden text-slate-800">
    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden flex items-center justify-center bg-[#0d1629]">
      <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=1920&q=80');">
      </div>
      <div class="absolute inset-0 bg-black/60 z-10 pointer-events-none"></div>
      
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <span class="font-bold text-xs sm:text-sm uppercase tracking-[0.25em] block mb-4 drop-shadow text-[#fbbf24]" style="color: #fbbf24 !important;">Group Touring Vans</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md text-white" style="color: #ffffff !important;">
          Tempo Traveller Rentals
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-semibold drop-shadow-md text-white" style="color: #ffffff !important;">
          Dependable Tempo Traveller rentals for group travel. Perfect for family retreats, corporate outings, and long highway journeys.
        </p>
        <div class="inline-block bg-[#D97706]/20 border border-[#D97706]/40 text-[#fbbf24] font-bold text-xs md:text-sm uppercase tracking-widest px-6 py-2.5 rounded-full shadow-md backdrop-blur-sm" style="color: #fbbf24 !important;">
          <span>"Reliable Family Expeditions"</span>
        </div>
      </div>
    </section>

    <!-- ===== INTRO & PILLARS ===== -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">Group Road Trips</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-6 font-heading">Comfortable Group Highway Tours</h2>
          <p class="text-slate-600 text-base sm:text-lg leading-relaxed">
            Enjoy comfortable and affordable group road trips with our premium Tempo Travellers in Bangalore. Available in 12, 13, and 14-seat variants, our vehicles come with dual AC, premium audio systems, and professional chauffeurs who know the local and outstation routes.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          <!-- Pillar 1 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Multiple Layouts</h3>
            <p class="text-sm text-gray-600">Choose the exact seating space needed, from 12-seater up to 14-seater options.</p>
          </div>

          <!-- Pillar 2 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Climate Control</h3>
            <p class="text-sm text-gray-600">Powerful dual-AC systems with separate airflow controls for every seating row.</p>
          </div>

          <!-- Pillar 3 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Outstation Ready</h3>
            <p class="text-sm text-gray-600">Sturdy highway performance built for hilly terrain and long journeys.</p>
          </div>

          <!-- Pillar 4 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Luggage Accommodation</h3>
            <p class="text-sm text-gray-600">Spacious overhead luggage racks and rear trunk space for all bags.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FLEET SECTION ===== -->
    <section class="py-24 bg-[#fafaf8] border-y border-slate-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">The Traveller Fleet</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-5 font-heading">Select Your Seating Space</h2>
          <p class="text-slate-600 max-w-2xl mx-auto text-sm sm:text-base">
            Select the best matching variant for your outstation pilgrimage, corporate event, or family tour.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {tempoFleet.map(c => (
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
              <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover transform duration-500 hover:scale-105" />
                <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">
                  {c.category.toUpperCase()}
                </div>
              </div>
              <div class="p-5 flex flex-col flex-grow">
                <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">{c.name}</h3>
                <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                  </svg>
                  <span>{c.seats} Seater</span>
                </div>
                <div class="space-y-1 mb-6 flex-grow text-sm">
                  <div class="flex items-center text-slate-600">
                    <span class="text-[#D97706] mr-2 font-bold">✓</span>
                    <span>Professional Uniformed Driver</span>
                  </div>
                  <div class="flex items-center text-slate-600">
                    <span class="text-[#D97706] mr-2 font-bold">✓</span>
                    <span>Push-back Comfort Seats</span>
                  </div>
                  <div class="flex items-center text-slate-600">
                    <span class="text-[#D97706] mr-2 font-bold">✓</span>
                    <span>AC &amp; Music System with Speakers</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                  <button 
                    class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer"
                    data-book-now 
                    data-vehicle={c.name} 
                    data-category="Tempo Traveller Fleet"
                  >
                    Book Now
                  </button>
                  <a 
                    href={`/vehicle/${c.id}`} 
                    class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all"
                  >
                    Details
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FEATURES SECTION ===== -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-extrabold text-[#1a1f36] mb-12 text-center font-heading">Features &amp; Amenities</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">✓ Reclining Captain Chairs</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Ergonomically designed seats for stress-free long-distance highway travel.</p>
          </div>
          <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">✓ Dual Air Cooling</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Surrounding AC blowers with individual controls for every passenger row.</p>
          </div>
          <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">✓ Infotainment Setup</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Premium sound systems with Bluetooth connectivity and surrounding speakers.</p>
          </div>
          <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">✓ Wide Glass Windows</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Large panoramic side windows for scenic highway and sightseeing views.</p>
          </div>
          <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">✓ Roof &amp; Trunk Storage</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Dedicated overhead roof carriers and deep trunk space for all travel bags.</p>
          </div>
          <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">✓ Emergency Equipment</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Onboard emergency first aid kits and safety fire extinguishers present in every cabin.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== BOTTOM CTA SECTION ===== -->
    <section class="py-20 bg-[#1E2D5A] text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-cover bg-center opacity-10" style="background-image: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=1920&q=80');"></div>
      <div class="container mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-extrabold mb-4 font-heading" style="color: #ffffff !important;">Reserve Your Tempo Traveller</h2>
        <p class="text-slate-300 max-w-xl mx-auto mb-8 text-sm sm:text-base">Plan a comfortable and memorable highway journey with your group. Get flat, transparent pricing quotes.</p>
        <button data-book-now data-vehicle="General Enquiry" data-category="Tempo Traveller Rental" class="btn-gold px-8 py-4 font-bold rounded-2xl shadow-lg hover:shadow-xl transition-all cursor-pointer">
          Enquire Now
        </button>
      </div>
    </section>
  </main>
</Layout>
