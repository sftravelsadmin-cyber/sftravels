---
import Layout from '../../layouts/Layout.astro';

const placeholderImage = "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/hatchback-1770872540052-15.png";

const tempoFleet = [
  { id: "tempo-traveller-12", name: "Tempo Traveller 12", seats: "12", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-12-1770871044575-9.png" },
  { id: "tempo-traveller-13", name: "Tempo Traveller 13", seats: "13", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-13-1770871064897-30.png" },
  { id: "tempo-traveller-14", name: "Tempo Traveller 14", seats: "14", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-14-1770871083292-33.png" }
];
---

<Layout 
  title="Tempo Traveller Rental Bangalore - SF Travels"
  description="Rent 12, 13, or 14 seater Tempo Travellers in Bangalore with SF Travels. Clean vehicles, push-back seats, and verified drivers for local and outstation trips."
>
  

  <main class="bg-gray-50 min-h-screen overflow-x-hidden pt-12 text-slate-800">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center pt-20 overflow-hidden">
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/bda0fdb8b258bf205c0653b2583c1ec0.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat;">
      </div>
      <div class="absolute inset-0 bg-black/65 bg-gradient-to-b from-black/80 via-black/50 to-black/70 z-10 pointer-events-none"></div>
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight drop-shadow-lg">Tempo Traveller Rental</h1>
        <p class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed drop-shadow-md">
          Comfortable 12+1, 13+1, and 14+1 seater Tempo Travellers for group travel. Perfect for family trips, pilgrimages, and corporate events.
        </p>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Spacious Group Transportation</h2>
          <p class="text-gray-600 mb-4">Our Tempo Traveller rental service in Bangalore offers the perfect solution for medium to large group travel. With comfortable seating variants for 12, 13, or 14 passengers plus driver, it's ideal for family trips, religious tours, corporate outings, and group vacations.</p>
          <p class="text-gray-600 mb-4">All our Tempo Travellers are well-maintained, equipped with air conditioning, push-back seats, and ample luggage space. Experience comfortable long-distance travel with professional drivers who prioritize your safety and convenience.</p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#10b981] mx-auto mb-3">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">12-14 Seats</h3>
              <p class="text-sm text-gray-600">Various capacities</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#10b981] mx-auto mb-3">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">AC Comfort</h3>
              <p class="text-sm text-gray-600">Climate controlled</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#10b981] mx-auto mb-3">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Any Destination</h3>
              <p class="text-sm text-gray-600">Pan India service</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#10b981] mx-auto mb-3">
                <rect width="20" height="14" x="2" y="7" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Ample Space</h3>
              <p class="text-sm text-gray-600">Large luggage capacity</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Fleet Cards Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Tempo Traveller Variants</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {tempoFleet.map(c => (
            <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col h-full w-full">
              <div class="relative aspect-[16/10] overflow-hidden bg-gray-50">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover" />
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm">
                  {c.category.toUpperCase()}
                </div>
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-grow">
                <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-2">{c.name}</h3>
                <div class="flex items-center text-gray-500 mb-3 text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5 text-[#10b981]">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                  </svg>
                  <span>{c.seats} Seater</span>
                </div>
                <div class="space-y-1 mb-4 flex-grow text-sm">
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#10b981] mr-1.5 font-bold">✓</span>
                    <span>Professional Driver</span>
                  </div>
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#10b981] mr-1.5 font-bold">✓</span>
                    <span>AC & Music System</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <div class="grid grid-cols-2 gap-2 sm:gap-3">
                    <button 
                      class="inline-flex items-center justify-center rounded-md px-4 bg-[#10b981] hover:bg-[#059669] text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                      data-book-now 
                      data-vehicle={c.name} 
                      data-category="Tempo Traveller Fleet"
                    >
                      Book Now
                    </button>
                    <a 
                      href={`/vehicle/${c.id}`} 
                      class="inline-flex items-center justify-center rounded-md border border-[#10b981] text-[#10b981] hover:bg-[#10b981] hover:text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                    >
                      Details
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Features & Amenities</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-3">✓ Push Back Seats</h3>
              <p class="text-gray-600">Reclining seats for comfortable long-distance travel.</p>
            </div>
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-3">✓ Air Conditioning</h3>
              <p class="text-gray-600">Powerful AC to keep everyone cool during the journey.</p>
            </div>
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-3">✓ Music System</h3>
              <p class="text-gray-600">Entertainment system with USB connectivity and speakers.</p>
            </div>
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-3">✓ Large Windows</h3>
              <p class="text-gray-600">Enjoy scenic views through large panoramic windows.</p>
            </div>
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-3">✓ Luggage Carrier</h3>
              <p class="text-gray-600">Top carrier and rear storage for all your luggage needs.</p>
            </div>
            <div class="bg-gray-50 p-6 rounded-lg">
              <h3 class="text-xl font-bold text-gray-900 mb-3">✓ First Aid Kit</h3>
              <p class="text-gray-600">Safety equipment and first aid kit always available.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
