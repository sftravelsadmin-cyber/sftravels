---
import Layout from '../../layouts/Layout.astro';

const weddingServices = [
  { title: "Bridal Cars", desc: "Decorated premium sedans and luxury SUVs for the couple's special entries." },
  { title: "Procession Logistics", desc: "High-end convoy vehicles with top-grade sound setups for the baraat." },
  { title: "Guest Shuttles", desc: "Mass transportation coaches linking hotels, wedding halls, and airports." },
  { title: "Family Chauffeurs", desc: "Dedicated multi-utility vehicles for close relatives to manage event errands." },
  { title: "Celebration Shuttles", desc: "Hassle-free group transfers for Mehendi, Sangeet, and reception parties." },
  { title: "Newlywed Airport Drops", desc: "Seamless airport transfers or direct outstation rides for the couple's getaway." }
];

const fleet = [
  { id: "sedan", name: "Sedan", seats: "4+1", category: "Car", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/sedan-1770872682504-18.png" },
  { id: "innova-crysta", name: "Innova Crysta", seats: "7+1", category: "MPV", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-crysta-1770870762832-21.png" },
  { id: "force-urbania-luxury", name: "Force Urbania Luxury", seats: "12", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-luxury-1770870993546-3.png" },
  { id: "tempo-traveller-14", name: "Tempo Traveller 14", seats: "14", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-14-1770871083292-33.png" },
  { id: "volvo-bus-45", name: "Volvo Bus 45", seats: "45", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/volvo-bus-45-1770872238415-49.png" }
];
---

<Layout 
  title="Wedding Car Rental &amp; Guest Transportation Bangalore | SF Travels"
  description="Make your marriage logistics flawless. Rent luxury bridal cars, decorated wedding sedans, and large guest buses or Tempo Travellers in Bangalore."
>
  <main class="bg-[#fafaf8] min-h-screen overflow-x-hidden text-slate-800">
    <!-- ===== HERO BANNER ===== -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden flex items-center justify-center bg-[#0d1629]">
      <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?w=1920&q=80');">
      </div>
      <div class="absolute inset-0 bg-black/60 z-10 pointer-events-none"></div>
      
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center max-w-4xl">
        <span class="font-bold text-xs sm:text-sm uppercase tracking-[0.25em] block mb-4 drop-shadow text-[#fbbf24]" style="color: #fbbf24 !important;">Marriage Fleet Logistics</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight drop-shadow-md text-white" style="color: #ffffff !important;">
          Wedding Fleet Management
        </h1>
        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-semibold drop-shadow-md text-white" style="color: #ffffff !important;">
          Celebrate your wedding day with premium hospitality and fleet management. Ensure your relatives and wedding guests ride in absolute luxury and comfort.
        </p>
        <div class="inline-block bg-[#D97706]/20 border border-[#D97706]/40 text-[#fbbf24] font-bold text-xs md:text-sm uppercase tracking-widest px-6 py-2.5 rounded-full shadow-md backdrop-blur-sm" style="color: #fbbf24 !important;">
          <span>"Elegant Celebrations"</span>
        </div>
      </div>
    </section>

    <!-- ===== INTRO & PILLARS ===== -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">Wedding Logistics &amp; Transit</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-6 font-heading">Elegant Marriage Event Logistics</h2>
          <p class="text-slate-600 text-base sm:text-lg leading-relaxed">
            We provide complete wedding transport logistics in Bangalore to ensure a beautiful and seamless experience. From elite luxury cars for the wedding couple to spacious, premium buses and vans for your wedding guests, we manage all venue coordinates on time.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          <!-- Pillar 1 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Elegant Decor</h3>
            <p class="text-sm text-gray-600">Vehicles styled and decorated to reflect the elegance of your wedding day.</p>
          </div>

          <!-- Pillar 2 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Elite Fleet</h3>
            <p class="text-sm text-gray-600">Selection of luxury sedans, premium MPVs, and rugged executive SUVs.</p>
          </div>

          <!-- Pillar 3 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Mass Transit</h3>
            <p class="text-sm text-gray-600">Comfortable luxury buses and high-capacity vans to transport guests together.</p>
          </div>

          <!-- Pillar 4 -->
          <div class="p-6 rounded-3xl border border-slate-100 bg-[#fafaf8] hover:border-[#1E2D5A]/10 transition-colors shadow-sm text-center">
            <div class="w-14 h-14 rounded-2xl bg-[#1E2D5A]/10 flex items-center justify-center mb-5 text-[#1E2D5A] mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <rect x="3" y="8" width="18" height="4" rx="1"></rect>
                <path d="M12 8v13"></path>
                <path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2 2v-7"></path>
              </svg>
            </div>
            <h3 class="font-bold text-lg text-gray-900 mb-2 font-heading">Bespoke Support</h3>
            <p class="text-sm text-gray-600">Custom schedules, multiple pickup points, and special requests catered to.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WEDDING SERVICES SECTION ===== -->
    <section class="py-24 bg-white border-t border-slate-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-extrabold text-[#1a1f36] mb-12 text-center font-heading">Our Wedding Services</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {weddingServices.map(ws => (
              <div class="bg-[#fafaf8] p-8 rounded-3xl border border-slate-100 hover:border-amber-500/20 hover:shadow-lg transition-all duration-300">
                <h3 class="text-xl font-bold text-gray-900 mb-3 font-heading">{ws.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{ws.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FLEET SECTION ===== -->
    <section class="py-24 bg-[#fafaf8] border-y border-slate-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="text-[#D97706] font-bold text-xs uppercase tracking-[0.2em] block mb-3">Our Fleet</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1a1f36] mb-5 font-heading">Select Your Wedding Transport</h2>
          <p class="text-slate-600 max-w-2xl mx-auto text-sm sm:text-base">
            Choose from our range of elite bridal cars, multi-seater family vans, and large high-capacity coaches.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {fleet.map(c => (
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 hover:border-slate-200/60 hover:shadow-2xl transition-all duration-300 overflow-hidden flex flex-col h-full w-full">
              <div class="relative aspect-[16/10] overflow-hidden bg-[#fafaf8]">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover transform duration-500 hover:scale-105" />
                <div class="absolute top-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1 rounded-xl text-xs font-bold text-white shadow-sm">
                  {c.category.toUpperCase()}
                </div>
              </div>
              <div class="p-5 flex flex-col flex-grow">
                <h3 class="text-lg font-bold text-gray-900 mb-2 font-heading">{c.name}</h3>
                <div class="flex items-center text-slate-500 mb-4 text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-1.5 shrink-0">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                  </svg>
                  <span>{c.seats} Seater</span>
                </div>
                <div class="space-y-1 mb-6 flex-grow text-sm">
                  <div class="flex items-center text-slate-600">
                    <span class="text-[#D97706] mr-2 font-bold">✓</span>
                    <span>Professional Uniformed Chauffeur</span>
                  </div>
                  <div class="flex items-center text-slate-600">
                    <span class="text-[#D97706] mr-2 font-bold">✓</span>
                    <span>Clean &amp; Sanitized Luxury Cabin</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-slate-100 mt-auto flex gap-3">
                  <button 
                    class="btn-gold flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-2xl shadow-md hover:shadow-lg transition-all cursor-pointer"
                    data-book-now 
                    data-vehicle={c.name} 
                    data-category="Wedding Event"
                  >
                    Book Now
                  </button>
                  <a 
                    href={`/vehicle/${c.id}`} 
                    class="flex-1 py-2.5 text-xs sm:text-sm font-bold text-[#1E2D5A] hover:bg-[#1E2D5A]/5 border border-[#1E2D5A]/20 hover:border-[#1E2D5A] rounded-2xl text-center transition-all"
                  >
                    Details
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CTA BANNER — Left-aligned, warm indigo + amber accent
    ═══════════════════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden py-16 bg-[#0d1629]">
      <!-- Background image with deep brand blue/black overlay -->
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://images.unsplash.com/photo-1608340173813-afedec884f1f?w=1920&q=80'); background-size: cover; background-position: center;">
      </div>
      <div class="absolute inset-0 bg-slate-950/80 z-10"></div>

      <div class="container mx-auto px-4 relative z-20">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-10">
          <div class="text-center lg:text-left">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4" style="color: #ffffff !important;">Ready to Book Your Premium Ride?</h2>
            <p class="text-white/80 text-lg" style="color: rgba(255, 255, 255, 0.8) !important;">Get started today — our team confirms within 15 minutes.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0 items-center lg:items-start">
            <button class="inline-flex items-center justify-center gap-2 bg-[#D97706] hover:bg-[#b45309] text-white font-bold px-10 py-5 rounded-2xl text-lg transition-all shadow-lg" data-book-now data-vehicle="Premium Cab" data-category="General Booking">
              Book a Cab Now
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
            <a href="tel:9353966815" class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/25 hover:bg-white/20 text-white font-bold px-10 py-5 rounded-2xl text-lg transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              Call 9353966815
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
