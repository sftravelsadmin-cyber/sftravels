---
import Layout from '../../layouts/Layout.astro';

const placeholderImage = "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/hatchback-1770872540052-15.png";

const weddingServices = [
  { title: "Bridal Car Service", desc: "Luxury sedans and SUVs for the bride's grand entrance with decorations." },
  { title: "Groom's Baraat", desc: "Decorated vehicles for the groom's procession with music system." },
  { title: "Guest Transportation", desc: "Buses and vans for guest pickup from hotels to venue and back." },
  { title: "Family Transfers", desc: "Comfortable vehicles for family members between multiple venues." },
  { title: "Pre-Wedding Events", desc: "Transportation for mehendi, sangeet, and other pre-wedding functions." },
  { title: "Honeymoon Drop", desc: "Airport or honeymoon destination drop-off for the newlyweds." }
];

const fleet = [
  { id: "sedan", name: "Sedan", seats: "4+1", category: "Car", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/sedan-1770872682504-18.png" },
  { id: "innova-crysta", name: "Innova Crysta", seats: "7+1", category: "MPV", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/innova-crysta-1770870762832-21.png" },
  { id: "force-urbania-luxury", name: "Force Urbania Luxury", seats: "12", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/force-urbania-luxury-1770870993546-3.png" },
  { id: "tempo-traveller-14", name: "Tempo Traveller 14", seats: "14", category: "Van", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/tempo-traveller-14-1770871083292-33.png" },
  { id: "volvo-bus-45", name: "Volvo Bus 45", seats: "45", category: "Bus", image: "https://wdybiksmheimcrkzgzcm.supabase.co/storage/v1/object/public/vehicle-images/volvo-bus-45-1770872238415-49.png" }
];
---

<Layout 
  title="Wedding Transportation Services Bangalore - SF Travels"
  description="Premium wedding car and guest transportation rentals in Bangalore. Book decorated luxury bridal cars, guest buses, and tempo travellers."
>
  

  <main class="bg-gray-50 min-h-screen overflow-x-hidden pt-12 text-slate-800">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center pt-20 overflow-hidden">
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/bda0fdb8b258bf205c0653b2583c1ec0.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat;">
      </div>
      <div class="absolute inset-0 bg-black/65 bg-gradient-to-b from-black/80 via-black/50 to-black/70 z-10 pointer-events-none"></div>
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight drop-shadow-lg">Wedding Transportation Services</h1>
        <p class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed drop-shadow-md">
          Make your special day memorable with our premium wedding transportation. Luxury vehicles for every celebration.
        </p>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Luxury Wedding Transportation</h2>
          <p class="text-gray-600 mb-4">Your wedding day is one of the most important days of your life, and transportation should be the least of your worries. SF Travels offers comprehensive wedding transportation services in Bangalore, ensuring that you, your family, and your guests travel in comfort and style.</p>
          <p class="text-gray-600 mb-4">From luxury cars for the bride and groom to spacious buses for guest transportation, we provide complete wedding transport solutions. Our vehicles are decorated upon request, and our professional drivers ensure timely service throughout your celebrations.</p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Special Day</h3>
              <p class="text-sm text-gray-600">Make it memorable</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Luxury Fleet</h3>
              <p class="text-sm text-gray-600">Premium vehicles</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Guest Transport</h3>
              <p class="text-sm text-gray-600">Comfortable shuttles</p>
            </div>
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-[#1E2D5A] mx-auto mb-3">
                <rect x="3" y="8" width="18" height="4" rx="1"></rect>
                <path d="M12 8v13"></path>
                <path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"></path>
              </svg>
              <h3 class="font-semibold text-gray-900 mb-2">Decorated Cars</h3>
              <p class="text-sm text-gray-600">On request</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Our Wedding Services</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {weddingServices.map(ws => (
              <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300">
                <h3 class="text-xl font-bold text-gray-900 mb-3">{ws.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{ws.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Fleet Vehicles -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Choose Your Wedding Vehicle</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {fleet.map(c => (
            <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col h-full w-full">
              <div class="relative aspect-[16/10] overflow-hidden bg-gray-50">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover" />
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm">
                  {c.category.toUpperCase()}
                </div>
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-grow">
                <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-2">{c.name}</h3>
                <div class="flex items-center text-gray-500 mb-3 text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5 text-[#1E2D5A]">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                  </svg>
                  <span>{c.seats} Seater</span>
                </div>
                <div class="space-y-1 mb-4 flex-grow text-sm">
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#1E2D5A] mr-1.5 font-bold">✓</span>
                    <span>Professional Uniformed Chauffeur</span>
                  </div>
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#1E2D5A] mr-1.5 font-bold">✓</span>
                    <span>Clean & Sanitized Luxury Cabin</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <div class="grid grid-cols-2 gap-2 sm:gap-3">
                    <button 
                      class="inline-flex items-center justify-center rounded-md px-4 bg-[#1E2D5A] hover:bg-[#151f3f] text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                      data-book-now 
                      data-vehicle={c.name} 
                      data-category="Wedding Fleet"
                    >
                      Book Now
                    </button>
                    <a 
                      href={`/vehicle/${c.id}`} 
                      class="inline-flex items-center justify-center rounded-md border border-[#1E2D5A] text-[#1E2D5A] hover:bg-[#1E2D5A] hover:text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                    >
                      Details
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
