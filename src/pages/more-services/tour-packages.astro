  },
  {
    name: "Ooty Hill Station Tour",
    duration: "3 Days / 2 Nights",
    desc: "Visit the Queen of Hill Stations and enjoy scenic beauty",
    highlights: ["Botanical Garden", "Ooty Lake", "Doddabetta Peak", "Toy Train Ride"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/e3a3286b88c3cbb532fbc0a0cd7c2779.png"
  },
  {
    name: "Mysore Palace & Gardens",
    duration: "1 Day",
    desc: "One day trip to the City of Palaces",
    highlights: ["Mysore Palace", "Brindavan Gardens", "Chamundi Hills", "Local Shopping"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/2bab1fc02a213be6a7e14dd42fca31cb.jpg"
  },
  {
    name: "Chikmagalur Coffee Land",
    duration: "2 Days / 1 Night",
    desc: "Experience coffee estates and mountain peaks",
    highlights: ["Mullayanagiri Peak", "Baba Budangiri", "Hebbe Falls", "Coffee Estate Visit"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/baad984aea1fc703ceb81ac7fc7f48dd.png"
  },
  {
    name: "Gokarna Beach Retreat",
    duration: "2 Days / 1 Night",
    desc: "Relax at pristine beaches and temples",
    highlights: ["Om Beach", "Kudle Beach", "Mahabaleshwar Temple", "Beach Activities"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/4bb726435500525094f28cd6699300b5.png"
  },
  {
    name: "Hampi Heritage Tour",
    duration: "2 Days / 1 Night",
    desc: "Explore UNESCO World Heritage Site",
    highlights: ["Virupaksha Temple", "Stone Chariot", "Vittala Temple", "Royal Enclosure"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/2c775c7091fcf1f8f1768dd81acb4340.png"
  },
  {
    name: "North Indian Tour",
    duration: "10 Days / 9 Nights",
    desc: "Experience the grandeur of Delhi, Agra, and Jaipur",
    highlights: ["Taj Mahal", "Red Fort", "Hawa Mahal", "Amber Fort"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/893b7f26811c5b264ca4b8350f4980b7.png"
  },
  {
    name: "Prayagraj Pilgrimage",
    duration: "3 Days / 2 Nights",
    desc: "Spiritual journey to the holy Sangam",
    highlights: ["Triveni Sangam", "Hanuman Temple", "Anand Bhavan", "Alopi Devi Mandir"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/6013980f361b5addb4ba24096355eab9.png"
  },
  {
    name: "Kashi & Varanasi",
    duration: "4 Days / 3 Nights",
    desc: "Experience the spiritual capital of India",
    highlights: ["Kashi Vishwanath Temple", "Ganga Aarti", "Sarnath", "Boat Ride"],
    img: "https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/6d2e68429b7e4bf9199eab3c1071d662.png"
  },
  {
    name: "Tirupati Balaji Darshan",
    duration: "2 Days / 1 Night",
    desc: "Seek blessings at the richest temple in the world",
    highlights: ["Lord Venkateswara Temple", "Padmavathi Ammavari Temple", "Kapila Theertham", "Akasaganga"],
