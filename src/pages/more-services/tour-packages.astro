---

<Layout 
  title="Tour Packages from Bangalore - SF Travels"
  description="Discover amazing destinations with our curated tour packages. Complete travel solutions with private transport and professional driver guidance."
>
  

  <main class="bg-gray-50 min-h-screen overflow-x-hidden pt-12 text-slate-800">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center pt-20 overflow-hidden">
      <div class="absolute inset-0 z-0"
        style="background-image: url('https://horizons-cdn.hostinger.com/e3da7081-89fa-4296-8e0b-208ae94398b5/bda0fdb8b258bf205c0653b2583c1ec0.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat;">
      </div>
      <div class="absolute inset-0 bg-black/65 bg-gradient-to-b from-black/80 via-black/50 to-black/70 z-10 pointer-events-none"></div>
      <div class="container mx-auto px-4 sm:px-6 relative z-20 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight drop-shadow-lg">Tour Packages from Bangalore</h1>
        <p class="text-lg md:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed drop-shadow-md">
          Discover amazing destinations with our curated tour packages. Complete travel solutions with transport and guidance.
        </p>
      </div>
    </section>

    <!-- Tour Packages Grid -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Popular Tour Packages</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {tourPackages.map(pkg => (
            <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 flex flex-col h-full group border border-gray-100">
              <div class="overflow-hidden h-48 w-full relative bg-gray-100">
                <img src={pkg.img} alt={pkg.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>
              <div class="p-6 flex-grow flex flex-col">
                <h3 class="text-xl font-bold text-gray-900 mb-2">{pkg.name}</h3>
                <p class="text-sm text-[#10b981] font-semibold mb-3">{pkg.duration}</p>
                <p class="text-gray-600 mb-4 text-sm leading-relaxed">{pkg.desc}</p>
                <div class="mb-6 flex-grow">
                  <p class="font-semibold text-gray-900 mb-2 text-sm">Highlights:</p>
                  <ul class="text-sm text-gray-600 space-y-1">
                    {pkg.highlights.map(hl => (
                      <li>• {hl}</li>
                    ))}
                  </ul>
                </div>
                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <button 
                    class="w-full inline-flex items-center justify-center rounded-md px-4 bg-[#10b981] hover:bg-[#059669] text-white font-semibold text-sm py-2.5 h-10 transition-colors"
                    data-book-now 
                    data-vehicle={pkg.name} 
                    data-category="Tour Package"
                  >
                    Enquire Now
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Choose Your Tour Vehicle Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center">Choose Your Tour Vehicle</h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">Select the most comfortable vehicle for your multi-day tour package.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {vehicles.map(c => (
            <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col h-full w-full">
              <div class="relative aspect-[16/10] overflow-hidden bg-gray-50">
                <img src={c.image} alt={c.name} class="w-full h-full object-cover" />
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm">
                  {c.category.toUpperCase()}
                </div>
              </div>
              <div class="p-4 sm:p-5 flex flex-col flex-grow">
                <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-2">{c.name}</h3>
                <div class="flex items-center text-gray-500 mb-3 text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5 text-[#10b981]">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                  </svg>
                  <span>{c.seats} Seater</span>
                </div>
                <div class="space-y-1 mb-4 flex-grow text-sm">
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#10b981] mr-1.5 font-bold">✓</span>
                    <span>Professional Chauffeur</span>
                  </div>
                  <div class="flex items-center text-gray-600">
                    <span class="text-[#10b981] mr-1.5 font-bold">✓</span>
                    <span>AC & Music System</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <div class="grid grid-cols-2 gap-2 sm:gap-3">
                    <button 
                      class="inline-flex items-center justify-center rounded-md px-4 bg-[#10b981] hover:bg-[#059669] text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                      data-book-now 
                      data-vehicle={c.name} 
                      data-category="Tour Fleet"
                    >
                      Book Now
                    </button>
                    <a 
                      href={`/vehicle/${c.id}`} 
                      class="inline-flex items-center justify-center rounded-md border border-[#10b981] text-[#10b981] hover:bg-[#10b981] hover:text-white font-semibold text-xs sm:text-sm py-2 h-9 sm:h-10 transition-colors"
                    >
                      Details
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
