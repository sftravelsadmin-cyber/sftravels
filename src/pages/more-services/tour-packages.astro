---
import Layout from '../../layouts/Layout.astro';

const tourPackages = [
  {
    name: 'Bangalore to Mysuru & Coorg',
    duration: '2 Days / 1 Night',
    distance: '~500 km',
    icon: '🌿',
    highlights: ['Brindavan Gardens', 'Mysuru Palace', 'Abbey Falls', 'Coffee Estates'],
    vehicle: 'Sedan or SUV',
    price: 'From ₹6,500',
  },
  {
    name: 'Bangalore to Ooty & Coonoor',
    duration: '2 Days / 1 Night',
    distance: '~550 km',
    icon: '🏔️',
    highlights: ['Doddabetta Peak', 'Ooty Lake', 'Tea Gardens', 'Nilgiri Train View'],
    vehicle: 'Sedan or SUV',
    price: 'From ₹7,200',
  },
  {
    name: 'Bangalore to Goa',
    duration: '3 Days / 2 Nights',
    distance: '~1,140 km',
    icon: '🏖️',
    highlights: ['Calangute Beach', 'Old Goa Churches', 'Dudhsagar Falls', 'Anjuna Market'],
    vehicle: 'SUV or Tempo',
    price: 'From ₹14,000',
  },
  {
    name: 'South India Pilgrimage Circuit',
    duration: '4 Days / 3 Nights',
    distance: '~1,400 km',
    icon: '🛕',
    highlights: ['Tirupati', 'Srisailam', 'Mantralayam', 'Dharmasthala'],
    vehicle: 'Tempo Traveller',
    price: 'From ₹22,000',
  },
];
---

<Layout
  title="Custom Tour Packages Bangalore | SF Travels — South India Cab Tours"
  description="Book custom cab tour packages from Bangalore. 2-day, 3-day South India getaways to Mysuru, Coorg, Ooty, Goa, and pilgrimage circuits with SF Travels."
>

  <section class="service-hero tours-hero">
    <div class="hero-overlay-dark"></div>
    <div class="container service-hero-content">
      <div class="service-badge-pill">🗺️ Custom Tour Packages</div>
      <h1 class="service-hero-title">
        Explore South India —<br />
        <span class="gold-text">At Your Own Pace.</span>
      </h1>
      <p class="service-hero-desc">
        Curated multi-day tour packages with private cab, experienced driver-guide, and flexible itineraries. No crowded buses. No fixed schedules.
      </p>
      <div class="service-hero-cta">
        <a href="/contact" class="btn-gold">📞 Customise My Tour</a>
        <a href="https://wa.me/919187232348?text=Hi%2C%20I%20need%20a%20custom%20tour%20package%20from%20Bangalore." target="_blank" rel="noopener" class="btn-outline">💬 WhatsApp Tour Plan</a>
      </div>
      <div class="hero-pills">
        <span class="pill">✓ Private cab, no sharing</span>
        <span class="pill">✓ Flexible itinerary</span>
        <span class="pill">✓ 50+ South India routes</span>
      </div>
    </div>
  </section>

  <section class="section-padding tours-section">
    <div class="container">
      <div class="section-label">Popular Tour Packages</div>
      <h2 class="section-title">Curated <span class="gold-text">Getaways</span></h2>
      <p class="section-desc">All packages include a private cab with driver. Hotels and meals are optional add-ons.</p>
      <div class="tours-grid">
        {tourPackages.map(pkg => (
          <div class="tour-card glass-card">
            <div class="tour-icon">{pkg.icon}</div>
            <div class="tour-body">
              <h3 class="tour-name">{pkg.name}</h3>
              <div class="tour-meta">
                <span>📅 {pkg.duration}</span>
                <span>📏 {pkg.distance}</span>
                <span>🚗 {pkg.vehicle}</span>
              </div>
              <div class="tour-highlights">
                {pkg.highlights.map(h => <span class="highlight-tag">✓ {h}</span>)}
              </div>
              <div class="tour-price-row">
                <span class="tour-price">{pkg.price}</span>
                <a href={`https://wa.me/919187232348?text=Hi%2C%20I%20need%20the%20tour%20package%20for%20${encodeURIComponent(pkg.name)}`} target="_blank" rel="noopener" class="btn-gold tour-btn">Book This Tour</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container cta-content">
      <h2 class="cta-title">Have a Custom Route in Mind?</h2>
      <p class="cta-subtitle">Tell us your destination, group size, and dates — we'll build a personalised tour itinerary and fare quote.</p>
      <div class="cta-actions">
        <a href="tel:+919187232348" class="btn-gold">📞 Plan My Tour: 9187232348</a>
        <a href="https://wa.me/919187232348?text=Hi%2C%20I%20want%20a%20custom%20tour%20from%20Bangalore" target="_blank" rel="noopener" class="btn-outline">💬 WhatsApp Tour Plan</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.service-hero { position: relative; min-height: 520px; display: flex; align-items: center; overflow: hidden; }
.tours-hero { background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1400&q=80'); background-size: cover; background-position: center 60%; }
.hero-overlay-dark { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(5,13,26,0.92) 0%, rgba(5,13,26,0.72) 100%); }
.service-hero-content { position: relative; z-index: 2; padding: 120px 20px 80px; max-width: 720px; }
.service-badge-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: #10b981; padding: 6px 16px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; margin-bottom: 20px; }
.service-hero-title { font-size: clamp(2rem, 5vw, 3rem); color: #fff; line-height: 1.15; margin-bottom: 18px; }
.service-hero-desc { font-size: 1.05rem; color: rgba(255,255,255,0.78); line-height: 1.7; margin-bottom: 28px; max-width: 560px; }
.service-hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 24px; }
.hero-pills { display: flex; gap: 10px; flex-wrap: wrap; }
.pill { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #a7f3d0; padding: 5px 14px; border-radius: 50px; font-size: 0.82rem; }
.tours-section { background: var(--bg-primary); }
.tours-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; margin-top: 40px; }
.tour-card { padding: 28px 26px; display: flex; gap: 20px; align-items: flex-start; }
.tour-icon { font-size: 2.8rem; flex-shrink: 0; }
.tour-body { display: flex; flex-direction: column; gap: 12px; flex: 1; }
.tour-name { font-size: 1.1rem; font-weight: 700; color: #fff; line-height: 1.3; }
.tour-meta { display: flex; gap: 14px; flex-wrap: wrap; font-size: 0.82rem; color: rgba(255,255,255,0.55); }
.tour-highlights { display: flex; flex-wrap: wrap; gap: 6px; }
.highlight-tag { font-size: 0.78rem; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.18); color: #a7f3d0; padding: 3px 9px; border-radius: 50px; }
.tour-price-row { display: flex; justify-content: space-between; align-items: center; margin-top: 4px; flex-wrap: wrap; gap: 10px; }
.tour-price { font-size: 1.25rem; font-weight: 700; color: #10b981; font-family: var(--font-heading); }
.tour-btn { font-size: 0.85rem; padding: 10px 20px; }
.cta-banner { background: linear-gradient(135deg, #0b172a 0%, #051a2c 100%); border-top: 1px solid rgba(16,185,129,0.2); padding: 80px 20px; }
.cta-content { text-align: center; }
.cta-title { font-size: clamp(1.6rem, 4vw, 2.4rem); color: #fff; margin-bottom: 14px; }
.cta-subtitle { color: rgba(255,255,255,0.65); font-size: 1.05rem; margin-bottom: 32px; }
.cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.section-label { font-size: 0.8rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #10b981; margin-bottom: 10px; }
.section-title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: #fff; margin-bottom: 12px; }
.section-desc { font-size: 1rem; color: rgba(255,255,255,0.6); max-width: 560px; }
@media (max-width: 900px) { .tours-grid { grid-template-columns: 1fr; } .tour-card { flex-direction: column; } }
@media (max-width: 640px) { .service-hero-cta { flex-direction: column; } }
</style>
