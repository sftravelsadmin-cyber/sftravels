---
import Layout from '../layouts/Layout.astro';

// SF Travels - Premium About Us Page
---

<Layout 
  title="About Us | SF Travels - Redefining Premium Mobility in Bangalore"
  description="Learn about the legacy of SF Travels. Built on absolute safety, transparent slab rate pricing, exceptional chauffeur hospitality, and executive corporate fleet transport."
>

  <!-- ==================== PAGE HERO HEADER ==================== -->
  <section class="about-hero-section">
    <div class="hero-overlay"></div>
    <div class="container relative z-10 text-center">
      <span class="gold-subtitle">OUR LEGACY</span>
      <h1 class="about-hero-title">
        Redefining <span class="gold-text">Premium Mobility</span><br />in Bangalore
      </h1>
      <p class="about-hero-subtitle max-w-3xl mx-auto">
        The story of SF Travels — built on absolute safety, transparent slab pricing, and executive comfort since inception.
      </p>
    </div>
  </section>

  <!-- ==================== OUR STORY SECTION ==================== -->
  <section class="section-padding story-section">
    <div class="container story-container">
      <div class="story-text-content">
        <span class="gold-subtitle">OUR HISTORY</span>
        <h2 class="section-title text-dark">Driven by Passion, Defined by Trust</h2>
        <div class="story-paragraphs">
          <p class="story-para text-muted">
            SF Travels was founded with a singular, clear objective: to elevate the quality of vehicle rental and corporate cab services in Bangalore. In an industry often troubled by erratic pricing, late pickups, and unkempt vehicles, we set out to create a service built entirely on trust and predictability.
          </p>
          <p class="story-para text-muted">
            What started as a boutique car rental service has matured into a premier mobility provider for top corporate companies, luxury resorts, and thousands of daily travelers. We have consistently expanded our fleet to include the absolute best in class—from premium sedans and Toyota Crystas to first-class Force Urbania vans and heavy Volvo coaches.
          </p>
          <p class="story-para text-muted">
            Our name, <strong class="text-dark">SF Travels</strong>, stands for seamless coordination, modern technology, and a customer-centric heart. With our tagline, <strong class="emerald-highlight">"Smooth Ride On Time"</strong>, we promise our corporate and retail clients that we will never compromise on safety, cleanliness, or punctuality.
          </p>
        </div>
      </div>
      
      <div class="story-image-wrapper">
        <div class="story-image-glow"></div>
        <img src="https://images.unsplash.com/photo-1549399542-7e3f8b79c341?q=80&w=800&auto=format&fit=crop" alt="Premium Chauffeur Travel Experience" class="story-image" />
      </div>
    </div>
  </section>

  <!-- ==================== MISSION & VISION (DARK SECTION) ==================== -->
  <section class="mission-section section-padding">
    <div class="mission-overlay"></div>
    <div class="container relative z-10">
      <div class="mission-vision-grid">
        <!-- Mission Card -->
        <div class="mission-card glass-card">
          <div class="mission-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
          </div>
          <h3 class="mission-card-title">Our Mission</h3>
          <p class="mission-card-desc">
            To deliver safe, highly reliable, and executive-grade transportation services that far exceed customer expectations. We strive to provide travel certainty for businesses and individuals by maintaining the highest standards of driver training, vehicle maintenance, and transparent slab rates.
          </p>
        </div>

        <!-- Vision Card -->
        <div class="mission-card glass-card">
          <div class="mission-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><circle cx="12" cy="12" r="10"></circle><path d="m4.93 4.93 4.24 4.24"></path><path d="m14.83 9.17 4.24-4.24"></path><path d="m14.83 14.83 4.24 4.24"></path><path d="m9.17 14.83-4.24 4.24"></path></svg>
          </div>
          <h3 class="mission-card-title">Our Vision</h3>
          <p class="mission-card-desc">
            To be recognized as the most trusted and preferred corporate mobility partner in Bangalore and surrounding states, setting new benchmarks in the travel industry through continuous fleet modernization, eco-friendly transit additions, and exceptional customer service.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CORE VALUES SECTION (THE SF CODE) ==================== -->
  <section class="section-padding values-section">
    <div class="container">
      <div class="text-center">
        <span class="gold-subtitle">THE SF CODE</span>
        <h2 class="section-title text-dark">Our Core Values</h2>
        <p class="section-desc text-muted max-w-3xl">
          We enforce these four absolute principles on every single journey, ensuring corporate excellence and absolute passenger trust.
        </p>
      </div>

      <div class="values-grid">
        <!-- Value 1 -->
        <div class="value-card">
          <div class="value-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path></svg>
          </div>
          <h3 class="value-title text-dark">Safety First, Always</h3>
          <p class="value-desc text-muted">
            We do not cut corners when it comes to human lives. Every vehicle in our fleet is fitted with dynamic GPS trackers, speed limiters, and first-aid kits, and undergoes pre-trip mechanical checks.
          </p>
        </div>

        <!-- Value 2 -->
        <div class="value-card">
          <div class="value-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 class="value-title text-dark">Uncompromising Punctuality</h3>
          <p class="value-desc text-muted">
            In the business world, 5 minutes late is unacceptable. We guarantee on-time arrival. Our dispatch system ensures our chauffeurs are pre-stationed at your pickup spot before the trip begins.
          </p>
        </div>

        <!-- Value 3 -->
        <div class="value-card">
          <div class="value-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <h3 class="value-title text-dark">Client-First Chauffeur Etiquette</h3>
          <p class="value-desc text-muted">
            Our drivers are professional chauffeurs, not just cab operators. They are well-trained in defensive driving, polite conversation, luggage handling, and corporate etiquette.
          </p>
        </div>

        <!-- Value 4 -->
        <div class="value-card">
          <div class="value-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line></svg>
          </div>
          <h3 class="value-title text-dark">Transparent Slab Rates</h3>
          <p class="value-desc text-muted">
            We believe that trust is built on transparency. Our slab rate structures are clear, fixed, and free of surge shocks. Our corporate rate slab cards ensure absolute pricing clarity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== THE SF DIFFERENCE BANNER ==================== -->
  <section class="difference-section">
    <div class="container text-center">
      <span class="white-subtitle">THE SF TRAVELS DIFFERENCE</span>
      <h2 class="difference-title">Elevating Chauffeur Transits</h2>
      <p class="difference-desc max-w-2xl mx-auto">
        We bridge the gap between traditional car rentals and modern corporate expectations by committing to absolute quality checkpoints on every ride.
      </p>

      <div class="difference-checklist">
        <!-- Item 1 -->
        <div class="checklist-item">
          <div class="check-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <div class="check-text">
            <h4 class="check-title">24/7 Roadside Assistance</h4>
            <p class="check-desc">Active dispatch desk managing route updates or emergency roadside support instantly.</p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="checklist-item">
          <div class="check-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <div class="check-text">
            <h4 class="check-title">Deep Sanitization</h4>
            <p class="check-desc">Comprehensive mechanical cleanup and deep vehicle sanitization performed before every duty.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="checklist-item">
          <div class="check-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <div class="check-text">
            <h4 class="check-title">All India Tourist Permit (AITP)</h4>
            <p class="check-desc">Fully cleared state documents for hassle-free inter-state highway border crossings.</p>
          </div>
        </div>

        <!-- Item 4 -->
        <div class="checklist-item">
          <div class="check-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <div class="check-text">
            <h4 class="check-title">Customized Billing Solutions</h4>
            <p class="check-desc">Effortless monthly consolidated invoice templates with verified logs for corporate clients.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ==================== PAGE HERO HEADER STYLES ==================== */
  .about-hero-section {
    min-height: 50vh;
    position: relative;
    padding-top: 150px;
    padding-bottom: 70px;
    display: flex;
    align-items: center;
    background-image: url('https://images.unsplash.com/photo-1506012787146-f92b2d7d6d96?q=80&w=1600&auto=format&fit=crop');
    background-size: cover;
    background-position: center center;
    background-attachment: fixed;
    overflow: hidden;
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(5, 13, 26, 0.95) 0%, rgba(5, 13, 26, 0.8) 100%);
    z-index: 1;
  }
  
  .relative {
    position: relative;
  }
  
  .z-10 {
    z-index: 10;
  }
  
  .about-hero-title {
    font-size: 3.5rem;
    line-height: 1.15;
    font-weight: 800;
    margin-bottom: 20px;
    color: var(--text-white);
  }
  
  .about-hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-light);
    line-height: 1.7;
  }

  .gold-subtitle {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    color: var(--brand-gold-dark);
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }

  .text-dark {
    color: #050d1a !important;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  
  .section-desc {
    font-size: 1.05rem;
    margin: 0 auto 56px auto;
    line-height: 1.75;
  }

  .max-w-3xl {
    max-w: 48rem;
  }

  .max-w-2xl {
    max-w: 42rem;
  }

  .mx-auto {
    margin-left: auto;
    margin-right: auto;
  }

  /* ==================== OUR STORY SECTION ==================== */
  .story-section {
    background-color: #ffffff;
    background-image: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%);
  }
  
  .story-container {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }
  
  .story-text-content {
    display: flex;
    flex-direction: column;
  }
  
  .story-paragraphs {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 16px;
  }
  
  .story-para {
    font-size: 0.98rem;
    line-height: 1.7;
    color: #4b5563 !important;
  }

  .emerald-highlight {
    color: var(--brand-gold-dark);
    font-weight: 700;
  }
  
  .story-image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .story-image {
    width: 100%;
    border-radius: var(--border-radius);
    box-shadow: 0 15px 35px rgba(5, 13, 26, 0.15);
    z-index: 2;
    transition: var(--transition-smooth);
  }
  
  .story-image-wrapper:hover .story-image {
    transform: translateY(-4px);
  }
  
  .story-image-glow {
    position: absolute;
    width: 90%;
    height: 90%;
    border-radius: var(--border-radius);
    background: var(--brand-gold);
    opacity: 0.1;
    filter: blur(20px);
    z-index: 1;
    top: 20px;
    left: 20px;
  }

  /* ==================== MISSION & VISION STYLES ==================== */
  .mission-section {
    position: relative;
    background-image: url('https://images.unsplash.com/photo-1557403072-f101218865a9?q=80&w=1600&auto=format&fit=crop');
    background-size: cover;
    background-position: center center;
    overflow: hidden;
  }
  
  .mission-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(5, 13, 26, 0.95) 0%, rgba(5, 13, 26, 0.85) 100%);
    z-index: 1;
  }
  
  .mission-vision-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  
  .mission-card {
    padding: 40px;
    border-color: rgba(16, 185, 129, 0.15);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .mission-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: rgba(16, 185, 129, 0.15);
    color: var(--brand-gold);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .mission-icon-wrapper svg {
    width: 28px;
    height: 28px;
  }
  
  .mission-card-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-white);
  }
  
  .mission-card-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ==================== CORE VALUES SECTION ==================== */
  .values-section {
    background-color: #ffffff;
    background-image: linear-gradient(to bottom, #f8fafc 0%, #ffffff 100%);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }
  
  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
    margin-top: 50px;
  }
  
  .value-card {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    border-radius: var(--border-radius);
    padding: 35px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: var(--transition-smooth);
  }
  
  .value-card:hover {
    transform: translateY(-4px);
    border-color: rgba(16, 185, 129, 0.25);
    box-shadow: 0 10px 30px rgba(16, 185, 129, 0.08);
  }
  
  .value-icon-wrapper {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    background: rgba(16, 185, 129, 0.1);
    color: var(--brand-gold-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
  }
  
  .value-card:hover .value-icon-wrapper {
    background: var(--brand-gold);
    color: var(--text-white);
  }
  
  .value-icon-wrapper svg {
    width: 22px;
    height: 22px;
  }
  
  .value-title {
    font-size: 1.25rem;
    font-weight: 700;
  }
  
  .value-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #4b5563 !important;
  }

  /* ==================== DIFFERENCE CHECKLIST STYLES ==================== */
  .difference-section {
    position: relative;
    background: linear-gradient(135deg, var(--brand-gold-dark) 0%, var(--brand-gold) 100%);
    padding: 80px 0;
    color: var(--text-white);
  }
  
  .white-subtitle {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    color: var(--brand-gold-light);
    text-transform: uppercase;
    display: block;
    margin-bottom: 12px;
  }
  
  .difference-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
    color: var(--text-white);
  }
  
  .difference-desc {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    margin-bottom: 50px;
  }
  
  .difference-checklist {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    text-align: left;
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--border-radius);
    padding: 24px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: var(--transition-smooth);
  }
  
  .checklist-item:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }
  
  .check-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--brand-gold-light);
    color: var(--brand-gold-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .check-icon svg {
    width: 16px;
    height: 16px;
    stroke-width: 3;
    display: block;
  }
  
  .check-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .check-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-white);
  }
  
  .check-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
  }

  /* ==================== RESPONSIVE LAYOUTS ==================== */
  @media (max-width: 992px) {
    .about-hero-title {
      font-size: 2.8rem;
    }
    
    .story-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .story-image-wrapper {
      margin-top: 20px;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .mission-vision-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .values-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .difference-checklist {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
  
  @media (max-width: 576px) {
    .about-hero-section {
      padding-top: 120px;
      padding-bottom: 50px;
    }
    
    .about-hero-title {
      font-size: 2.2rem;
    }
    
    .section-title {
      font-size: 2rem;
    }
    
    .mission-card {
      padding: 24px;
    }
    
    .value-card {
      padding: 24px;
    }
    
    .checklist-item {
      padding: 20px;
    }
  }
</style>
