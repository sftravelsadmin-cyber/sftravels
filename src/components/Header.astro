---
// SF Travels Header Navigation
---

<header class="header-main">
  <div class="container header-container">
    
    <!-- Premium Logo Section -->
    <a href="/" class="logo-wrapper">
      <!-- Golden dynamic circle monogram SVG Logo -->
      <svg class="logo-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#F2E5C9"></stop>
            <stop offset="30%" stop-color="#C5A85C"></stop>
            <stop offset="50%" stop-color="#AA8439"></stop>
            <stop offset="70%" stop-color="#EBDCB9"></stop>
            <stop offset="100%" stop-color="#8A6623"></stop>
          </linearGradient>
        </defs>
        
        <!-- Outer dynamic swooshes (Top-right crescent) -->
        <path d="M 50 8 C 73.19 8 92 26.81 92 50 C 92 65.5 83.5 79 70 86 C 82 76 87 60 87 50 C 87 29.56 70.44 13 50 13 Z" fill="url(#goldGrad)"></path>
        
        <!-- Bottom-left crescent swoosh -->
        <path d="M 50 92 C 26.81 92 8 73.19 8 50 C 8 34.5 16.5 21 30 14 C 18 24 13 40 13 50 C 13 70.44 29.56 87 50 87 Z" fill="url(#goldGrad)"></path>
        
        <!-- Inner thin decorative swoosh lines -->
        <path d="M 50 18 A 32 32 0 0 1 82 50 A 32 32 0 0 1 73 72" fill="none" stroke="url(#goldGrad)" stroke-width="1.5" stroke-linecap="round"></path>
        <path d="M 50 82 A 32 32 0 0 1 18 50 A 32 32 0 0 1 27 28" fill="none" stroke="url(#goldGrad)" stroke-width="1.5" stroke-linecap="round"></path>
        
        <!-- Stylized "SF" Monogram inside -->
        <g fill="url(#goldGrad)">
          <!-- "S" Path -->
          <path d="M 28,45 C 28,34 39,32 44,32 C 48,32 50,34 50,37 C 50,42 42,42 38,44 C 31,46.5 27,50 27,57 C 27,65 35,68 45,68 C 50,68 53,67 56,65 L 56,59 C 52,61 47,62 44,62 C 40,62 35,61 35,57 C 35,51 44,51 48,49 C 54,46 58,43 58,36 C 58,29 50,26 42,26 C 35,26 29,28 28,30 Z"></path>
          <!-- "F" Path -->
          <path d="M 64,28 L 64,68 L 71,68 L 71,51 L 82,51 L 82,45 L 71,45 L 71,34 L 84,34 L 84,28 Z"></path>
        </g>
      </svg>
      <div class="logo-text">
        <span class="logo-title"><span class="logo-title-first">SF</span> TRAVELS</span>
        <span class="logo-tagline">Smooth Ride On Time</span>
      </div>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="nav-desktop">
      <a href="/" class="nav-link active">Home</a>
      <a href="/about" class="nav-link">About Us</a>
      
      <!-- Services Dropdown -->
      <div class="dropdown-wrapper">
        <button class="dropdown-btn">
          Services
          <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-menu glass-card">
          <a href="/services/airport-taxi" class="dropdown-link">Airport Taxi</a>
          <a href="/services/outstation-cabs" class="dropdown-link">Outstation Cabs</a>
          <a href="/services/local-hire" class="dropdown-link">Local Hourly Cabs</a>
          <a href="/services/one-way-taxi" class="dropdown-link">One Way Taxi</a>
        </div>
      </div>
      
      <!-- More Services Dropdown -->
      <div class="dropdown-wrapper">
        <button class="dropdown-btn">
          More Services
          <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-menu glass-card">
          <a href="/more-services/bus-rental" class="dropdown-link">Bus Rental Service</a>
          <a href="/more-services/force-urbania" class="dropdown-link">Urban Rental Service</a>
          <a href="/more-services/tempo-traveller" class="dropdown-link">Tempo Traveller Rental</a>
          <a href="/more-services/corporate-events" class="dropdown-link">Corporate Events</a>
          <a href="/more-services/marriage-events" class="dropdown-link">Marriage Events</a>
          <a href="/more-services/tour-packages" class="dropdown-link">Tour Packages</a>
        </div>
      </div>
      
      <a href="/driver-vacancy" class="nav-link">Driver Vacancy</a>
      <a href="/contact" class="nav-link">Contact Us</a>
      <a href="/blog" class="nav-link">Blog</a>
    </nav>

    <!-- Desktop WhatsApp Button -->
    <div class="header-action">
      <a href="https://wa.me/919353966815?text=Hello%20SF%20Travels%2C%20I%20would%20like%20to%20book%20a%20ride." target="_blank" rel="noopener noreferrer" class="btn-gold header-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        <span>WhatsApp Now</span>
      </a>
    </div>

    <!-- Mobile Menu Toggle Button -->
    <button class="mobile-toggle-btn" aria-label="Toggle Navigation Menu" id="mobileToggle">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
    </button>

  </div>
</header>

<!-- Mobile Slide-out Menu Panel -->
<div class="mobile-menu-overlay" id="mobileOverlay">
  <div class="mobile-menu-panel glass-card">
    <div class="mobile-menu-header">
      <span class="gold-text menu-title">SF Travels</span>
      <button class="mobile-close-btn" id="mobileClose" aria-label="Close Navigation Menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="18" x2="6" y1="6" y2="18"></line><line x1="6" x2="18" y1="6" y2="18"></line></svg>
      </button>
    </div>
    <nav class="nav-mobile-links">
      <a href="/" class="mobile-link active">Home</a>
      <a href="/about" class="mobile-link">About Us</a>
      
      <div class="mobile-expandable">
        <button class="mobile-expand-btn">
          Services
          <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="mobile-submenu">
          <a href="/services/airport-taxi" class="mobile-sub-link">Airport Taxi</a>
          <a href="/services/outstation-cabs" class="mobile-sub-link">Outstation Cabs</a>
          <a href="/services/local-hire" class="mobile-sub-link">Local Hourly Cabs</a>
          <a href="/services/one-way-taxi" class="mobile-sub-link">One Way Taxi</a>
        </div>
      </div>
      
      <div class="mobile-expandable">
        <button class="mobile-expand-btn">
          More Services
          <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="mobile-submenu">
          <a href="/more-services/bus-rental" class="mobile-sub-link">Bus Rental Service</a>
          <a href="/more-services/force-urbania" class="mobile-sub-link">Urban Rental Service</a>
          <a href="/more-services/tempo-traveller" class="mobile-sub-link">Tempo Traveller Rental</a>
          <a href="/more-services/corporate-events" class="mobile-sub-link">Corporate Events</a>
          <a href="/more-services/marriage-events" class="mobile-sub-link">Marriage Events</a>
          <a href="/more-services/tour-packages" class="mobile-sub-link">Tour Packages</a>
        </div>
      </div>
      
      <a href="/driver-vacancy" class="mobile-link">Driver Vacancy</a>
      <a href="/contact" class="mobile-link">Contact Us</a>
      <a href="/blog" class="mobile-link">Blog</a>
      
      <a href="https://wa.me/919353966815?text=Hello%20SF%20Travels%2C%20I%20would%20like%20to%20book%20a%20ride." target="_blank" rel="noopener noreferrer" class="btn-gold mobile-call-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        <span>WhatsApp Now</span>
      </a>
    </nav>
  </div>
</div>

<style>
  /* Header Core Styles */
  .header-main {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: linear-gradient(135deg, #1E2D5A 0%, #0d1629 100%);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: var(--transition-smooth);
    padding: 12px 0;
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  /* Premium Logo Section */
  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .logo-svg {
    width: 48px;
    height: 48px;
    filter: drop-shadow(0 2px 8px rgba(197, 168, 92, 0.15));
    transition: var(--transition-smooth);
  }
  
  .logo-wrapper:hover .logo-svg {
    transform: scale(1.05) rotate(5deg);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }
  
  .logo-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.5px;
    background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .logo-title-first {
    color: #ffffff;
    background: none;
    -webkit-text-fill-color: initial;
    -webkit-background-clip: initial;
    transition: var(--transition-smooth);
  }
  
  .logo-tagline {
    font-size: 0.7rem;
    letter-spacing: 0.2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    font-weight: 600;
  }

  /* Desktop Menu Links */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .nav-link {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.98rem;
    color: rgba(255, 255, 255, 0.9);
    position: relative;
    padding: 8px 10px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 2.5px;
    background: #D97706;
    border-radius: 2px;
    transition: all 0.25s ease;
    transform: translateX(-50%);
  }
  
  .nav-link:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }
 
  .nav-link.active {
    color: #ffffff;
    background: #D97706;
  }
  
  .nav-link:hover::after {
    width: calc(100% - 20px);
  }
 
  /* Dropdown Styles */
  .dropdown-wrapper {
    position: relative;
  }
  
  .dropdown-btn {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.98rem;
    color: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .dropdown-btn.active {
    color: #ffffff !important;
    background: #D97706 !important;
  }
  
  .chevron-icon {
    width: 15px;
    height: 15px;
    transition: var(--transition-smooth);
    color: currentColor;
  }
  
  .dropdown-wrapper:hover .dropdown-btn {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }
  
  .dropdown-wrapper:hover .chevron-icon {
    transform: rotate(180deg);
  }
  
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    width: 220px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
    background: #ffffff;
    border: 1px solid rgba(30, 45, 90, 0.1);
    border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12), 0 4px 12px rgba(30,45,90,0.08);
  }
  
  .dropdown-wrapper:hover .dropdown-menu {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }
  
  .dropdown-link {
    font-size: 0.95rem;
    font-weight: 600;
    padding: 9px 14px;
    border-radius: 9px;
    color: #334155;
    transition: all 0.18s ease;
  }
  
  .dropdown-link:hover {
    background: rgba(30, 45, 90, 0.07);
    color: #1E2D5A;
    padding-left: 18px;
  }

  .dropdown-link.active {
    background: rgba(30, 45, 90, 0.07);
    color: #1E2D5A;
    font-weight: 700;
  }

  /* Header Actions & Call button */
  .header-action {
    display: flex;
    align-items: center;
  }
  
  .header-btn {
    padding: 11px 22px;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 10px;
    background: linear-gradient(135deg, #1E2D5A 0%, #2d4080 100%) !important;
    color: #ffffff !important;
    box-shadow: 0 4px 18px rgba(30, 45, 90, 0.28) !important;
    transition: all 0.25s ease;
    border: none !important;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .header-btn:hover {
    background: linear-gradient(135deg, #D97706 0%, #b45309 100%) !important;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(217, 119, 6, 0.35) !important;
  }
  
  .header-btn svg {
    width: 17px !important;
    height: 17px !important;
    color: #ffffff !important;
    flex-shrink: 0;
  }
  
  .mobile-toggle-btn {
    display: none;
    color: #ffffff;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    transition: var(--transition-smooth);
  }
  
  .mobile-toggle-btn:hover {
    color: var(--accent);
  }

  .mobile-toggle-btn svg,
  .mobile-close-btn svg {
    width: 32px;
    height: 32px;
    display: block;
    stroke-width: 2.5;
  }

  /* Mobile slideout structures */
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(15, 23, 42, 0.5);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
  }
  
  .mobile-menu-overlay.open {
    opacity: 1;
    pointer-events: all;
  }
  
  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 80%;
    max-width: 320px;
    border-radius: 0;
    border-top: none;
    border-bottom: none;
    border-right: none;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    transform: translateX(100%);
    transition: var(--transition-smooth);
    background: #ffffff;
    box-shadow: -10px 0 30px rgba(0, 0, 0, 0.05);
  }
  
  .mobile-menu-overlay.open .mobile-menu-panel {
    transform: translateX(0);
  }
  
  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding-bottom: 16px;
  }
  
  .menu-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.3rem;
    color: var(--text-body);
  }
  
  .mobile-close-btn {
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition-smooth);
  }
  
  .mobile-close-btn:hover {
    color: var(--primary);
  }
  
  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow-y: auto;
    max-height: calc(100% - 80px);
    padding-bottom: 40px;
  }
  
  .mobile-link {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 6px 0;
    color: var(--text-body);
  }
  
  .mobile-link:hover, .mobile-link.active {
    color: var(--primary);
  }
  
  .mobile-expandable {
    display: flex;
    flex-direction: column;
  }
  
  .mobile-expand-btn {
    width: 100%;
    text-align: left;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--text-body);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0;
    cursor: pointer;
  }
  
  .mobile-expandable:hover .mobile-expand-btn {
    color: var(--primary);
  }
  
  .mobile-expandable.active .chevron-icon {
    transform: rotate(180deg);
  }
  
  .mobile-submenu {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding-left: 16px;
    margin-top: 4px;
    border-left: 1px dashed rgba(16, 185, 129, 0.2);
  }
  
  .mobile-expandable.active .mobile-submenu {
    display: flex;
  }
  
  .mobile-sub-link {
    font-size: 0.92rem;
    color: var(--text-muted);
    padding: 4px 0;
  }
  
  .mobile-sub-link:hover {
    color: var(--primary);
  }
  
  .mobile-call-btn {
    margin-top: 16px;
    width: 100%;
  }
  
  .mobile-call-btn svg {
    width: 16px !important;
    height: 16px !important;
    flex-shrink: 0;
  }

  /* ==================== SCROLLED HEADER TRANSITION ==================== */
  .header-main.scrolled {
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    padding: 6px 0;
  }
  
  .header-main.scrolled .logo-title {
    background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .header-main.scrolled .logo-title-first {
    color: inherit;
    background: inherit;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
  }
  
  .header-main.scrolled .logo-tagline {
    color: var(--text-muted);
  }
  
  .header-main.scrolled .nav-link,
  .header-main.scrolled .dropdown-btn {
    color: var(--text-body);
  }
  
  .header-main.scrolled .nav-link::after {
    background: #1E2D5A;
  }
  
  .header-main.scrolled .nav-link:hover,
  .header-main.scrolled .dropdown-wrapper:hover .dropdown-btn {
    color: var(--primary);
    background: rgba(30, 45, 90, 0.06);
  }
  
  .header-main.scrolled .nav-link.active {
    color: #ffffff;
    background: #1E2D5A;
  }

  .header-main.scrolled .dropdown-btn.active {
    color: #ffffff !important;
    background: #1E2D5A !important;
  }
  
  .header-main.scrolled .mobile-toggle-btn {
    color: var(--text-body);
  }
  
  .header-main.scrolled .header-btn {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary) 100%) !important;
    color: #ffffff !important;
    border: none !important;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.15) !important;
  }
  
  .header-main.scrolled .header-btn:hover {
    background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-dark) 100%) !important;
    box-shadow: 0 6px 22px rgba(16, 185, 129, 0.25) !important;
    transform: translateY(-2px);
  }
  
  .header-main.scrolled .header-btn svg {
    color: #ffffff !important;
  }

  /* Responsive breakpoints */
  @media (max-width: 992px) {
    .nav-desktop, .header-action {
      display: none;
    }
    
    .mobile-toggle-btn {
      display: block;
    }
  }
</style>

<!-- Mobile Navigation Toggle Logic -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Dynamic Active Link Highlighting
    const normalizePath = (path) => {
      if (path === '/' || !path) return '/';
      return path.replace(/\/$/, '');
    };
    const currentPath = normalizePath(window.location.pathname);
    
    // Desktop Nav Links
    const navLinks = document.querySelectorAll('.nav-desktop .nav-link');
    navLinks.forEach(link => {
      const href = normalizePath(link.getAttribute('href') || '');
      if (href === currentPath || (currentPath.startsWith(href) && href !== '/')) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    // Desktop Dropdowns
    const dropdownWrappers = document.querySelectorAll('.nav-desktop .dropdown-wrapper');
    dropdownWrappers.forEach(wrapper => {
      const dropdownBtn = wrapper.querySelector('.dropdown-btn');
      const dropdownLinks = wrapper.querySelectorAll('.dropdown-link');
      let isAnyLinkActive = false;
      dropdownLinks.forEach(link => {
        const href = normalizePath(link.getAttribute('href') || '');
        if (href === currentPath || (currentPath.startsWith(href) && href !== '/')) {
          link.classList.add('active');
          isAnyLinkActive = true;
        } else {
          link.classList.remove('active');
        }
      });
      if (isAnyLinkActive) {
        dropdownBtn?.classList.add('active');
      } else {
        dropdownBtn?.classList.remove('active');
      }
    });

    // Mobile Links
    const mobileLinks = document.querySelectorAll('.nav-mobile-links .mobile-link');
    mobileLinks.forEach(link => {
      const href = normalizePath(link.getAttribute('href') || '');
      if (href === currentPath || (currentPath.startsWith(href) && href !== '/')) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    const toggleBtn = document.getElementById('mobileToggle');
    const closeBtn = document.getElementById('mobileClose');
    const overlay = document.getElementById('mobileOverlay');
    
    if (toggleBtn && closeBtn && overlay) {
      // Toggle Menu Open
      toggleBtn.addEventListener('click', () => {
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden'; // Stop scroll
      });
      
      // Close Menu
      const closeMenu = () => {
        overlay.classList.remove('open');
        document.body.style.overflow = ''; // Resume scroll
      };
      
      closeBtn.addEventListener('click', closeMenu);
      
      // Close on clicking overlay bg
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          closeMenu();
        }
      });
    }
    
    // Mobile Expandable Dropdowns Logic
    const expandables = document.querySelectorAll('.mobile-expandable');
    expandables.forEach(expandable => {
      const btn = expandable.querySelector('.mobile-expand-btn');
      if (btn) {
        btn.addEventListener('click', () => {
          expandable.classList.toggle('active');
        });
      }
    });

    // Sticky Header Scroll Transition
    const header = document.querySelector('.header-main');
    const handleScroll = () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    };
    
    // Trigger on load as well in case of page refresh
    handleScroll();
    window.addEventListener('scroll', handleScroll, { passive: true });
  });
</script>
