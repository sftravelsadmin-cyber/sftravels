---
// SF Travels Footer Component
const currentYear = new Date().getFullYear();
---

<footer class="footer-main">
  <div class="container footer-grid">
    
    <!-- Column 1: Brand Info -->
    <div class="footer-col brand-col">
      <a href="/" class="footer-logo">
        <div class="logo-text">
          <span class="logo-title"><span class="logo-sf">SF</span> <span class="logo-travels">Travels</span></span>
        </div>
      </a>
      <p class="brand-desc">
        Your premier mobility partner in Bangalore. Offering luxury corporate fleets, reliable airport drops, outstation travels, and bus rentals with certified professional chauffeurs.
      </p>
      
      <!-- Social Buttons -->
      <div class="social-links">
        <a href="#" class="social-btn" aria-label="Follow SF Travels on Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="#" class="social-btn" aria-label="Follow SF Travels on Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
        </a>
        <a href="#" class="social-btn" aria-label="Follow SF Travels on Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Quick Links -->
    <div class="footer-col links-col">
      <h3 class="footer-title">Quick Links</h3>
      <ul class="footer-links-list">
        <li><a href="/" class="footer-link-item"><span class="dot-bullet"></span>Home</a></li>
        <li><a href="/about" class="footer-link-item"><span class="dot-bullet"></span>Our Story</a></li>
        <li><a href="/driver-vacancy" class="footer-link-item"><span class="dot-bullet"></span>Drive With Us</a></li>
        <li><a href="/contact" class="footer-link-item"><span class="dot-bullet"></span>Get in Touch</a></li>
        <li><a href="/blog" class="footer-link-item"><span class="dot-bullet"></span>Travel Guides</a></li>
      </ul>
    </div>

    <!-- Column 3: Our Services -->
    <div class="footer-col links-col">
      <h3 class="footer-title">Our Services</h3>
      <ul class="footer-links-list">
        <li><a href="/services/airport-taxi" class="footer-link-item"><span class="dot-bullet"></span>Airport Transfers</a></li>
        <li><a href="/services/outstation-cabs" class="footer-link-item"><span class="dot-bullet"></span>Intercity Travel</a></li>
        <li><a href="/services/local-hire" class="footer-link-item"><span class="dot-bullet"></span>Hourly Rentals</a></li>
        <li><a href="/services/one-way-taxi" class="footer-link-item"><span class="dot-bullet"></span>One-Way Drop</a></li>
        <li><a href="/more-services/bus-rental" class="footer-link-item"><span class="dot-bullet"></span>Coach & Bus Hire</a></li>
        <li><a href="/more-services/force-urbania" class="footer-link-item"><span class="dot-bullet"></span>Force Urbania Hire</a></li>
        <li><a href="/more-services/tempo-traveller" class="footer-link-item"><span class="dot-bullet"></span>Tempo Traveller Hire</a></li>
        <li><a href="/more-services/marriage-events" class="footer-link-item"><span class="dot-bullet"></span>Wedding Transport</a></li>
        <li><a href="/more-services/tour-packages" class="footer-link-item"><span class="dot-bullet"></span>Holiday Tours</a></li>
      </ul>
    </div>

    <!-- Column 4: Contact Us -->
    <div class="footer-col contact-col">
      <h3 class="footer-title">Contact Us</h3>
      <ul class="contact-details-list">
        <!-- Location -->
        <li class="contact-detail-item">
          <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span class="detail-text">
            Shirke Rd, KHB Colony, Shirke Layout, Kengeri Satellite Town, Bengaluru, Karnataka 560060, India
          </span>
        </li>
        
        <!-- Hours -->
        <li class="contact-detail-item">
          <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          <span class="detail-text">Open 24 Hours</span>
        </li>
        
        <!-- Phone Hotlines -->
        <li class="contact-detail-item">
          <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <div class="phone-group">
            <a href="tel:9353966815" class="phone-link">+91 9353966815</a>
          </div>
        </li>
        
        <!-- Email -->
        <li class="contact-detail-item">
          <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          <a href="mailto:sftravelsadmin@gmail.com" class="email-link">sftravelsadmin@gmail.com</a>
        </li>
      </ul>
    </div>

  </div>

  <!-- Bottom Copyright Bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-container">
      <p class="copyright-text">
        &copy; {currentYear} SF Travels. All rights reserved. "Smooth Ride On Time."
      </p>
      <div class="footer-legal">
        <a href="/privacy" class="legal-link">Privacy Policy</a>
        <span class="divider">|</span>
        <a href="/terms" class="legal-link">Terms &amp; Conditions</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer Core Styles */
  .footer-main {
    background: linear-gradient(135deg, #1E2D5A 0%, #030811 100%);
    border-top: 1px solid rgba(212, 175, 55, 0.15);
    padding-top: 80px;
    color: #e2e8f0;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 40px;
    padding-bottom: 60px;
  }

  /* Column 1: Brand Info styles */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  

  
  .logo-text {
    display: flex;
    flex-direction: column;
  }
  
  .logo-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.45rem;
    letter-spacing: 0.5px;
  }
  
  .logo-sf {
    color: #ffffff;
  }
  
  .logo-travels {
    color: #C5A85C; /* brandGold */
  }
  
  .brand-desc {
    font-size: 0.88rem;
    line-height: 1.6;
    color: #cbd5e1;
    margin-bottom: 24px;
  }
  
  .social-links {
    display: flex;
    gap: 12px;
  }
  
  .social-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-secondary);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: var(--transition-smooth);
  }
  
  .social-btn:hover {
    color: var(--bg-primary);
    background: var(--accent);
    border-color: var(--accent);
    transform: translateY(-3px);
  }

  /* List & Columns Styles */
  .footer-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: #ffffff !important;
    margin-bottom: 24px;
    position: relative;
    padding-bottom: 8px;
  }
  
  .footer-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 35px;
    height: 2px;
    background: var(--accent);
  }
  
  .footer-links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .footer-link-item {
    font-size: 0.9rem;
    color: #cbd5e1;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: var(--transition-smooth);
  }
  
  .dot-bullet {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    transition: var(--transition-smooth);
  }
  
  .footer-link-item:hover {
    color: var(--accent);
    padding-left: 8px;
  }
  
  .footer-link-item:hover .dot-bullet {
    opacity: 1;
  }

  /* Contact Details styles */
  .contact-details-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  
  .contact-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.88rem;
    color: #cbd5e1;
  }
  
  .detail-icon {
    width: 18px;
    height: 18px;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .detail-text {
    line-height: 1.5;
  }
  
  .phone-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .phone-link, .email-link {
    transition: var(--transition-smooth);
  }
  
  .phone-link:hover, .email-link:hover {
    color: var(--accent);
  }

  /* Bottom Copyright Bar styles */
  .footer-bottom {
    background-color: #02050b;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 30px 0;
    margin-top: 40px;
    font-size: 0.8rem;
    color: #94a3b8;
  }
  
  .footer-bottom-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  
  .footer-legal {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .legal-link:hover {
    color: var(--accent);
  }
  
  .divider {
    color: rgba(255, 255, 255, 0.1);
  }
  
  .designer-text {
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.5px;
  }
  
  .accent-gold {
    color: var(--accent);
  }

  /* Responsive breakpoints */
  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }
  }
  
  @media (max-width: 576px) {
    .footer-main {
      padding-top: 60px;
    }
    
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .footer-bottom-container {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
