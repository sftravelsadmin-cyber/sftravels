  /* Safe padding for mobile notch spacing */
  .pb-safe {
    padding-bottom: calc(env(safe-area-inset-bottom, 12px) + 12px);
  }

  /* Styling for the success message modal */
  .form-success-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 13, 26, 0.85);
    backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }
  .form-success-overlay.active {
    display: flex;
  }
  .form-success-card {
    background: white;
    border-radius: 12px;
    padding: 40px;
    max-width: 520px;
    width: 90%;
    text-align: center;
    color: #1e293b;
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
  }
  .success-icon-circle {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(30, 203, 21, 0.1);
    border: 2px solid #1ecb15;
