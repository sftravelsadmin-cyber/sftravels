---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingModal from '../components/BookingModal.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "SF Travels | Smooth Ride On Time - Corporate & Luxury Cab Services", 
  description = "SF Travels offers executive corporate mobility, professional airport transfers, and premium outstation car rentals in Bangalore. Book well-maintained sedans, SUVs, or luxury Force Urbania vans with professional chauffeurs." 
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Leaflet CSS & JS for Interactive Map Selection -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>

    <!-- Global Tailwind CDN with premium Gold & Navy config -->
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <script is:inline>
      tailwind.config = {
        corePlugins: {
          preflight: false,
        },
        theme: {
          extend: {
            colors: {
              // Map legacy green classes to vibrant green/blue for instant global migration
              primaryGreen: '#1E2D5A',
              hoverGreen: '#151f3f',
              
              // Custom brand colors
              brandGreen: {
                DEFAULT: '#1E2D5A',
                hover: '#151f3f',
              },
              brandBlue: {
                DEFAULT: '#1E2D5A',
                hover: '#151f3f',
              },
              brandGold: {
                DEFAULT: '#C5A85C',
                light: '#EBDCB9',
                dark: '#AA8439',
              },
              brandNavy: {
                DEFAULT: '#0A1128',
                light: '#101B37',
                dark: '#050914',
              }
            }
          }
        }
      }
    </script>
  </head>
  <body class="bg-navy-gradient">
    
    <!-- Unified Premium Header -->
    <Header />
    
    <!-- Main Content Slot -->
    <main>
      <slot />
    </main>
    
    <!-- Unified Premium Footer -->
    <Footer />
    
    <!-- Floating Communication Widgets -->
    <div class="floating-widgets">
      <!-- WhatsApp Widget -->
      <a href="https://wa.me/919353966815?text=Hello%20SF%20Travels%2C%20I%20would%20like%20to%20book%20a%20ride." target="_blank" rel="noopener noreferrer" class="widget-btn whatsapp-btn" aria-label="Chat with SF Travels on WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
      </a>
    </div>

    <!-- Global Booking Modal Popup -->
    <BookingModal />

  </body>
</html>

<style>
  /* Floating Communication Buttons styling */
  .floating-widgets {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    display: flex;
    flex-direction: flex-col;
    gap: 16px;
    flex-direction: column;
  }
  
  .widget-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-heading);
    box-shadow: var(--shadow-premium), 0 4px 10px rgba(0,0,0,0.3);
    transition: var(--transition-smooth);
  }
  
  .widget-btn svg {
    width: 24px;
    height: 24px;
  }
  
  .whatsapp-btn {
    background: linear-gradient(135deg, #15803d 0%, #166534 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff !important;
  }
  
  .whatsapp-btn:hover {
    background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
    box-shadow: 0 0 15px rgba(34, 197, 94, 0.5), var(--shadow-premium);
    transform: scale(1.1) rotate(-15deg);
  }

  @media (max-width: 576px) {
    .floating-widgets {
      bottom: 16px;
      right: 16px;
      gap: 12px;
    }
    
    .widget-btn {
      width: 48px;
      height: 48px;
    }
    
    .widget-btn svg {
      width: 20px;
      height: 20px;
    }
  }
</style>
